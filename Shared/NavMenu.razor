@using GymBudgetApp
@using GymBudgetApp.Models
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">GymBudgetApp</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>
<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="budget">
                <span class="oi oi-dollar" aria-hidden="true"></span> Budget
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="seasons">
                <span class="oi oi-calendar" aria-hidden="true"></span> Seasons
            </NavLink>
        </div>
        @if (labels.EnableTeamLevels)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teamlevels">
                    <span class="oi oi-star" aria-hidden="true"></span> @labels.TeamLevels
                </NavLink>
            </div>
        }
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="coaches">
                <span class="oi oi-people" aria-hidden="true"></span> @labels.Coaches
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="meets">
                <span class="oi oi-map-marker" aria-hidden="true"></span> @labels.Meets
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="reports">
                <span class="oi oi-document" aria-hidden="true"></span> Reports
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="import-budget">
                <span class="oi oi-data-transfer-download" aria-hidden="true"></span> Import Budget
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="import-csv">
                <span class="oi oi-spreadsheet" aria-hidden="true"></span> Import CSV
            </NavLink>
        </div>
        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="oi oi-wrench" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
        }
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mt-3">
                    <a href="/SignOut" class="nav-link text-danger">
                        <span class="oi oi-account-logout" aria-hidden="true"></span> Log Out
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
    <NotesPanel />
</div>
@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private ProjectLabels labels = ProjectLabels.Default;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        var adminEmail = Configuration["AdminEmail"] ?? "deshaun@tntgym.org";
        isAdmin = string.Equals(email, adminEmail, StringComparison.OrdinalIgnoreCase);
        if (userId != null)
        {
            var activeSeason = await Db.Seasons.Where(s => s.UserId == userId && s.IsActive).FirstOrDefaultAsync();
            labels = new ProjectLabels(activeSeason);
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
