@using GymBudgetApp
@using GymBudgetApp.Models
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject GymBudgetApp.Services.PermissionService PermissionService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">GymHub</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>
<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <div class="nav-link d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="ToggleAnnouncementPanel">
                <span>
                    <span class="oi oi-bullhorn" aria-hidden="true"></span> Announcements
                    @if (newAnnouncementCount > 0)
                    {
                        <span class="badge bg-danger ms-1">@newAnnouncementCount new</span>
                    }
                </span>
                <span class="oi @(showAnnouncementPanel ? "oi-chevron-bottom" : "oi-chevron-right")" style="font-size: 0.6rem;"></span>
            </div>
            @if (showAnnouncementPanel)
            {
                <div style="padding: 0 0.5rem 0.5rem; max-height: 250px; overflow-y: auto;">
                    @if (recentAnnouncements.Any())
                    {
                        @foreach (var a in recentAnnouncements)
                        {
                            <div style="padding: 6px 8px; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 0.8rem;">
                                <div class="d-flex justify-content-between">
                                    <strong style="color: rgba(255,255,255,0.9);">@a.Title</strong>
                                    @if (a.IsPinned)
                                    {
                                        <span class="oi oi-pin" style="color: #ffc107; font-size: 0.6rem;"></span>
                                    }
                                </div>
                                <div style="color: rgba(255,255,255,0.6); font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@a.Content</div>
                                <small style="color: rgba(255,255,255,0.4);">@a.CreatedAt.ToLocalTime().ToString("MMM dd")</small>
                            </div>
                        }
                        <a href="announcements" class="d-block text-center py-1" style="color: rgba(255,255,255,0.6); font-size: 0.75rem; text-decoration: none;">View All</a>
                    }
                    else
                    {
                        <div class="text-center py-2" style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">No announcements</div>
                    }
                </div>
            }
        </div>
        @if (PermissionService.CanViewMeets)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="calendar">
                    <span class="oi oi-calendar" aria-hidden="true"></span> Calendar
                </NavLink>
            </div>
        }
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="seasons">
                <span class="oi oi-calendar" aria-hidden="true"></span> Seasons
            </NavLink>
        </div>
        @if (labels.EnableTeamLevels && PermissionService.CanViewAthletes)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teamlevels">
                    <span class="oi oi-star" aria-hidden="true"></span> @labels.TeamLevels
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewBudget)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="budget">
                    <span class="oi oi-dollar" aria-hidden="true"></span> Budget
                </NavLink>
            </div>
        }
        @if (labels.EnableTeamLevels && PermissionService.CanViewAthletes)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="athletes">
                    <span class="oi oi-person" aria-hidden="true"></span> Athletes
                </NavLink>
            </div>
        }
        @if (labels.EnableTeamLevels && PermissionService.CanManageRoster)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="roster">
                    <span class="oi oi-list" aria-hidden="true"></span> Roster
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewCoaches)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="coaches">
                    <span class="oi oi-people" aria-hidden="true"></span> @labels.Coaches
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewMeets)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="meets">
                    <span class="oi oi-map-marker" aria-hidden="true"></span> @labels.Meets
                </NavLink>
            </div>
            @if (labels.EnablePerDiem)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="perdiem">
                        <span class="oi oi-basket" aria-hidden="true"></span> Per Diem
                    </NavLink>
                </div>
            }
            @if (labels.EnableMileage)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="mileage">
                        <span class="oi oi-compass" aria-hidden="true"></span> Mileage
                    </NavLink>
                </div>
            }
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="practices">
                    <span class="oi oi-clock" aria-hidden="true"></span> Practices
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewReports)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="reports">
                    <span class="oi oi-document" aria-hidden="true"></span> Reports
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewPayments)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="payments">
                    <span class="oi oi-credit-card" aria-hidden="true"></span> Payments
                </NavLink>
            </div>
        }
        @if (PermissionService.CanViewNotes)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="notes">
                    <span class="oi oi-pencil" aria-hidden="true"></span> Notes
                </NavLink>
            </div>
        }
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="messages">
                <span class="oi oi-envelope-closed" aria-hidden="true"></span> Messages
                @if (unreadMessageCount > 0)
                {
                    <span class="badge bg-danger ms-1">@unreadMessageCount</span>
                }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="gallery">
                <span class="oi oi-image" aria-hidden="true"></span> Gallery
            </NavLink>
        </div>
        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="oi oi-wrench" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
        }
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mt-3">
                    <a href="/SignOut" class="nav-link text-danger">
                        <span class="oi oi-account-logout" aria-hidden="true"></span> Log Out
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
    <NotesPanel />
</div>
@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private ProjectLabels labels = ProjectLabels.Default;
    private bool isAdmin;
    private int unreadMessageCount;
    private int newAnnouncementCount;
    private bool showAnnouncementPanel;
    private List<Announcement> recentAnnouncements = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        var adminEmail = Configuration["AdminEmail"] ?? "deshaun@tntgym.org";
        isAdmin = string.Equals(email, adminEmail, StringComparison.OrdinalIgnoreCase);
        await PermissionService.LoadAsync(userId, email, isAdmin);
        if (userId != null)
        {
            var activeSeason = await Db.Seasons.Where(s => s.IsActive).FirstOrDefaultAsync();
            labels = new ProjectLabels(activeSeason);
            unreadMessageCount = await Db.Messages
                .Where(m => m.RecipientUserId == userId && !m.IsRead)
                .CountAsync();

            // Load recent announcements
            var activeSeason2 = await Db.Seasons.Where(s => s.IsActive).FirstOrDefaultAsync();
            if (activeSeason2 != null)
            {
                recentAnnouncements = await Db.Announcements
                    .Where(a => a.SeasonId == activeSeason2.Id)
                    .OrderByDescending(a => a.IsPinned)
                    .ThenByDescending(a => a.CreatedAt)
                    .Take(5)
                    .ToListAsync();

                var readIds = await Db.AnnouncementReadReceipts
                    .Where(r => r.UserId == userId)
                    .Select(r => r.AnnouncementId)
                    .ToListAsync();
                newAnnouncementCount = recentAnnouncements.Count(a => !readIds.Contains(a.Id));
            }
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleAnnouncementPanel()
    {
        showAnnouncementPanel = !showAnnouncementPanel;
    }
}
