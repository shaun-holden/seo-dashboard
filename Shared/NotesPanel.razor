@using GymBudgetApp.Models
@using GymBudgetApp.Services
@using System.Security.Claims
@inject AppDbContext Db
@inject NotesPanelState PanelState
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<div class="notes-sidebar-section">
    <div class="notes-sidebar-toggle" @onclick="Toggle">
        <span class="oi oi-pencil me-2"></span> Notes
        @if (notes.Any())
        {
            <span class="badge bg-light text-dark ms-1" style="font-size: 0.65rem;">@notes.Count</span>
        }
        <span class="ms-auto oi @(isOpen ? "oi-chevron-bottom" : "oi-chevron-right")" style="font-size: 0.65rem;"></span>
    </div>

    @if (isOpen)
    {
        <div class="notes-sidebar-body">
            @if (PanelState.SeasonId > 0)
            {
                <!-- Add Note -->
                <div class="notes-input">
                    <textarea class="form-control form-control-sm" rows="2" placeholder="Add a note..." @bind="newNote"></textarea>
                    <div class="d-flex gap-1 mt-1">
                        <select class="form-select form-select-sm" style="flex: 1;" @bind="newCategory">
                            <option value="">No category</option>
                            <option value="Budget">Budget</option>
                            <option value="Parent">Parent</option>
                            <option value="Meet">Meet</option>
                            <option value="Team">Team</option>
                            <option value="Todo">To-Do</option>
                        </select>
                        <button class="btn btn-sm btn-primary" style="flex: 1;" @onclick="AddNote">Add</button>
                    </div>
                </div>

                <!-- Search -->
                @if (notes.Count > 3)
                {
                    <div class="mt-2">
                        <input type="text" class="form-control form-control-sm" placeholder="Search notes..."
                               @bind="searchText" @bind:event="oninput" style="font-size: 0.75rem;" />
                    </div>
                }

                <!-- Notes List -->
                <div class="notes-list">
                    @foreach (var note in displayedNotes)
                    {
                        <div class="note-item @(note.IsPinned ? "note-pinned" : "")">
                            @if (editingNoteId == note.Id)
                            {
                                <textarea class="form-control form-control-sm" rows="2" @bind="editContent" style="font-size: 0.8rem;"></textarea>
                                <div class="d-flex gap-1 mt-1">
                                    <select class="form-select form-select-sm" @bind="editCategory" style="font-size: 0.75rem;">
                                        <option value="">No category</option>
                                        <option value="Budget">Budget</option>
                                        <option value="Parent">Parent</option>
                                        <option value="Meet">Meet</option>
                                        <option value="Team">Team</option>
                                        <option value="Todo">To-Do</option>
                                    </select>
                                    <button class="btn btn-sm btn-success px-2" @onclick="() => SaveEdit(note)" style="font-size: 0.7rem;">Save</button>
                                    <button class="btn btn-sm btn-secondary px-2" @onclick="CancelEdit" style="font-size: 0.7rem;">X</button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        @if (note.IsPinned)
                                        {
                                            <span class="oi oi-pin" style="font-size: 0.6rem; color: #ffc107;" title="Pinned"></span>
                                        }
                                        @if (!string.IsNullOrEmpty(note.Category))
                                        {
                                            <span class="badge bg-@GetCategoryColor(note.Category) me-1" style="font-size: 0.6rem;">@note.Category</span>
                                        }
                                        <small class="text-muted" style="font-size: 0.65rem;">@note.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</small>
                                    </div>
                                    <div class="note-actions">
                                        <button class="note-btn" title="@(note.IsPinned ? "Unpin" : "Pin")" @onclick="() => TogglePin(note)">
                                            <span class="oi oi-pin"></span>
                                        </button>
                                        <button class="note-btn" title="Edit" @onclick="() => StartEdit(note)">
                                            <span class="oi oi-pencil"></span>
                                        </button>
                                        <button class="note-btn text-danger" title="Delete" @onclick="() => DeleteNote(note)">
                                            <span class="oi oi-x"></span>
                                        </button>
                                    </div>
                                </div>
                                <div class="note-content">@note.Content</div>
                                @if (!string.IsNullOrEmpty(note.Author))
                                {
                                    <small class="text-muted" style="font-size: 0.6rem;">— @note.Author</small>
                                }
                            }
                        </div>
                    }
                    @if (!displayedNotes.Any())
                    {
                        <p class="text-muted small text-center mt-2">
                            @(string.IsNullOrWhiteSpace(searchText) ? "No notes yet." : "No matching notes.")
                        </p>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small text-center mt-2 px-2">Select a season to view notes.</p>
            }
        </div>
    }
</div>

@code {
    private bool isOpen;
    private string newNote = "";
    private string newCategory = "";
    private string searchText = "";
    private List<SeasonNote> notes = new();
    private string? userEmail;

    private int editingNoteId;
    private string editContent = "";
    private string editCategory = "";

    private List<SeasonNote> displayedNotes
    {
        get
        {
            var list = notes.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchText))
                list = list.Where(n => n.Content.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            return list.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PanelState.OnChange += OnSeasonChanged;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userEmail = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value
                    ?? authState.User.Identity?.Name;
    }

    private void OnSeasonChanged()
    {
        LoadNotes();
        InvokeAsync(StateHasChanged);
    }

    private void Toggle()
    {
        isOpen = !isOpen;
        if (isOpen && PanelState.SeasonId > 0)
            LoadNotes();
    }

    private void LoadNotes()
    {
        if (PanelState.SeasonId > 0)
        {
            notes = Db.SeasonNotes
                .Where(n => n.SeasonId == PanelState.SeasonId)
                .OrderByDescending(n => n.IsPinned)
                .ThenByDescending(n => n.CreatedAt)
                .ToList();
        }
        else
        {
            notes = new();
        }
    }

    private async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(newNote) || PanelState.SeasonId <= 0) return;
        Db.SeasonNotes.Add(new SeasonNote
        {
            Content = newNote.Trim(),
            CreatedAt = DateTime.UtcNow,
            SeasonId = PanelState.SeasonId,
            Category = string.IsNullOrEmpty(newCategory) ? null : newCategory,
            Author = userEmail
        });
        await Db.SaveChangesAsync();
        newNote = "";
        newCategory = "";
        LoadNotes();
    }

    private void StartEdit(SeasonNote note)
    {
        editingNoteId = note.Id;
        editContent = note.Content;
        editCategory = note.Category ?? "";
    }

    private void CancelEdit()
    {
        editingNoteId = 0;
        editContent = "";
        editCategory = "";
    }

    private async Task SaveEdit(SeasonNote note)
    {
        if (string.IsNullOrWhiteSpace(editContent)) return;
        note.Content = editContent.Trim();
        note.Category = string.IsNullOrEmpty(editCategory) ? null : editCategory;
        await Db.SaveChangesAsync();
        editingNoteId = 0;
        LoadNotes();
    }

    private async Task TogglePin(SeasonNote note)
    {
        note.IsPinned = !note.IsPinned;
        await Db.SaveChangesAsync();
        LoadNotes();
    }

    private async Task DeleteNote(SeasonNote note)
    {
        Db.SeasonNotes.Remove(note);
        await Db.SaveChangesAsync();
        LoadNotes();
    }

    private string GetCategoryColor(string category) => category switch
    {
        "Budget" => "success",
        "Parent" => "info",
        "Meet" => "primary",
        "Team" => "warning",
        "Todo" => "danger",
        _ => "secondary"
    };

    public void Dispose()
    {
        PanelState.OnChange -= OnSeasonChanged;
    }
}
