@page
@model GymBudgetApp.Areas.Identity.Pages.Account.Manage.EnableAuthenticatorModel

@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
}

<h4>@ViewData["Title"]</h4>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.StatusMessage.StartsWith("Error") ? "alert-danger" : "alert-success")">
        @Model.StatusMessage
    </div>
}

@if (Model.Is2faEnabled)
{
    <div class="alert alert-success">
        <strong>Two-Factor Authentication is enabled.</strong>
        <p class="mb-0 mt-1">Your account is secured with an authenticator app.</p>
    </div>
}
else
{
    <p>To enable two-factor authentication, follow these steps:</p>
    <ol>
        <li>Download an authenticator app such as <strong>Google Authenticator</strong> or <strong>Authy</strong>.</li>
        <li>Add a new account in the app and enter the following setup key:</li>
    </ol>

    <div class="alert alert-info">
        <strong>Setup Key:</strong> <code class="fs-5">@Model.SharedKey</code>
    </div>

    <p>3. Enter the verification code from your authenticator app below:</p>

    <form method="post">
        <div class="row">
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="Verification Code" />
                    <label asp-for="Input.Code">Verification Code</label>
                    <span asp-validation-for="Input.Code" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Verify & Enable 2FA</button>
            </div>
        </div>
    </form>
}

<div class="mt-3">
    <a href="/admin" class="btn btn-outline-secondary">Back to Admin</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
