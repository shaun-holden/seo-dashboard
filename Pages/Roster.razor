@page "/roster"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Gymnast Roster</h3>
<p class="text-muted">Manage your master list of gymnasts. Use this roster to quickly add athletes to a season.</p>

<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <button class="btn btn-primary" @onclick="ShowAddForm">+ Add Gymnast</button>
    @if (!string.IsNullOrEmpty(filterLevel))
    {
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => filterLevel = null">Clear Filter</button>
    }
    @if (levels.Any())
    {
        <select class="form-select" style="max-width: 200px;" @onchange="OnFilterChanged">
            <option value="">All Levels</option>
            @foreach (var lvl in levels)
            {
                <option value="@lvl" selected="@(lvl == filterLevel)">@lvl</option>
            }
        </select>
    }
    <span class="text-muted">@filteredGymnasts.Count gymnast(s)</span>
</div>

@if (showForm)
{
    <div class="card mb-4 p-3">
        <h5>@(editingGymnast == null ? "Add Gymnast" : "Edit Gymnast")</h5>
        <div class="row">
            <div class="col-md-4 mb-2">
                <label>Name</label>
                <input class="form-control" @bind="formName" placeholder="Gymnast name" />
            </div>
            <div class="col-md-3 mb-2">
                <label>Level</label>
                <input class="form-control" @bind="formLevel" placeholder="e.g. Level 4, Xcel Gold" />
            </div>
            <div class="col-md-3 mb-2">
                <label>Parent Email (optional)</label>
                <input class="form-control" @bind="formParentEmail" placeholder="parent@email.com" />
            </div>
        </div>
        <div>
            <button class="btn btn-success me-2" @onclick="SaveGymnast">Save</button>
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible mb-3">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Level</th>
                    <th>Parent Email</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in filteredGymnasts)
                {
                    <tr>
                        <td><strong>@g.Name</strong></td>
                        <td>@(g.Level ?? "—")</td>
                        <td>@(g.ParentEmail ?? "—")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditGymnast(g)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGymnast(g)">Delete</button>
                        </td>
                    </tr>
                }
                @if (!filteredGymnasts.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No gymnasts yet. Click "+ Add Gymnast" to get started.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Gymnast> gymnasts = new();
    private string? userId;
    private bool showForm;
    private Gymnast? editingGymnast;
    private string formName = "";
    private string formLevel = "";
    private string formParentEmail = "";
    private string? filterLevel;
    private string? successMessage;

    private List<string> levels => gymnasts
        .Where(g => !string.IsNullOrWhiteSpace(g.Level))
        .Select(g => g.Level!)
        .Distinct()
        .OrderBy(l => l)
        .ToList();

    private List<Gymnast> filteredGymnasts => string.IsNullOrEmpty(filterLevel)
        ? gymnasts
        : gymnasts.Where(g => g.Level == filterLevel).ToList();

    private void OnFilterChanged(ChangeEventArgs e)
    {
        filterLevel = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        gymnasts = await db.Gymnasts.AsNoTracking()
            .OrderBy(g => g.Level).ThenBy(g => g.Name)
            .ToListAsync();
    }

    private void ShowAddForm()
    {
        editingGymnast = null;
        formName = "";
        formLevel = "";
        formParentEmail = "";
        showForm = true;
    }

    private void EditGymnast(Gymnast g)
    {
        editingGymnast = g;
        formName = g.Name;
        formLevel = g.Level ?? "";
        formParentEmail = g.ParentEmail ?? "";
        showForm = true;
    }

    private void CancelForm() { showForm = false; editingGymnast = null; }

    private async Task SaveGymnast()
    {
        if (string.IsNullOrWhiteSpace(formName)) return;
        using var db = await DbFactory.CreateDbContextAsync();

        if (editingGymnast != null)
        {
            var entity = await db.Gymnasts.FindAsync(editingGymnast.Id);
            if (entity != null)
            {
                entity.Name = formName.Trim();
                entity.Level = string.IsNullOrWhiteSpace(formLevel) ? null : formLevel.Trim();
                entity.ParentEmail = string.IsNullOrWhiteSpace(formParentEmail) ? null : formParentEmail.Trim();
                await db.SaveChangesAsync();
            }
        }
        else
        {
            db.Gymnasts.Add(new Gymnast
            {
                Name = formName.Trim(),
                Level = string.IsNullOrWhiteSpace(formLevel) ? null : formLevel.Trim(),
                ParentEmail = string.IsNullOrWhiteSpace(formParentEmail) ? null : formParentEmail.Trim(),
                UserId = userId!
            });
            await db.SaveChangesAsync();
        }

        showForm = false;
        editingGymnast = null;
        await LoadData();
    }

    private async Task DeleteGymnast(Gymnast g)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(g.Id);
        if (entity != null)
        {
            db.Gymnasts.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadData();
    }
}
