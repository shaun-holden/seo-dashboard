@page "/roster"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<div class="d-flex align-items-center gap-2 mb-2">
    <a href="/" class="btn btn-sm btn-outline-secondary">
        <span class="oi oi-arrow-left"></span> Back
    </a>
    <h3 class="mb-0">Gymnast Roster</h3>
</div>
<p class="text-muted">Manage your master list of gymnasts. Use this roster to quickly add athletes to a season.</p>

<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <button class="btn btn-primary" @onclick="ShowAddForm">+ Add Gymnast</button>
    @if (!string.IsNullOrEmpty(filterLevel))
    {
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => filterLevel = null">Clear Filter</button>
    }
    @if (levels.Any())
    {
        <select class="form-select" style="max-width: 200px;" @onchange="OnFilterChanged">
            <option value="">All Levels</option>
            @foreach (var lvl in levels)
            {
                <option value="@lvl" selected="@(lvl == filterLevel)">@lvl</option>
            }
        </select>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => showLevelManager = !showLevelManager">
            <span class="oi oi-cog me-1"></span> Manage Levels
        </button>
    }
    <span class="text-muted">@filteredGymnasts.Count gymnast(s)</span>
</div>

@if (showLevelManager)
{
    <div class="card mb-3 p-3">
        <h6>Manage Levels</h6>
        <div class="table-responsive">
            <table class="table table-sm mb-2">
                <thead><tr><th>Level</th><th>Athletes</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var lvl in levels)
                    {
                        var levelName = lvl;
                        var count = gymnasts.Count(g => g.Level == levelName);
                        <tr>
                            <td>
                                @if (renamingLevel == levelName)
                                {
                                    <div class="input-group input-group-sm">
                                        <input class="form-control" @bind="renameNewName" />
                                        <button class="btn btn-success" @onclick="() => ConfirmRename(levelName)">Save</button>
                                        <button class="btn btn-secondary" @onclick="() => renamingLevel = null">X</button>
                                    </div>
                                }
                                else
                                {
                                    <span>@levelName</span>
                                }
                            </td>
                            <td>@count</td>
                            <td>
                                @if (renamingLevel != levelName)
                                {
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartRename(levelName)">Rename</button>
                                    @if (count == 0)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLevel(levelName)">Delete</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLevel(levelName)" title="Removes level from all @count gymnasts">Delete (@count)</button>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="input-group input-group-sm mt-2" style="max-width: 350px;">
            <input class="form-control" @bind="newManagedLevel" placeholder="New level name" />
            <button class="btn btn-primary" @onclick="AddManagedLevel">Add Level</button>
        </div>
        @if (levelMessage != null)
        {
            <div class="alert alert-success py-1 mt-2 mb-0">@levelMessage</div>
        }
    </div>
}

@if (showForm)
{
    <div class="card mb-4 p-3">
        <h5>@(editingGymnast == null ? "Add Gymnast" : "Edit Gymnast")</h5>
        <div class="row">
            <div class="col-md-3 mb-2">
                <label>Name</label>
                <input class="form-control" @bind="formName" placeholder="Gymnast name" />
            </div>
            <div class="col-md-3 mb-2">
                <label>Level</label>
                <div class="input-group">
                    <select class="form-select" @bind="formLevel">
                        <option value="">-- Select or type below --</option>
                        @foreach (var lvl in allLevels)
                        {
                            <option value="@lvl">@lvl</option>
                        }
                    </select>
                </div>
                <div class="input-group input-group-sm mt-1">
                    <input class="form-control" @bind="newLevelName" placeholder="New level name" />
                    <button class="btn btn-outline-primary" type="button" @onclick="AddNewLevel">Add</button>
                </div>
            </div>
            <div class="col-md-7 mb-2">
                <label>Items</label>
                <div class="d-flex flex-wrap gap-3 mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formLeotard" />
                        <label class="form-check-label">Leotard</label>
                        <small class="text-muted d-block">Optional</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formLeggings" />
                        <label class="form-check-label">Leggings</label>
                        <small class="text-muted d-block">Optional</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formTeamBag" />
                        <label class="form-check-label">Team Bag</label>
                        <small class="text-muted d-block">Optional</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formJacket" />
                        <label class="form-check-label">Jacket</label>
                        <small class="text-muted d-block">Optional</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formTeamCamp" disabled />
                        <label class="form-check-label fw-bold">Team Camp</label>
                        <small class="text-danger d-block">Required</small>
                    </div>
                </div>
            </div>
        </div>
        <div>
            <button class="btn btn-success me-2" @onclick="SaveGymnast">Save</button>
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible mb-3">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="roster-table-wrap" style="margin: 0 -2rem; padding: 0;">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Level</th>
                    @foreach (var col in apparelColumns)
                    {
                        <th class="text-center" style="min-width: 80px;">
                            @col.Name
                            @if (col.IsRequired)
                            {
                                <br/><span class="badge bg-danger" style="font-size: 0.6rem;">Required</span>
                            }
                        </th>
                    }
                    @foreach (var col in competitionColumns)
                    {
                        <th class="text-center" style="min-width: 80px;">
                            @col.Name
                            @if (col.IsRequired)
                            {
                                <br/><span class="badge bg-danger" style="font-size: 0.6rem;">Required</span>
                            }
                        </th>
                    }
                    <th class="text-end">Shared Fees</th>
                    <th class="text-end">Apparel</th>
                    <th class="text-end">Competitions</th>
                    <th class="text-end">Total Cost</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in filteredGymnasts)
                {
                    var apparelCost = GetGymnastApparelCost(g);
                    var gymnastTotal = costPerGymnast + apparelCost;
                    <tr>
                        <td><strong>@g.Name</strong></td>
                        <td>@(g.Level ?? "—")</td>
                        @foreach (var col in apparelColumns)
                        {
                            var isChecked = IsGymnastItemChecked(g, col.Name);
                            var itemPrice = GetItemPrice(col.Name, g.Level);
                            var appliesToGymnast = DoesItemApplyToLevel(col.Name, g.Level);
                            var colName = col.Name;
                            var gymnastId = g.Id;
                            <td class="text-center">
                                @if (!appliesToGymnast)
                                {
                                    <span class="text-muted" title="Not applicable to this level">—</span>
                                }
                                else if (col.IsRequired)
                                {
                                    <input type="checkbox" class="form-check-input" checked disabled />
                                    <small class="d-block text-muted">$@itemPrice.ToString("N0")</small>
                                }
                                else
                                {
                                    <input type="checkbox" class="form-check-input" checked="@isChecked"
                                           @onchange="(e) => ToggleApparelItem(gymnastId, colName, (bool)e.Value!)" />
                                    @if (isChecked && itemPrice > 0)
                                    {
                                        <small class="d-block text-muted">$@itemPrice.ToString("N0")</small>
                                    }
                                }
                            </td>
                        }
                        @foreach (var col in competitionColumns)
                        {
                            var compApplies = DoesCompItemApplyToLevel(col.Name, g.Level);
                            var compChecked = IsCompItemChecked(g, col.Name);
                            var compPrice = GetCompItemPrice(col.Name, g.Level);
                            var compColName = col.Name;
                            var compGymnastId = g.Id;
                            <td class="text-center">
                                @if (!compApplies)
                                {
                                    <span class="text-muted">—</span>
                                }
                                else if (col.IsRequired)
                                {
                                    <input type="checkbox" class="form-check-input" checked disabled />
                                    <small class="d-block text-muted">$@compPrice.ToString("N0")</small>
                                }
                                else
                                {
                                    <input type="checkbox" class="form-check-input" checked="@compChecked"
                                           @onchange="(e) => ToggleCompetitionItem(compGymnastId, compColName, (bool)e.Value!)" />
                                    @if (compChecked && compPrice > 0)
                                    {
                                        <small class="d-block text-muted">$@compPrice.ToString("N0")</small>
                                    }
                                }
                            </td>
                        }
                        @{
                            var compCost = GetGymnastCompetitionCost(g);
                            var fullTotal = costPerGymnast + apparelCost + compCost;
                        }
                        <td class="text-end fw-bold text-primary">$@costPerGymnast.ToString("N2")</td>
                        <td class="text-end">$@apparelCost.ToString("N2")</td>
                        <td class="text-end">$@compCost.ToString("N2")</td>
                        <td class="text-end fw-bold">$@fullTotal.ToString("N2")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditGymnast(g)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGymnast(g)">Delete</button>
                        </td>
                    </tr>
                }
                @if (!filteredGymnasts.Any())
                {
                    <tr><td colspan="@(apparelColumns.Count + competitionColumns.Count + 7)" class="text-center text-muted py-3">No gymnasts yet. Click "+ Add Gymnast" to get started.</td></tr>
                }
            </tbody>
            @if (filteredGymnasts.Any())
            {
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td>@filteredGymnasts.Count gymnast(s)</td>
                        <td></td>
                        @foreach (var col in apparelColumns)
                        {
                            var count = filteredGymnasts.Count(g => col.IsRequired || IsGymnastItemChecked(g, col.Name));
                            <td class="text-center">@count</td>
                        }
                        @foreach (var col in competitionColumns)
                        {
                            var count = filteredGymnasts.Count(g => col.IsRequired || IsCompItemChecked(g, col.Name));
                            <td class="text-center">@count</td>
                        }
                        <td class="text-end text-primary">$@((costPerGymnast * filteredGymnasts.Count).ToString("N2"))</td>
                        <td class="text-end">$@filteredGymnasts.Sum(g => GetGymnastApparelCost(g)).ToString("N2")</td>
                        <td class="text-end">$@filteredGymnasts.Sum(g => GetGymnastCompetitionCost(g)).ToString("N2")</td>
                        <td class="text-end">$@GetGrandTotal().ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            }
        </table>
</div>

@code {
    private List<Gymnast> gymnasts = new();
    private string? userId;
    private decimal costPerGymnast;
    private bool showForm;
    private Gymnast? editingGymnast;
    private string formName = "";
    private string formLevel = "";
    private string formParentEmail = "";
    private bool formLeotard;
    private bool formLeggings;
    private bool formTeamBag;
    private bool formJacket;
    private bool formTeamCamp = true;
    private string newLevelName = "";
    private List<string> customLevels = new();
    private bool showLevelManager;
    private string? renamingLevel;
    private string renameNewName = "";
    private string? levelMessage;
    private string newManagedLevel = "";
    private string? filterLevel;
    private string? successMessage;

    private List<string> levels => gymnasts
        .Where(g => !string.IsNullOrWhiteSpace(g.Level))
        .Select(g => g.Level!)
        .Distinct()
        .OrderBy(l => l)
        .ToList();

    private List<string> allLevels => levels
        .Concat(customLevels)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(l => l)
        .ToList();

    private void AddManagedLevel()
    {
        if (string.IsNullOrWhiteSpace(newManagedLevel)) return;
        var name = newManagedLevel.Trim();
        if (!customLevels.Contains(name, StringComparer.OrdinalIgnoreCase) && !levels.Contains(name, StringComparer.OrdinalIgnoreCase))
        {
            customLevels.Add(name);
            levelMessage = $"Level \"{name}\" added. Assign gymnasts to it using the level dropdown.";
        }
        newManagedLevel = "";
    }

    private void StartRename(string level)
    {
        renamingLevel = level;
        renameNewName = level;
        levelMessage = null;
    }

    private async Task ConfirmRename(string oldName)
    {
        if (string.IsNullOrWhiteSpace(renameNewName) || renameNewName.Trim() == oldName)
        {
            renamingLevel = null;
            return;
        }
        using var db = await DbFactory.CreateDbContextAsync();
        var toUpdate = await db.Gymnasts.Where(g => g.Level == oldName).ToListAsync();
        foreach (var g in toUpdate)
            g.Level = renameNewName.Trim();
        await db.SaveChangesAsync();
        levelMessage = $"Renamed \"{oldName}\" to \"{renameNewName.Trim()}\" ({toUpdate.Count} gymnasts updated).";
        renamingLevel = null;
        await LoadData();
    }

    private async Task DeleteLevel(string levelName)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var toUpdate = await db.Gymnasts.Where(g => g.Level == levelName).ToListAsync();
        foreach (var g in toUpdate)
            g.Level = null;
        await db.SaveChangesAsync();
        levelMessage = $"Deleted level \"{levelName}\". {toUpdate.Count} gymnast(s) now have no level.";
        await LoadData();
    }

    private void AddNewLevel()
    {
        if (!string.IsNullOrWhiteSpace(newLevelName) && !allLevels.Contains(newLevelName.Trim(), StringComparer.OrdinalIgnoreCase))
        {
            customLevels.Add(newLevelName.Trim());
        }
        formLevel = newLevelName.Trim();
        newLevelName = "";
    }

    private List<Gymnast> filteredGymnasts => string.IsNullOrEmpty(filterLevel)
        ? gymnasts
        : gymnasts.Where(g => g.Level == filterLevel).ToList();

    private void OnFilterChanged(ChangeEventArgs e)
    {
        filterLevel = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        gymnasts = await db.Gymnasts.AsNoTracking()
            .OrderBy(g => g.Level).ThenBy(g => g.Name)
            .ToListAsync();

        // Calculate cost per gymnast from active season's calculator
        var activeSeason = await db.Seasons.AsNoTracking().FirstOrDefaultAsync(s => s.IsActive);
        if (activeSeason != null)
        {
            var calcTotal = await db.BudgetCalculatorEntries.AsNoTracking()
                .Where(e => e.SeasonId == activeSeason.Id)
                .SumAsync(e => (decimal?)e.CalculatedTotal) ?? 0;
            var athleteCount = activeSeason.AthleteCount > 0 ? activeSeason.AthleteCount : gymnasts.Count;
            costPerGymnast = athleteCount > 0 ? Math.Round(calcTotal / athleteCount, 2) : 0;

            // Load apparel items and selections
            apparelItems = await db.ApparelItems.AsNoTracking()
                .Where(a => a.SeasonId == activeSeason.Id)
                .OrderBy(a => a.IsRequired ? 0 : 1).ThenBy(a => a.Name)
                .ToListAsync();

            // Deduplicate apparel into one column per unique name
            apparelColumns = apparelItems
                .GroupBy(a => a.Name, StringComparer.OrdinalIgnoreCase)
                .Select(g => new ItemColumn(g.Key, g.Any(a => a.IsRequired), "apparel"))
                .ToList();

            // Load competition items
            competitionItems = await db.CompetitionItems.AsNoTracking()
                .Where(a => a.SeasonId == activeSeason.Id)
                .OrderBy(a => a.IsRequired ? 0 : 1).ThenBy(a => a.Name)
                .ToListAsync();

            competitionColumns = competitionItems
                .GroupBy(a => a.Name, StringComparer.OrdinalIgnoreCase)
                .Select(g => new ItemColumn(g.Key, g.Any(a => a.IsRequired), "competition"))
                .ToList();

            var gymnastIds = gymnasts.Select(g => g.Id).ToList();
            apparelSelections = await db.GymnastApparelSelections
                .Where(s => gymnastIds.Contains(s.GymnastId))
                .ToListAsync();
            competitionSelections = await db.GymnastCompetitionSelections
                .Where(s => gymnastIds.Contains(s.GymnastId))
                .ToListAsync();
        }
    }

    private void ShowAddForm()
    {
        editingGymnast = null;
        formName = "";
        formLevel = "";
        formParentEmail = "";
        formLeotard = false;
        formLeggings = false;
        formTeamBag = false;
        formJacket = false;
        formTeamCamp = true;
        showForm = true;
    }

    private void EditGymnast(Gymnast g)
    {
        editingGymnast = g;
        formName = g.Name;
        formLevel = g.Level ?? "";
        formParentEmail = g.ParentEmail ?? "";
        formLeotard = g.Leotard;
        formLeggings = g.Leggings;
        formTeamBag = g.TeamBag;
        formJacket = g.Jacket;
        formTeamCamp = g.TeamCamp;
        showForm = true;
    }

    private void CancelForm() { showForm = false; editingGymnast = null; }

    private async Task SaveGymnast()
    {
        if (string.IsNullOrWhiteSpace(formName)) return;
        using var db = await DbFactory.CreateDbContextAsync();

        if (editingGymnast != null)
        {
            var entity = await db.Gymnasts.FindAsync(editingGymnast.Id);
            if (entity != null)
            {
                entity.Name = formName.Trim();
                entity.Level = string.IsNullOrWhiteSpace(formLevel) ? null : formLevel.Trim();
                entity.ParentEmail = string.IsNullOrWhiteSpace(formParentEmail) ? null : formParentEmail.Trim();
                entity.Leotard = formLeotard;
                entity.Leggings = formLeggings;
                entity.TeamBag = formTeamBag;
                entity.Jacket = formJacket;
                entity.TeamCamp = true;
                await db.SaveChangesAsync();
            }
        }
        else
        {
            db.Gymnasts.Add(new Gymnast
            {
                Name = formName.Trim(),
                Level = string.IsNullOrWhiteSpace(formLevel) ? null : formLevel.Trim(),
                ParentEmail = string.IsNullOrWhiteSpace(formParentEmail) ? null : formParentEmail.Trim(),
                Leotard = formLeotard,
                Leggings = formLeggings,
                TeamBag = formTeamBag,
                Jacket = formJacket,
                TeamCamp = true,
                UserId = userId!
            });
            await db.SaveChangesAsync();
        }

        showForm = false;
        editingGymnast = null;
        await LoadData();
    }

    private List<ApparelItem> apparelItems = new();
    private List<GymnastApparelSelection> apparelSelections = new();
    private List<CompetitionItem> competitionItems = new();
    private List<GymnastCompetitionSelection> competitionSelections = new();

    private record ItemColumn(string Name, bool IsRequired, string Type); // Type: "apparel" or "competition"
    private List<ItemColumn> apparelColumns = new();
    private List<ItemColumn> competitionColumns = new();

    private bool LevelMatchesAppliesTo(string level, string appliesTo)
    {
        var keywords = appliesTo.Split(',').Select(k => k.Trim()).Where(k => k.Length > 0);
        var levelUpper = level.ToUpper().Trim();

        foreach (var keyword in keywords)
        {
            var kwUpper = keyword.ToUpper().Trim();

            // Exact match
            if (levelUpper == kwUpper) return true;

            // Level contains the full keyword (e.g. "Xcel Bronze" contains "Bronze")
            if (kwUpper.Length >= 3 && levelUpper.Contains(kwUpper)) return true;

            // Keyword contains the full level (e.g. "USA/NGA/Xcel Bronze" contains "Xcel Bronze")
            if (kwUpper.Contains(levelUpper)) return true;

            // For short keywords (numbers like "9", "10"), require they appear as a word boundary
            // e.g. "NGA 9" matches "9" but "USA Level 9" should only match if the prefix matches too
            if (kwUpper.Length <= 2)
            {
                // Check if level starts with a prefix that's in the AppliesTo string
                // e.g. "NGA 9" → level must contain "NGA" for "9" to match
                var prefixes = appliesTo.Split(',')[0].Split(' ', '/').Where(p => p.Length >= 3).Select(p => p.Trim().ToUpper());
                if (prefixes.Any(p => levelUpper.Contains(p)) && levelUpper.Contains(kwUpper))
                    return true;
            }
        }
        return false;
    }

    private bool DoesItemApplyToLevel(string itemName, string? level)
    {
        if (string.IsNullOrEmpty(level)) return true;
        var items = apparelItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return false;

        // If any item has no AppliesTo (general), it applies to all
        if (items.Any(a => string.IsNullOrEmpty(a.AppliesTo))) return true;

        // Check if any item's AppliesTo matches this level
        return items.Any(a => !string.IsNullOrEmpty(a.AppliesTo) && LevelMatchesAppliesTo(level, a.AppliesTo));
    }

    private decimal GetItemPrice(string itemName, string? level)
    {
        var items = apparelItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return 0;

        // Check for level-specific pricing
        if (!string.IsNullOrEmpty(level))
        {
            var levelItem = items.FirstOrDefault(a => !string.IsNullOrEmpty(a.AppliesTo) &&
                LevelMatchesAppliesTo(level, a.AppliesTo));
            if (levelItem != null) return levelItem.Price;
        }

        // Only use general pricing (no AppliesTo) — if all items have AppliesTo and none match, return 0
        var generalItem = items.FirstOrDefault(a => string.IsNullOrEmpty(a.AppliesTo));
        return generalItem?.Price ?? 0;
    }

    private bool IsGymnastItemChecked(Gymnast g, string itemName)
    {
        var sel = apparelSelections.FirstOrDefault(s => s.GymnastId == g.Id && s.ItemName == itemName);
        return sel?.IsSelected ?? false;
    }

    private decimal GetGymnastApparelCost(Gymnast g)
    {
        decimal cost = 0;
        foreach (var col in apparelColumns)
        {
            if (!DoesItemApplyToLevel(col.Name, g.Level)) continue;
            if (col.IsRequired || IsGymnastItemChecked(g, col.Name))
            {
                cost += GetItemPrice(col.Name, g.Level);
            }
        }
        return cost;
    }

    private decimal GetGrandTotal()
    {
        return filteredGymnasts.Sum(g => costPerGymnast + GetGymnastApparelCost(g) + GetGymnastCompetitionCost(g));
    }

    // Competition methods
    private bool DoesCompItemApplyToLevel(string itemName, string? level)
    {
        if (string.IsNullOrEmpty(level)) return true;
        var items = competitionItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return false;
        if (items.Any(a => string.IsNullOrEmpty(a.AppliesTo))) return true;
        return items.Any(a => !string.IsNullOrEmpty(a.AppliesTo) && LevelMatchesAppliesTo(level, a.AppliesTo));
    }

    private decimal GetCompItemPrice(string itemName, string? level)
    {
        var items = competitionItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return 0;
        if (!string.IsNullOrEmpty(level))
        {
            var levelItem = items.FirstOrDefault(a => !string.IsNullOrEmpty(a.AppliesTo) && LevelMatchesAppliesTo(level, a.AppliesTo));
            if (levelItem != null) return levelItem.Price;
        }
        var generalItem = items.FirstOrDefault(a => string.IsNullOrEmpty(a.AppliesTo));
        return generalItem?.Price ?? 0;
    }

    private bool IsCompItemChecked(Gymnast g, string itemName)
    {
        var sel = competitionSelections.FirstOrDefault(s => s.GymnastId == g.Id && s.ItemName == itemName);
        return sel?.IsSelected ?? false;
    }

    private decimal GetGymnastCompetitionCost(Gymnast g)
    {
        decimal cost = 0;
        foreach (var col in competitionColumns)
        {
            if (!DoesCompItemApplyToLevel(col.Name, g.Level)) continue;
            if (col.IsRequired || IsCompItemChecked(g, col.Name))
                cost += GetCompItemPrice(col.Name, g.Level);
        }
        return cost;
    }

    private async Task ToggleCompetitionItem(int gymnastId, string itemName, bool isChecked)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.GymnastCompetitionSelections
            .FirstOrDefaultAsync(s => s.GymnastId == gymnastId && s.ItemName == itemName);
        if (existing != null)
            existing.IsSelected = isChecked;
        else
            db.GymnastCompetitionSelections.Add(new GymnastCompetitionSelection { GymnastId = gymnastId, ItemName = itemName, IsSelected = isChecked });
        await db.SaveChangesAsync();

        var localSel = competitionSelections.FirstOrDefault(s => s.GymnastId == gymnastId && s.ItemName == itemName);
        if (localSel != null) localSel.IsSelected = isChecked;
        else competitionSelections.Add(new GymnastCompetitionSelection { GymnastId = gymnastId, ItemName = itemName, IsSelected = isChecked });
    }

    private async Task ToggleApparelItem(int gymnastId, string itemName, bool isChecked)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.GymnastApparelSelections
            .FirstOrDefaultAsync(s => s.GymnastId == gymnastId && s.ItemName == itemName);

        if (existing != null)
        {
            existing.IsSelected = isChecked;
        }
        else
        {
            db.GymnastApparelSelections.Add(new GymnastApparelSelection
            {
                GymnastId = gymnastId,
                ItemName = itemName,
                IsSelected = isChecked
            });
        }
        await db.SaveChangesAsync();

        // Update local state
        var localSel = apparelSelections.FirstOrDefault(s => s.GymnastId == gymnastId && s.ItemName == itemName);
        if (localSel != null)
            localSel.IsSelected = isChecked;
        else
            apparelSelections.Add(new GymnastApparelSelection { GymnastId = gymnastId, ItemName = itemName, IsSelected = isChecked });
    }

    private async Task ToggleItem(int gymnastId, string field, bool value)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(gymnastId);
        if (entity == null) return;

        switch (field)
        {
            case nameof(Gymnast.Leotard): entity.Leotard = value; break;
            case nameof(Gymnast.Leggings): entity.Leggings = value; break;
            case nameof(Gymnast.TeamBag): entity.TeamBag = value; break;
            case nameof(Gymnast.Jacket): entity.Jacket = value; break;
        }
        await db.SaveChangesAsync();

        var local = gymnasts.FirstOrDefault(g => g.Id == gymnastId);
        if (local != null)
        {
            switch (field)
            {
                case nameof(Gymnast.Leotard): local.Leotard = value; break;
                case nameof(Gymnast.Leggings): local.Leggings = value; break;
                case nameof(Gymnast.TeamBag): local.TeamBag = value; break;
                case nameof(Gymnast.Jacket): local.Jacket = value; break;
            }
        }
    }

    private async Task DeleteGymnast(Gymnast g)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(g.Id);
        if (entity != null)
        {
            db.Gymnasts.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadData();
    }
