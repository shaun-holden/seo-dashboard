            existing.CanViewCoaches = editPerm.CanViewCoaches;
            existing.CanViewMeets = editPerm.CanViewMeets;
            existing.CanViewReports = editPerm.CanViewReports;
            existing.CanViewPayments = editPerm.CanViewPayments;
            existing.CanManageRoster = editPerm.CanManageRoster;
            existing.CanViewNotes = editPerm.CanViewNotes;
            await db.SaveChangesAsync();
