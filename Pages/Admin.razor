    }

    private async Task QuickReset(string email)
    {
        resetEmail = email;
        resetPassword = "TntGym2026!";
        await ResetPassword();
    }

    private async Task ResetPassword()
    {
        isResetting = true;
        if (string.IsNullOrWhiteSpace(resetEmail) || string.IsNullOrWhiteSpace(resetPassword))
        {
            SetStatus("Please enter both email and new password.", true);
            isResetting = false;
            return;
        }

        var user = await UserManager.FindByEmailAsync(resetEmail.Trim());
        if (user == null)
        {
            SetStatus($"No user found with email '{resetEmail}'.", true);
            isResetting = false;
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, resetPassword);
        if (result.Succeeded)
        {
            await AuditService.LogAsync(adminUserId, adminEmail, "PasswordReset", $"Reset password for {user.Email}");
            SetStatus($"Password for {user.Email} reset to: {resetPassword}", false);
        }
        else
            SetStatus(string.Join(" ", result.Errors.Select(e => e.Description)), true);

        isResetting = false;
    }

    private string? selectAllMessage;
    private bool isSendingCodes;

    private async Task SelectAllItemsForAllGymnasts()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var gymnasts = await db.Gymnasts.ToListAsync();
        var apparelNames = await db.ApparelItems.Where(a => !a.IsRequired).Select(a => a.Name).Distinct().ToListAsync();
        var compNames = await db.CompetitionItems.Where(c => !c.IsRequired).Select(c => c.Name).Distinct().ToListAsync();
        var count = 0;

        foreach (var g in gymnasts)
        {
            foreach (var name in apparelNames)
            {
                var exists = await db.GymnastApparelSelections.FirstOrDefaultAsync(s => s.GymnastId == g.Id && s.ItemName == name);
                if (exists != null)
                {
                    if (!exists.IsSelected) { exists.IsSelected = true; count++; }
                }
                else
                {
                    db.GymnastApparelSelections.Add(new GymnastApparelSelection { GymnastId = g.Id, ItemName = name, IsSelected = true });
                    count++;
                }
            }
            foreach (var name in compNames)
            {
                var exists = await db.GymnastCompetitionSelections.FirstOrDefaultAsync(s => s.GymnastId == g.Id && s.ItemName == name);
                if (exists != null)
                {
                    if (!exists.IsSelected) { exists.IsSelected = true; count++; }
                }
                else
                {
                    db.GymnastCompetitionSelections.Add(new GymnastCompetitionSelection { GymnastId = g.Id, ItemName = name, IsSelected = true });
                    count++;
                }
            }
        }
        await db.SaveChangesAsync();
        selectAllMessage = $"Done! Selected {count} items across {gymnasts.Count} gymnasts.";
    }

    private async Task ClearAllInviteCodes()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var allLinks = await db.ParentLinks.ToListAsync();
        db.ParentLinks.RemoveRange(allLinks);
        await db.SaveChangesAsync();
        selectAllMessage = $"Cleared {allLinks.Count} old codes. Now click 'Generate All Missing Codes' on the Athletes page to create fresh ones.";
        await LoadData();
    }

    private async Task SendAllInviteCodes()
    {
        isSendingCodes = true;
        selectAllMessage = null;
        StateHasChanged();

        using var db = await DbFactory.CreateDbContextAsync();
        var gymnasts = await db.Gymnasts.ToListAsync();
        var parentLinks = await db.ParentLinks.ToListAsync();
        var users = UserManager.Users.ToList();
        var parentUsers = new List<IdentityUser>();

        // Get all users with Parent role
        foreach (var u in users)
        {
            if (await UserManager.IsInRoleAsync(u, "Parent"))
                parentUsers.Add(u);
        }

        var sent = 0;
        var skipped = 0;

        foreach (var gymnast in gymnasts)
        {
            var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == gymnast.Id);
            if (link == null)
            {
                // Generate code if missing
                link = new ParentLink { AthleteId = gymnast.Id, InviteCode = ParentLink.GenerateCode() };
                db.ParentLinks.Add(link);
                await db.SaveChangesAsync();
                parentLinks.Add(link);
            }

            // Find parent by gymnast's ParentEmail
            if (!string.IsNullOrEmpty(gymnast.ParentEmail))
            {
                var parentUser = parentUsers.FirstOrDefault(u =>
                    string.Equals(u.Email, gymnast.ParentEmail, StringComparison.OrdinalIgnoreCase));

                if (parentUser != null)
                {
                    try
                    {
                        var body = $@"
                            <div style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;'>
                                <h2>Your GymHub Invite Code</h2>
                                <p>Here is your invite code to link <strong>{gymnast.Name}</strong> to your account:</p>
                                <p style='font-size: 1.5em; font-weight: bold; color: #0d6efd; letter-spacing: 3px;'>{link.InviteCode}</p>
                                <p>Steps:</p>
                                <ol>
                                    <li>Log in at <a href='https://gymbudgetapp-production.up.railway.app'>GymHub</a></li>
                                    <li>Go to <strong>Link Athlete</strong></li>
                                    <li>Enter your code: <strong>{link.InviteCode}</strong></li>
                                </ol>
                                <p>Your login: <strong>{parentUser.Email}</strong></p>
                                <hr/>
                                <p style='color: #6c757d;'>Top Notch Training</p>
                            </div>";
                        await EmailSender.SendEmailAsync(parentUser.Email!, "Your GymHub Invite Code", body);
                        sent++;
                    }
                    catch
                    {
                        skipped++;
                    }
                }
                else
                {
                    skipped++;
                }
            }
            else
            {
                skipped++;
            }
        }

        selectAllMessage = $"Sent {sent} invite codes. Skipped {skipped} (no matching parent email or email failed).";
        isSendingCodes = false;
    }

