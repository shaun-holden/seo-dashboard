@page "/admin"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using GymBudgetApp.Models
@using System.Security.Claims
@inject UserManager<IdentityUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IDbContextFactory<AppDbContext> DbFactory
@inject GymBudgetApp.Services.AuditService AuditService
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender

<h3>Admin</h3>

@if (!isAdmin)
{
    <div class="alert alert-danger">Access denied.</div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" @onclick="ExpandAllSections">
                <span class="oi oi-fullscreen-enter me-1"></span> Expand All
            </button>
            <button class="btn btn-outline-secondary" @onclick="CollapseAllSections">
                <span class="oi oi-fullscreen-exit me-1"></span> Collapse All
            </button>
        </div>
        <input type="text" class="form-control" style="max-width: 250px;" placeholder="Search users..."
               @bind="adminSearchText" @bind:event="oninput" />
    </div>

    <!-- Quick Actions -->
    <div class="card mb-4">
        <div class="card-body d-flex gap-2 align-items-center">
            <button class="btn btn-warning me-2" @onclick="SelectAllItemsForAllGymnasts">Select All Items for All Athletes</button>
            <button class="btn btn-primary me-2" @onclick="SendAllInviteCodes" disabled="@isSendingCodes">
                @if (isSendingCodes) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Send All Invite Codes to Parents
            </button>
            <button class="btn btn-outline-danger" @onclick="ClearAllInviteCodes">Clear All Codes & Start Fresh</button>
            @if (selectAllMessage != null)
            {
                <span class="text-success ms-2">@selectAllMessage</span>
            }
        </div>
    </div>

    <!-- Database Backup -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(0)">
            <strong>Database Backup</strong>
            <span class="oi @(expandedSections.Contains(0) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(0))
        {
        <div class="card-body">
            <p class="text-muted mb-2">Auto-backup runs daily. Last 7 days are kept.</p>
            <div class="d-flex gap-2">
                <a href="/api/backup/download" class="btn btn-primary">
                    <span class="oi oi-data-transfer-download me-1"></span> Download Backup
                </a>
                <button class="btn btn-outline-secondary" @onclick="TriggerBackup">
                    <span class="oi oi-reload me-1"></span> Create Backup Now
                </button>
            </div>
        </div>
        }
    </div>

    <!-- Two-Factor Authentication -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(1)">
            <strong>Two-Factor Authentication</strong>
            <span class="oi @(expandedSections.Contains(1) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(1))
        {
        <div class="card-body">
            @if (is2faEnabled)
            {
                <div class="d-flex align-items-center">
                    <span class="badge bg-success me-2">Enabled</span>
                    <span>2FA is active on your account.</span>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center">
                    <span class="badge bg-warning text-dark me-2">Disabled</span>
                    <span>Secure your account with an authenticator app.</span>
                </div>
            }
            <a href="/Identity/Account/Manage/EnableAuthenticator" class="btn btn-outline-primary mt-2">
                @(is2faEnabled ? "Manage 2FA" : "Setup 2FA")
            </a>
        </div>
        }
    </div>

    @if (statusMessage != null)
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <!-- Reset Password -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(2)">
            <strong>Reset User Password</strong>
            <span class="oi @(expandedSections.Contains(2) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(2))
        {
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label>User Email</label>
                    <select class="form-select" @bind="resetEmail">
                        <option value="">-- Select User --</option>
                        @foreach (var u in allUsers)
                        {
                            <option value="@u.Email">@u.Email</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label>New Password</label>
                    <input type="text" class="form-control" @bind="resetPassword" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-warning w-100" @onclick="ResetPassword" disabled="@isResetting">
                        @if (isResetting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Reset Password
                    </button>
                </div>
            </div>
            <div class="mt-2">
                <small class="text-muted">Default: <code>TntGym2026!</code></small>
            </div>
        </div>
        }
    </div>

    <!-- User Management -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(3)">
            <strong>User Management</strong>
            <span class="oi @(expandedSections.Contains(3) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(3))
        {
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in userInfos.Where(u => string.IsNullOrWhiteSpace(adminSearchText) || u.Email.Contains(adminSearchText, StringComparison.OrdinalIgnoreCase)))
                    {
                        var isCurrentAdmin = string.Equals(u.Email, adminEmail, StringComparison.OrdinalIgnoreCase);
                        <tr>
                            <td>@u.Email</td>
                            <td>
                                <span class="badge bg-@(u.Role == "Employee" ? "primary" : u.Role == "Parent" ? "success" : "secondary")">@u.Role</span>
                                @if (isCurrentAdmin)
                                {
                                    <span class="badge bg-dark ms-1">Admin</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!isCurrentAdmin)
                                {
                                    @if (u.Role == "Parent")
                                    {
                                        var uid = u.UserId;
                                        var uemail = u.Email;
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => MakeEmployee(uid, uemail)">
                                            Make Employee
                                        </button>
                                    }
                                    else if (u.Role == "Employee")
                                    {
                                        var uid2 = u.UserId;
                                        var uemail2 = u.Email;
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => MakeParent(uid2, uemail2)">
                                            Make Parent
                                        </button>
                                        <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ShowPermissions(u.UserId, u.Email)">
                                            Permissions
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => QuickReset(u.Email)">
                                        Reset PW
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    </div>

    <!-- Permissions Editor -->
    @if (editingPermUserId != null)
    {
        <div class="card mb-4 border-info">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <strong>Permissions for @editingPermEmail</strong>
                <button class="btn btn-sm btn-light" @onclick="() => editingPermUserId = null">Close</button>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>View Access</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewBudget" />
                            <label class="form-check-label">Budget</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewAthletes" />
                            <label class="form-check-label">Athletes</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewCoaches" />
                            <label class="form-check-label">Coaches</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewMeets" />
                            <label class="form-check-label">Meets</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewReports" />
                            <label class="form-check-label">Reports</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewPayments" />
                            <label class="form-check-label">Payments</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanViewNotes" />
                            <label class="form-check-label">Notes</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Edit Access</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanEditBudget" />
                            <label class="form-check-label">Edit Budget</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanEditAthletes" />
                            <label class="form-check-label">Edit Athletes</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editPerm.CanManageRoster" />
                            <label class="form-check-label">Manage Roster</label>
                        </div>
                    </div>
                </div>
                <button class="btn btn-primary mt-3" @onclick="SavePermissions">Save Permissions</button>
            </div>
        </div>
    }

    <!-- Invite Codes -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(5)">
            <strong>Parent Invite Codes</strong>
            <span class="oi @(expandedSections.Contains(5) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(5))
        {
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Athlete</th><th>Level</th><th>Invite Code</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var info in inviteInfos)
                    {
                        <tr>
                            <td><strong>@info.AthleteName</strong></td>
                            <td>@info.LevelName</td>
                            <td><code class="fs-6">@info.Code</code></td>
                            <td>
                                @if (info.IsClaimed)
                                {
                                    <span class="badge bg-success">Claimed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!inviteInfos.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No invite codes generated yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
        }
    </div>

    <!-- Emergency Contacts -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(7)">
            <strong>Emergency Contacts</strong>
            <span class="oi @(expandedSections.Contains(7) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(7))
        {
        <div class="card-body p-0">
            @if (!emergencyContactInfos.Any())
            {
                <div class="p-3 text-muted text-center">No athletes found.</div>
            }
            else
            {
                <div style="overflow-x: auto;">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Athlete Name</th>
                            <th>Level</th>
                            <th>Emergency Contact</th>
                            <th>Phone</th>
                            <th>Medical Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var info in emergencyContactInfos)
                        {
                            <tr>
                                <td><strong>@info.AthleteName</strong></td>
                                <td>@info.LevelName</td>
                                <td>@(info.EmergencyName ?? "—") @(!string.IsNullOrEmpty(info.Relationship) ? $"({info.Relationship})" : "")</td>
                                <td>@(info.EmergencyPhone ?? "—")</td>
                                <td>@(info.MedicalNotes ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }
        </div>
        }
    </div>

    <!-- Commitment Form Status -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(6)">
            <strong>Commitment Form Status</strong>
            <span class="oi @(expandedSections.Contains(6) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(6))
        {
            <div class="card-body">
                @if (commitmentFormTitle == null)
                {
                    <div class="text-muted">No active commitment form found.</div>
                }
                else
                {
                    <h6>@commitmentFormTitle</h6>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="card bg-light">
                                <div class="card-body text-center py-2">
                                    <small class="text-muted">Total Athletes</small>
                                    <h5 class="mb-0">@commitmentTotalAthletes</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-success text-white">
                                <div class="card-body text-center py-2">
                                    <small>Signed</small>
                                    <h5 class="mb-0">@commitmentSignedCount</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-warning">
                                <div class="card-body text-center py-2">
                                    <small>Unsigned</small>
                                    <h5 class="mb-0">@commitmentUnsignedCount</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (unsignedAthletes.Any())
                    {
                        <h6>Unsigned Athletes</h6>
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr><th>Athlete Name</th><th>Level</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var ua in unsignedAthletes)
                                {
                                    <tr>
                                        <td>@ua.Name</td>
                                        <td>@ua.Level</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        }
    </div>

    <!-- Audit Log -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleSection(8)">
            <strong>Audit Log</strong>
            <span class="oi @(expandedSections.Contains(8) ? "oi-chevron-top" : "oi-chevron-bottom")" style="font-size: 0.7rem;"></span>
        </div>
        @if (expandedSections.Contains(8))
        {
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in auditLogs)
                    {
                        <tr>
                            <td>@entry.Timestamp.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@entry.UserEmail</td>
                            <td><span class="badge bg-secondary">@entry.Action</span></td>
                            <td>@entry.Details</td>
                        </tr>
                    }
                    @if (!auditLogs.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No audit entries yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
        }
    </div>
}

@code {
    private bool isAdmin;
    private string adminSearchText = "";
    private HashSet<int> expandedSections = new() { 0, 1, 2, 3, 5, 8 };
    private string adminEmail = "";
    private string adminUserId = "";
    private bool is2faEnabled;
    private string resetEmail = "";
    private string resetPassword = "TntGym2026!";
    private bool isResetting;
    private string? statusMessage;
    private bool statusIsError;
    private List<IdentityUser> allUsers = new();
    private List<UserInfo> userInfos = new();
    private List<InviteInfo> inviteInfos = new();
    private List<GymBudgetApp.Models.AuditLog> auditLogs = new();

    // Permissions editor
    private string? editingPermUserId;
    private string? editingPermEmail;
    private EmployeePermission editPerm = new();

    private List<EmergencyContactInfo> emergencyContactInfos = new();

    // Commitment form status
    private string? commitmentFormTitle;
    private int commitmentTotalAthletes;
    private int commitmentSignedCount;
    private int commitmentUnsignedCount;
    private List<UnsignedAthleteInfo> unsignedAthletes = new();
    private record UnsignedAthleteInfo(string Name, string Level);

    private record UserInfo(string UserId, string Email, string Role);
    private record InviteInfo(string AthleteName, string LevelName, string Code, bool IsClaimed);
    private record EmergencyContactInfo(string AthleteName, string LevelName, string? EmergencyName, string? EmergencyPhone, string? Relationship, string? MedicalNotes);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        adminUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        adminEmail = Configuration["AdminEmail"] ?? "deshaun@tntgym.org";
        isAdmin = string.Equals(email, adminEmail, StringComparison.OrdinalIgnoreCase);

        if (isAdmin)
        {
            // Check 2FA status
            var adminUser = await UserManager.FindByEmailAsync(adminEmail);
            if (adminUser != null)
                is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(adminUser);

            await LoadData();
        }
    }

    private async Task LoadData()
    {
        allUsers = UserManager.Users.OrderBy(u => u.Email).ToList();
        userInfos = new();
        foreach (var u in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(u);
            userInfos.Add(new UserInfo(u.Id, u.Email ?? "", roles.FirstOrDefault() ?? "None"));
        }

        using var db = await DbFactory.CreateDbContextAsync();
        var links = await db.ParentLinks.AsNoTracking().ToListAsync();
        var athleteIds = links.Select(l => l.AthleteId).ToList();
        var athletes = await db.Athletes.AsNoTracking().Where(a => athleteIds.Contains(a.Id)).ToListAsync();
        var levelIds = athletes.Select(a => a.TeamLevelId).Distinct().ToList();
        var levels = await db.TeamLevels.AsNoTracking().Where(t => levelIds.Contains(t.Id)).ToListAsync();

        inviteInfos = links.Select(l =>
        {
            var athlete = athletes.FirstOrDefault(a => a.Id == l.AthleteId);
            var level = athlete != null ? levels.FirstOrDefault(t => t.Id == athlete.TeamLevelId) : null;
            return new InviteInfo(athlete?.Name ?? "Unknown", level?.Name ?? "", l.InviteCode, l.IsClaimed);
        }).OrderBy(i => i.AthleteName).ToList();

        auditLogs = await db.AuditLogs.AsNoTracking()
            .OrderByDescending(a => a.Timestamp)
            .Take(50)
            .ToListAsync();

        // Load emergency contacts
        var allAthletes = await db.Athletes.AsNoTracking().Include(a => a.TeamLevel).OrderBy(a => a.Name).ToListAsync();
        emergencyContactInfos = allAthletes.Select(a => new EmergencyContactInfo(
            a.Name,
            a.TeamLevel?.Name ?? "",
            a.EmergencyContactName,
            a.EmergencyContactPhone,
            a.EmergencyContactRelationship,
            a.MedicalNotes
        )).ToList();

        // Load commitment form status
        var activeSeason = await db.Seasons.AsNoTracking()
            .Where(s => s.IsActive)
            .OrderByDescending(s => s.Name)
            .FirstOrDefaultAsync();
        if (activeSeason != null)
        {
            var activeForm = await db.CommitmentForms.AsNoTracking()
                .Where(f => f.SeasonId == activeSeason.Id && f.IsActive)
                .OrderByDescending(f => f.CreatedAt)
                .FirstOrDefaultAsync();

            if (activeForm != null)
            {
                commitmentFormTitle = activeForm.Title;
                var signedAthleteIds = await db.CommitmentSignatures.AsNoTracking()
                    .Where(s => s.CommitmentFormId == activeForm.Id)
                    .Select(s => s.AthleteId)
                    .Distinct()
                    .ToListAsync();

                var seasonAthletes = allAthletes
                    .Where(a => a.TeamLevel != null && a.TeamLevel.SeasonId == activeSeason.Id)
                    .ToList();

                commitmentTotalAthletes = seasonAthletes.Count;
                commitmentSignedCount = seasonAthletes.Count(a => signedAthleteIds.Contains(a.Id));
                commitmentUnsignedCount = commitmentTotalAthletes - commitmentSignedCount;

                unsignedAthletes = seasonAthletes
                    .Where(a => !signedAthleteIds.Contains(a.Id))
                    .Select(a => new UnsignedAthleteInfo(a.Name, a.TeamLevel?.Name ?? ""))
                    .OrderBy(a => a.Name)
                    .ToList();
            }
            else
            {
                commitmentFormTitle = null;
            }
        }
    }

    private Task MakeEmployee(string userId, string email) => ChangeRole(userId, email, "Employee");
    private Task MakeParent(string userId, string email) => ChangeRole(userId, email, "Parent");

    private async Task ChangeRole(string userId, string email, string newRole)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user == null) return;

        var currentRoles = await UserManager.GetRolesAsync(user);
        if (currentRoles.Any())
            await UserManager.RemoveFromRolesAsync(user, currentRoles);
        await UserManager.AddToRoleAsync(user, newRole);

        // Create default permissions when making employee
        if (newRole == "Employee")
        {
            using var db = await DbFactory.CreateDbContextAsync();
            if (!await db.EmployeePermissions.AnyAsync(p => p.UserId == userId))
            {
                db.EmployeePermissions.Add(new EmployeePermission { UserId = userId });
                await db.SaveChangesAsync();
            }
        }

        await AuditService.LogAsync(adminUserId, adminEmail, "RoleChanged", $"Changed {email} to {newRole}");
        SetStatus($"{email} is now a {newRole}.", false);
        await LoadData();
    }

    private async Task ShowPermissions(string userId, string email)
    {
        editingPermUserId = userId;
        editingPermEmail = email;
        using var db = await DbFactory.CreateDbContextAsync();
        var perm = await db.EmployeePermissions.FirstOrDefaultAsync(p => p.UserId == userId);
        if (perm == null)
        {
            perm = new EmployeePermission { UserId = userId };
            db.EmployeePermissions.Add(perm);
            await db.SaveChangesAsync();
        }
        editPerm = perm;
    }

    private async Task SavePermissions()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.EmployeePermissions.FirstOrDefaultAsync(p => p.UserId == editingPermUserId);
        if (existing != null)
