@page "/admin"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using GymBudgetApp.Models
@using System.Security.Claims
@inject UserManager<IdentityUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IDbContextFactory<AppDbContext> DbFactory

<h3>Admin</h3>

@if (!isAdmin)
{
    <div class="alert alert-danger">Access denied.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-header"><strong>Reset User Password</strong></div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label>User Email</label>
                    <select class="form-select" @bind="resetEmail">
                        <option value="">-- Select User --</option>
                        @foreach (var u in allUsers)
                        {
                            <option value="@u.Email">@u.Email</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label>New Password</label>
                    <input type="text" class="form-control" @bind="resetPassword" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-warning w-100" @onclick="ResetPassword" disabled="@isResetting">
                        @if (isResetting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Reset Password
                    </button>
                </div>
            </div>
            <div class="mt-2">
                <small class="text-muted">Default: <code>TntGym2026!</code></small>
            </div>

            @if (resetSuccess != null)
            {
                <div class="alert alert-success mt-3 py-2">@resetSuccess</div>
            }
            @if (resetError != null)
            {
                <div class="alert alert-danger mt-3 py-2">@resetError</div>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>All Users</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Email</th><th>Role</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var u in userInfos)
                    {
                        <tr>
                            <td>@u.Email</td>
                            <td><span class="badge bg-@(u.Role == "Employee" ? "primary" : u.Role == "Parent" ? "success" : "secondary")">@u.Role</span></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => QuickReset(u.Email)">
                                    Reset PW
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Parent Invite Codes</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Athlete</th><th>Level</th><th>Invite Code</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var info in inviteInfos)
                    {
                        <tr>
                            <td><strong>@info.AthleteName</strong></td>
                            <td>@info.LevelName</td>
                            <td><code class="fs-6">@info.Code</code></td>
                            <td>
                                @if (info.IsClaimed)
                                {
                                    <span class="badge bg-success">Claimed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!inviteInfos.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No invite codes generated yet. Go to Athletes page to create them.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool isAdmin;
    private string resetEmail = "";
    private string resetPassword = "TntGym2026!";
    private bool isResetting;
    private string? resetSuccess;
    private string? resetError;
    private List<IdentityUser> allUsers = new();
    private List<UserInfo> userInfos = new();
    private List<InviteInfo> inviteInfos = new();

    private record UserInfo(string Email, string Role);
    private record InviteInfo(string AthleteName, string LevelName, string Code, bool IsClaimed);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        var adminEmail = Configuration["AdminEmail"] ?? "deshaun@tntgym.org";
        isAdmin = string.Equals(email, adminEmail, StringComparison.OrdinalIgnoreCase);

        if (isAdmin)
        {
            allUsers = UserManager.Users.OrderBy(u => u.Email).ToList();
            foreach (var u in allUsers)
            {
                var roles = await UserManager.GetRolesAsync(u);
                userInfos.Add(new UserInfo(u.Email ?? "", roles.FirstOrDefault() ?? "None"));
            }

            using var db = await DbFactory.CreateDbContextAsync();
            var links = await db.ParentLinks.AsNoTracking().ToListAsync();
            var athleteIds = links.Select(l => l.AthleteId).ToList();
            var athletes = await db.Athletes.AsNoTracking().Where(a => athleteIds.Contains(a.Id)).ToListAsync();
            var levelIds = athletes.Select(a => a.TeamLevelId).Distinct().ToList();
            var levels = await db.TeamLevels.AsNoTracking().Where(t => levelIds.Contains(t.Id)).ToListAsync();

            inviteInfos = links.Select(l =>
            {
                var athlete = athletes.FirstOrDefault(a => a.Id == l.AthleteId);
                var level = athlete != null ? levels.FirstOrDefault(t => t.Id == athlete.TeamLevelId) : null;
                return new InviteInfo(
                    athlete?.Name ?? "Unknown",
                    level?.Name ?? "",
                    l.InviteCode,
                    l.IsClaimed);
            }).OrderBy(i => i.AthleteName).ToList();
        }
    }

    private async Task QuickReset(string email)
    {
        resetEmail = email;
        resetPassword = "TntGym2026!";
        await ResetPassword();
    }

    private async Task ResetPassword()
    {
        resetSuccess = null;
        resetError = null;
        isResetting = true;

        if (string.IsNullOrWhiteSpace(resetEmail) || string.IsNullOrWhiteSpace(resetPassword))
        {
            resetError = "Please enter both email and new password.";
            isResetting = false;
            return;
        }

        var user = await UserManager.FindByEmailAsync(resetEmail.Trim());
        if (user == null)
        {
            resetError = $"No user found with email '{resetEmail}'.";
            isResetting = false;
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, resetPassword);

        if (result.Succeeded)
        {
            resetSuccess = $"Password for {user.Email} reset to: {resetPassword}";
        }
        else
        {
            resetError = string.Join(" ", result.Errors.Select(e => e.Description));
        }

        isResetting = false;
    }
}
