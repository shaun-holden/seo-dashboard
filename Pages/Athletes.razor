@page "/athletes"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender
@inject NavigationManager NavigationManager

<h3>Athletes</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id" selected="@(s.Id == selectedSeasonId)">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <button class="btn btn-primary" @onclick="ShowAddForm">+ Add Athlete</button>
            @if (teamLevels.Count > 1)
            {
                <select class="form-select" style="max-width: 200px;" value="@filterLevelId"
                        @onchange="OnFilterLevelChanged">
                    <option value="0">All @labels.TeamLevels</option>
                    @foreach (var level in teamLevels)
                    {
                        <option value="@level.Id">@level.Name</option>
                    }
                </select>
            }
            @if (athletes.Any())
            {
                <span class="text-muted">@filteredAthletes.Count athlete(s)</span>
            }
        </div>

        @if (inviteMessage != null)
        {
            <div class="alert alert-success alert-dismissible mb-3">
                @inviteMessage
                <button type="button" class="btn-close" @onclick="() => inviteMessage = null"></button>
            </div>
        }
        @if (inviteError != null)
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                @inviteError
                <button type="button" class="btn-close" @onclick="() => inviteError = null"></button>
            </div>
        }

        @if (showForm)
        {
            <div class="card mb-4 p-3">
                <h5>@(editingAthlete == null ? "Add Athlete" : "Edit Athlete")</h5>
                @if (editingAthlete == null && rosterGymnasts.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Add from Roster</label>
                        <select class="form-select" style="max-width: 400px;" @onchange="OnRosterSelect">
                            <option value="">-- Pick from roster or type below --</option>
                            @foreach (var g in rosterGymnasts)
                            {
                                <option value="@g.Id">@g.Name @(!string.IsNullOrEmpty(g.Level) ? $"({g.Level})" : "")</option>
                            }
                        </select>
                    </div>
                }
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <label>Name</label>
                        <input class="form-control" @bind="formName" placeholder="Athlete name" />
                    </div>
                    <div class="col-md-4 mb-2">
                        <label>@labels.TeamLevel</label>
                        <select class="form-select" @bind="formTeamLevelId">
                            <option value="0">-- Select --</option>
                            @foreach (var level in teamLevels)
                            {
                                <option value="@level.Id">@level.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <button class="btn btn-success me-2" @onclick="SaveAthlete">Save</button>
                    <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
        }

        @foreach (var level in filteredTeamLevels)
        {
            var levelAthletes = filteredAthletes.Where(a => a.TeamLevelId == level.Id).ToList();
            var levelOptionalItems = athleteItems.Where(i => i.TeamLevelId == level.Id && !i.IsRequired).ToList();
            var levelRequiredItems = athleteItems.Where(i => i.TeamLevelId == level.Id && i.IsRequired).ToList();
            var requiredCost = levelRequiredItems.Sum(i => i.Cost);
            var isExpanded = expandedLevels.Contains(level.Id);

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center"
                     @onclick="() => ToggleLevel(level.Id)" style="cursor: pointer;">
                    <div>
                        <h5 class="mb-0 d-inline">@level.Name</h5>
                        <span class="badge bg-primary ms-2">@levelAthletes.Count athlete(s)</span>
                        @if (levelOptionalItems.Any())
                        {
                            <span class="badge bg-info ms-1">@levelOptionalItems.Count optional item(s)</span>
                        }
                    </div>
                    <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                </div>
                @if (isExpanded)
                {
                <div class="card-body p-0">
                    @if (!levelAthletes.Any())
                    {
                        <div class="p-3 text-muted">No athletes in this level yet.</div>
                    }
                    else
                    {
                        <div style="overflow-x: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Athlete</th>
                                    @foreach (var item in levelRequiredItems)
                                    {
                                        <th class="text-center" style="min-width: 90px;">
                                            <span class="badge bg-success">@item.Name</span>
                                            <br/><small class="text-muted">$@item.Cost.ToString("N2")</small>
                                        </th>
                                    }
                                    @foreach (var item in levelOptionalItems)
                                    {
                                        <th class="text-center" style="min-width: 90px;">
                                            @item.Name
                                            <br/><small class="text-muted">$@item.Cost.ToString("N2")</small>
                                        </th>
                                    }
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var athlete in levelAthletes)
                                {
                                    var athleteSelections = selections.Where(s => s.AthleteId == athlete.Id).Select(s => s.AthleteItemId).ToHashSet();
                                    var optionalCost = levelOptionalItems.Where(i => athleteSelections.Contains(i.Id)).Sum(i => i.Cost);
                                    var totalCost = requiredCost + optionalCost;

                                    <tr>
                                        <td><strong>@athlete.Name</strong></td>
                                        @foreach (var item in levelRequiredItems)
                                        {
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input" checked disabled />
                                            </td>
                                        }
                                        @foreach (var item in levelOptionalItems)
                                        {
                                            var itemId = item.Id;
                                            var athleteId = athlete.Id;
                                            var isSelected = athleteSelections.Contains(itemId);
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input" checked="@isSelected"
                                                       @onchange="(e) => ToggleSelection(athleteId, itemId, (bool)e.Value!)" />
                                            </td>
                                        }
                                        <td class="text-end fw-bold">$@totalCost.ToString("N2")</td>
                                        <td class="text-end">
                                            @{
                                                var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == athlete.Id);
                                            }
                                            @if (link != null)
                                            {
                                                <span class="badge @(link.IsClaimed ? "bg-success" : "bg-secondary") font-monospace me-1" title="@(link.IsClaimed ? "Claimed" : "Pending")">@link.InviteCode</span>
                                                <button class="btn btn-sm btn-outline-warning me-1" title="Regenerate invite code" @onclick="() => ShowInviteForm(athlete.Id)">
                                                    <span class="oi oi-reload"></span>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => GenerateCodeOnly(athlete.Id)">Code</button>
                                                <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ShowInviteForm(athlete.Id)">Email Invite</button>
                                            }
                                            @if (showInviteForm && inviteAthleteId == athlete.Id)
                                            {
                                                <div class="d-inline-flex align-items-center gap-1 ms-1">
                                                    <input type="email" class="form-control form-control-sm" style="width: 200px;"
                                                           placeholder="Parent email" @bind="inviteEmail" />
                                                    <button class="btn btn-sm btn-success" @onclick="() => SendInviteEmail(athlete)">Send</button>
                                                    <button class="btn btn-sm btn-secondary" @onclick="CancelInviteForm">X</button>
                                                </div>
                                            }
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditAthlete(athlete)">Edit</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAthlete(athlete)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td>Level Summary</td>
                                    @foreach (var item in levelRequiredItems)
                                    {
                                        <td class="text-center">@levelAthletes.Count</td>
                                    }
                                    @foreach (var item in levelOptionalItems)
                                    {
                                        var selectedCount = levelAthletes.Count(a => selections.Any(s => s.AthleteId == a.Id && s.AthleteItemId == item.Id));
                                        <td class="text-center">@selectedCount / @levelAthletes.Count</td>
                                    }
                                    @{
                                        var levelTotalCost = levelAthletes.Sum(a =>
                                        {
                                            var sel = selections.Where(s => s.AthleteId == a.Id).Select(s => s.AthleteItemId).ToHashSet();
                                            return requiredCost + levelOptionalItems.Where(i => sel.Contains(i.Id)).Sum(i => i.Cost);
                                        });
                                    }
                                    <td class="text-end fw-bold">$@levelTotalCost.ToString("N2")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                        </div>
                    }
                </div>
                }
            </div>
        }
    }
}

@code {
    private List<Season>? seasons;
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<Athlete> athletes = new();
    private List<AthleteItemSelection> selections = new();
    private List<ParentLink> parentLinks = new();
    private int selectedSeasonId;
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;

    private bool showForm;
    private Athlete? editingAthlete;
    private string formName = "";
    private int formTeamLevelId;

    private int filterLevelId = 0;
    private HashSet<int> expandedLevels = new();
    private List<Gymnast> rosterGymnasts = new();

    private bool showInviteForm;
    private int inviteAthleteId;
    private string inviteEmail = "";
    private string? inviteMessage;
    private string? inviteError;

    private void OnFilterLevelChanged(ChangeEventArgs e) { filterLevelId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; }

    private void ToggleLevel(int levelId)
    {
        if (!expandedLevels.Remove(levelId))
            expandedLevels.Add(levelId);
    }

    private List<TeamLevel> filteredTeamLevels => filterLevelId > 0
        ? teamLevels.Where(t => t.Id == filterLevelId).ToList()
        : teamLevels;

    private List<Athlete> filteredAthletes => filterLevelId > 0
        ? athletes.Where(a => a.TeamLevelId == filterLevelId).ToList()
        : athletes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Db.Seasons.OrderByDescending(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var levelIds = teamLevels.Select(t => t.Id).ToList();
        athleteItems = await db.AthleteItems.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        athletes = await db.Athletes.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).OrderBy(a => a.Name).ToListAsync();
        var athleteIds = athletes.Select(a => a.Id).ToList();
        selections = await db.AthleteItemSelections.AsNoTracking().Where(s => athleteIds.Contains(s.AthleteId)).ToListAsync();
        parentLinks = await db.ParentLinks.AsNoTracking().Where(pl => athleteIds.Contains(pl.AthleteId)).ToListAsync();

        // Auto-expand levels that have athletes
        expandedLevels = athletes.Select(a => a.TeamLevelId).Distinct().ToHashSet();

        // Load roster for quick-add (exclude already added names)
        var existingNames = athletes.Select(a => a.Name.ToLower()).ToHashSet();
        rosterGymnasts = await db.Gymnasts.AsNoTracking()
            .Where(g => !existingNames.Contains(g.Name.ToLower()))
            .OrderBy(g => g.Name)
            .ToListAsync();
    }

    private void OnRosterSelect(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var gymnastId))
        {
            var g = rosterGymnasts.FirstOrDefault(r => r.Id == gymnastId);
            if (g != null)
            {
                formName = g.Name;
                // Try to match roster level to a team level
                var matchedLevel = teamLevels.FirstOrDefault(t =>
                    t.Name.Equals(g.Level, StringComparison.OrdinalIgnoreCase));
                if (matchedLevel != null)
                    formTeamLevelId = matchedLevel.Id;
            }
        }
    }

    private void ShowAddForm()
    {
        editingAthlete = null;
        formName = "";
        formTeamLevelId = teamLevels.FirstOrDefault()?.Id ?? 0;
        showForm = true;
    }

    private void EditAthlete(Athlete athlete)
    {
        editingAthlete = athlete;
        formName = athlete.Name;
        formTeamLevelId = athlete.TeamLevelId;
        showForm = true;
    }

    private void CancelForm() { showForm = false; editingAthlete = null; }

    private async Task SaveAthlete()
    {
        if (string.IsNullOrWhiteSpace(formName) || formTeamLevelId == 0) return;
        using var db = await DbFactory.CreateDbContextAsync();

        if (editingAthlete != null)
        {
            var entity = await db.Athletes.FindAsync(editingAthlete.Id);
            if (entity != null)
            {
                entity.Name = formName.Trim();
                entity.TeamLevelId = formTeamLevelId;
                await db.SaveChangesAsync();
            }
        }
        else
        {
            db.Athletes.Add(new Athlete { Name = formName.Trim(), TeamLevelId = formTeamLevelId });
            await db.SaveChangesAsync();
        }

        showForm = false;
        editingAthlete = null;
        await LoadData();
    }

    private async Task DeleteAthlete(Athlete athlete)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Athletes.FindAsync(athlete.Id);
        if (entity != null)
        {
            db.Athletes.Remove(entity);
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private void ShowInviteForm(int athleteId)
    {
        inviteAthleteId = athleteId;
        inviteEmail = "";
        showInviteForm = true;
    }

    private void CancelInviteForm()
    {
        showInviteForm = false;
        inviteAthleteId = 0;
        inviteEmail = "";
    }

    private async Task GenerateCodeOnly(int athleteId)
    {
        inviteMessage = null;
        inviteError = null;
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == athleteId);
        if (existing != null) return; // already has a code

        var code = ParentLink.GenerateCode();
        db.ParentLinks.Add(new ParentLink { AthleteId = athleteId, InviteCode = code });
        await db.SaveChangesAsync();

        var athlete = await db.Athletes.FindAsync(athleteId);
        inviteMessage = $"Code generated for {athlete?.Name ?? "athlete"}: {code}";
        await LoadData();
    }

    private async Task SendInviteEmail(Athlete athlete)
    {
        if (string.IsNullOrWhiteSpace(inviteEmail)) return;
        inviteMessage = null;
        inviteError = null;

        using var db = await DbFactory.CreateDbContextAsync();
        string inviteCode;

        var existingLink = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == athlete.Id);
        if (existingLink != null)
        {
            existingLink.InviteCode = ParentLink.GenerateCode();
            existingLink.IsClaimed = false;
            existingLink.ParentUserId = null;
            existingLink.ClaimedAt = null;
            inviteCode = existingLink.InviteCode;
            await db.SaveChangesAsync();
        }
        else
        {
            inviteCode = ParentLink.GenerateCode();
            db.ParentLinks.Add(new ParentLink
            {
                AthleteId = athlete.Id,
                InviteCode = inviteCode
            });
            await db.SaveChangesAsync();
        }

        var registerUrl = $"{NavigationManager.BaseUri}Identity/Account/Register";
        var emailBody = $@"
            <div style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;'>
                <h2>You're Invited to Top Notch Training!</h2>
                <p>You have been invited to manage <strong>{athlete.Name}</strong>'s account on Top Notch Training.</p>
                <p>Your invite code is: <strong style='font-size: 1.2em; color: #0d6efd;'>{inviteCode}</strong></p>
                <p>To get started, create your account by clicking the link below:</p>
                <p><a href='{registerUrl}' style='display: inline-block; padding: 10px 20px; background-color: #0d6efd; color: #ffffff; text-decoration: none; border-radius: 5px;'>Register Now</a></p>
                <p>After registering, use your invite code to link to your athlete's account.</p>
                <hr style='border: none; border-top: 1px solid #dee2e6;' />
                <p style='color: #6c757d; font-size: 0.9em;'>Top Notch Training</p>
            </div>";

        try
        {
            await EmailSender.SendEmailAsync(inviteEmail, "You're invited to Top Notch Training", emailBody);
            inviteMessage = $"Invite sent to {inviteEmail} for {athlete.Name} (Code: {inviteCode})";
        }
        catch (Exception ex)
        {
            inviteError = $"Email failed: {ex.Message}. Invite code {inviteCode} was still generated.";
        }

        showInviteForm = false;
        inviteAthleteId = 0;
        inviteEmail = "";
        await LoadData();
    }

    private async Task GenerateInvite(int athleteId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        if (!await db.ParentLinks.AnyAsync(pl => pl.AthleteId == athleteId))
        {
            db.ParentLinks.Add(new ParentLink
            {
                AthleteId = athleteId,
                InviteCode = ParentLink.GenerateCode()
            });
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private async Task RegenerateInvite(int linkId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var link = await db.ParentLinks.FindAsync(linkId);
        if (link != null)
        {
            link.InviteCode = ParentLink.GenerateCode();
            link.IsClaimed = false;
            link.ParentUserId = null;
            link.ClaimedAt = null;
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private async Task ToggleSelection(int athleteId, int itemId, bool isChecked)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        if (isChecked)
        {
            if (!await db.AthleteItemSelections.AnyAsync(s => s.AthleteId == athleteId && s.AthleteItemId == itemId))
                db.AthleteItemSelections.Add(new AthleteItemSelection { AthleteId = athleteId, AthleteItemId = itemId });
        }
        else
        {
            var existing = await db.AthleteItemSelections.FirstOrDefaultAsync(s => s.AthleteId == athleteId && s.AthleteItemId == itemId);
            if (existing != null) db.AthleteItemSelections.Remove(existing);
        }
        await db.SaveChangesAsync();
        await LoadData();
    }
}
