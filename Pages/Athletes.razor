@page "/athletes"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration

<h3>Athletes</h3>

@if (gymnasts == null)
{
    <p>Loading...</p>
}
else
{
    <p class="text-muted">Manage gymnasts on the <a href="/roster">Roster page</a>.</p>

    @if (gymnasts.Any(g => !parentLinks.Any(pl => pl.AthleteId == g.Id)))
    {
        <button class="btn btn-success mb-3" @onclick="GenerateAllCodes">
            <span class="oi oi-key me-1"></span> Generate All Missing Codes
        </button>
    }

    @if (bulkMessage != null)
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @bulkMessage
            <button type="button" class="btn-close" @onclick="() => bulkMessage = null"></button>
        </div>
    }

    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <input type="text" class="form-control" style="max-width: 200px;" placeholder="Search athlete..."
               @bind="searchText" @bind:event="oninput" />
        @if (allLevels.Count > 1)
        {
            <select class="form-select" style="max-width: 200px;" value="@filterLevel"
                    @onchange="OnFilterLevelChanged">
                <option value="">All Levels</option>
                @foreach (var level in allLevels)
                {
                    <option value="@level">@level</option>
                }
            </select>
        }
        @if (gymnasts.Any())
        {
            <span class="text-muted">@filteredGymnasts.Count athlete(s)</span>
        }
    </div>

    @if (deleteConfirmId != null)
    {
        <div class="alert alert-danger mb-3">
            <h6 class="alert-heading">Delete @deleteConfirmName?</h6>
            @if (deleteHasLink)
            {
                <p class="mb-2"><strong>This athlete is linked to a parent account.</strong> Deleting will remove their parent link, payment history, and all related data. The parent will no longer see this athlete.</p>
            }
            else
            {
                <p class="mb-2">This will permanently delete this athlete and all related data.</p>
            }
            <button class="btn btn-danger me-2" @onclick="DeleteGymnast">Yes, Delete</button>
            <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
        </div>
    }

    @if (inviteMessage != null)
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @inviteMessage
            <button type="button" class="btn-close" @onclick="() => inviteMessage = null"></button>
        </div>
    }
    @if (inviteError != null)
    {
        <div class="alert alert-danger alert-dismissible mb-3">
            @inviteError
            <button type="button" class="btn-close" @onclick="() => inviteError = null"></button>
        </div>
    }

    @foreach (var group in filteredGroups)
    {
        var levelGymnasts = group.Value;
        var levelName = group.Key;
        var isExpanded = expandedLevels.Contains(levelName);

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleLevel(levelName)" style="cursor: pointer;">
                <div>
                    <h5 class="mb-0 d-inline">@levelName</h5>
                    <span class="badge bg-primary ms-2">@levelGymnasts.Count athlete(s)</span>
                </div>
                <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>
            @if (isExpanded)
            {
            <div class="card-body p-0">
                @if (!levelGymnasts.Any())
                {
                    <div class="p-3 text-muted">No athletes in this level yet.</div>
                }
                else
                {
                    <div style="overflow-x: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Level</th>
                                <th>Invite Code</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gymnast in levelGymnasts)
                            {
                                <tr>
                                    <td><strong>@gymnast.Name</strong></td>
                                    <td>
                                        <select class="form-select form-select-sm d-inline-block" style="width: 150px;"
                                                value="@gymnast.Level"
                                                @onchange="(e) => UpdateLevel(gymnast.Id, e.Value?.ToString())">
                                            <option value="">-- Select --</option>
                                            @foreach (var lvl in allLevels)
                                            {
                                                <option value="@lvl">@lvl</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(gymnast.ParentEmail))
                                        {
                                            <small class="text-muted me-2">@gymnast.ParentEmail</small>
                                        }
                                        @if (!string.IsNullOrEmpty(gymnast.ParentEmail2))
                                        {
                                            <small class="text-muted me-2">| @gymnast.ParentEmail2</small>
                                        }
                                        @{
                                            var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == gymnast.Id);
                                        }
                                        @if (link != null)
                                        {
                                            <span class="badge @(link.IsClaimed ? "bg-success" : "bg-secondary") font-monospace" title="@(link.IsClaimed ? "Claimed" : "Pending")">@link.InviteCode</span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => GenerateCodeOnly(gymnast.Id)">Code</button>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (link != null)
                                        {
                                            <button class="btn btn-sm btn-outline-warning me-1" title="Regenerate invite code" @onclick="() => ShowInviteForm(gymnast.Id)">
                                                <span class="oi oi-reload"></span>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ShowInviteForm(gymnast.Id)">Email Invite</button>
                                        @if (showInviteForm && inviteGymnastId == gymnast.Id)
                                        {
                                            <div class="d-inline-flex align-items-center gap-1 ms-1">
                                                <input type="email" class="form-control form-control-sm" style="width: 200px;"
                                                       placeholder="Parent email" @bind="inviteEmail" />
                                                <button class="btn btn-sm btn-success" @onclick="() => SendInviteEmail(gymnast)">Send</button>
                                                <button class="btn btn-sm btn-secondary" @onclick="CancelInviteForm">X</button>
                                            </div>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ToggleProfile(gymnast.Id)">Profile</button>
                                        <a class="btn btn-sm btn-outline-primary me-1" href="/roster">Edit</a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteGymnast(gymnast.Id, gymnast.Name)">Delete</button>
                                    </td>
                                </tr>
                                @if (profileGymnastId == gymnast.Id)
                                {
                                    <tr>
                                        <td colspan="8">
                                            <div class="card border-info m-2">
                                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                                    <strong>Profile - @gymnast.Name</strong>
                                                    <button class="btn btn-sm btn-light" @onclick="() => profileGymnastId = null">Close</button>
                                                </div>
                                                <div class="card-body">
                                                    <div class="row">
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Parent 1 Email</label>
                                                            <input type="email" class="form-control" @bind="profileParentEmail" placeholder="parent1@example.com" />
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Parent 2 Email</label>
                                                            <input type="email" class="form-control" @bind="profileParentEmail2" placeholder="parent2@example.com" />
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Level</label>
                                                            <input type="text" class="form-control" value="@gymnast.Level" disabled />
                                                        </div>
                                                    </div>
                                                    <h6 class="mt-2">Sizes</h6>
                                                    <div class="row">
                                                        <div class="col-md-3 mb-3">
                                                            <label class="form-label">Leotard Size</label>
                                                            <select class="form-select" @bind="profileLeotardSize">
                                                                <option value="">-- Select --</option>
                                                                <option value="CXS">Child XS</option><option value="CS">Child S</option><option value="CM">Child M</option><option value="CL">Child L</option><option value="CXL">Child XL</option>
                                                                <option value="AXS">Adult XS</option><option value="AS">Adult S</option><option value="AM">Adult M</option><option value="AL">Adult L</option><option value="AXL">Adult XL</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-3 mb-3">
                                                            <label class="form-label">Leggings Size</label>
                                                            <select class="form-select" @bind="profileLeggingsSize">
                                                                <option value="">-- Select --</option>
                                                                <option value="YXS">Youth XS</option><option value="YS">Youth S</option><option value="YM">Youth M</option><option value="YL">Youth L</option><option value="YXL">Youth XL</option>
                                                                <option value="AS">Adult S</option><option value="AM">Adult M</option><option value="AL">Adult L</option><option value="AXL">Adult XL</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-3 mb-3">
                                                            <label class="form-label">Pants Size</label>
                                                            <select class="form-select" @bind="profilePantsSize">
                                                                <option value="">-- Select --</option>
                                                                <option value="YXS">Youth XS</option><option value="YS">Youth S</option><option value="YM">Youth M</option><option value="YL">Youth L</option><option value="YXL">Youth XL</option>
                                                                <option value="AS">Adult S</option><option value="AM">Adult M</option><option value="AL">Adult L</option><option value="AXL">Adult XL</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-3 mb-3">
                                                            <label class="form-label">Shirt Size</label>
                                                            <select class="form-select" @bind="profileShirtSize">
                                                                <option value="">-- Select --</option>
                                                                <option value="YXS">Youth XS</option><option value="YS">Youth S</option><option value="YM">Youth M</option><option value="YL">Youth L</option><option value="YXL">Youth XL</option>
                                                                <option value="AS">Adult S</option><option value="AM">Adult M</option><option value="AL">Adult L</option><option value="AXL">Adult XL</option><option value="AXXL">Adult XXL</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <button class="btn btn-success" @onclick="SaveProfile">Save Profile</button>
                                                    @if (profileSaveMessage != null)
                                                    {
                                                        <span class="text-success ms-2">@profileSaveMessage</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>
            }
        </div>
    }
}

@code {
    private List<Gymnast>? gymnasts;
    private List<ParentLink> parentLinks = new();
    private List<string> allLevels = new();

    private string filterLevel = "";
    private string searchText = "";
    private HashSet<string> expandedLevels = new();

    private bool showInviteForm;
    private int inviteGymnastId;
    private string inviteEmail = "";
    private string? inviteMessage;
    private string? inviteError;

    // Profile state
    private int? profileGymnastId;
    private string? profileParentEmail;
    private string? profileParentEmail2;
    private string? profileLeotardSize;
    private string? profileLeggingsSize;
    private string? profilePantsSize;
    private string? profileShirtSize;
    private string? profileSaveMessage;

    private void OnFilterLevelChanged(ChangeEventArgs e) { filterLevel = e.Value?.ToString() ?? ""; }

    private void ToggleLevel(string levelName)
    {
        if (!expandedLevels.Remove(levelName))
            expandedLevels.Add(levelName);
    }

    private List<Gymnast> filteredGymnasts
    {
        get
        {
            IEnumerable<Gymnast> list = gymnasts ?? new();
            if (!string.IsNullOrWhiteSpace(filterLevel))
                list = list.Where(g => string.Equals(g.Level, filterLevel, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(searchText))
                list = list.Where(g => g.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            return list.ToList();
        }
    }

    private List<KeyValuePair<string, List<Gymnast>>> filteredGroups
    {
        get
        {
            return filteredGymnasts
                .GroupBy(g => g.Level ?? "Unassigned")
                .OrderBy(g => g.Key)
                .Select(g => new KeyValuePair<string, List<Gymnast>>(g.Key, g.OrderBy(x => x.Name).ToList()))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        gymnasts = await db.Gymnasts.AsNoTracking().OrderBy(g => g.Name).ToListAsync();
        var gymnastIds = gymnasts.Select(g => g.Id).ToList();
        parentLinks = await db.ParentLinks.AsNoTracking().Where(pl => gymnastIds.Contains(pl.AthleteId)).ToListAsync();

        var savedLevels = await db.Levels.AsNoTracking().Select(l => l.Name).ToListAsync();
        allLevels = gymnasts
            .Select(g => g.Level ?? "Unassigned")
            .Concat(savedLevels)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(l => l)
            .ToList();

        // Auto-expand levels that have gymnasts
        expandedLevels = allLevels.ToHashSet();
    }

    private void ShowInviteForm(int gymnastId)
    {
        inviteGymnastId = gymnastId;
        inviteEmail = "";
        showInviteForm = true;
    }

    private void CancelInviteForm()
    {
        showInviteForm = false;
        inviteGymnastId = 0;
        inviteEmail = "";
    }

    private string? bulkMessage;

    private async Task GenerateAllCodes()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var count = 0;
        foreach (var g in gymnasts ?? [])
        {
            if (!await db.ParentLinks.AnyAsync(pl => pl.AthleteId == g.Id))
            {
                db.ParentLinks.Add(new ParentLink { AthleteId = g.Id, InviteCode = ParentLink.GenerateCode() });
                count++;
            }
        }
        await db.SaveChangesAsync();
        bulkMessage = $"Generated {count} invite codes.";
        await LoadData();
    }

    private async Task GenerateCodeOnly(int gymnastId)
    {
        inviteMessage = null;
        inviteError = null;
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == gymnastId);
        if (existing != null) return;

        var code = ParentLink.GenerateCode();
        db.ParentLinks.Add(new ParentLink { AthleteId = gymnastId, InviteCode = code });
        await db.SaveChangesAsync();

        var gymnast = await db.Gymnasts.FindAsync(gymnastId);
        inviteMessage = $"Code generated for {gymnast?.Name ?? "athlete"}: {code}";
        await LoadData();
    }

    private async Task SendInviteEmail(Gymnast gymnast)
    {
        if (string.IsNullOrWhiteSpace(inviteEmail)) return;
        inviteMessage = null;
        inviteError = null;

        using var db = await DbFactory.CreateDbContextAsync();
        string inviteCode;

        var existingLink = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == gymnast.Id);
        if (existingLink != null)
        {
            existingLink.InviteCode = ParentLink.GenerateCode();
            existingLink.IsClaimed = false;
            existingLink.ParentUserId = null;
            existingLink.ClaimedAt = null;
            inviteCode = existingLink.InviteCode;
            await db.SaveChangesAsync();
        }
        else
        {
            inviteCode = ParentLink.GenerateCode();
            db.ParentLinks.Add(new ParentLink
            {
                AthleteId = gymnast.Id,
                InviteCode = inviteCode
            });
            await db.SaveChangesAsync();
        }

        var appUrl = Configuration["AppUrl"] ?? NavigationManager.BaseUri.TrimEnd('/');
        var registerUrl = $"{appUrl}/Identity/Account/Register";
        var claimUrl = $"{appUrl}/claim";
        var emailBody = $@"
<div style='max-width:600px;margin:0 auto;font-family:Arial,sans-serif;'>
    <div style='background:#1a6b3c;padding:20px;text-align:center;'>
        <h1 style='color:white;margin:0;font-size:24px;'>Top Notch Training</h1>
    </div>
    <div style='padding:20px;background:#f8f9fa;'>
        <div style='background:white;border-radius:8px;padding:20px;margin-bottom:15px;'>
            <h2 style='color:#333;margin-top:0;'>You're Invited!</h2>
            <p>You have been invited to manage <strong>{gymnast.Name}</strong>'s account on GymHub, the parent portal for Top Notch Training.</p>

            <div style='background:#f0f7ff;border-radius:8px;padding:15px;text-align:center;margin:20px 0;'>
                <div style='color:#666;font-size:13px;'>Your Invite Code</div>
                <div style='font-size:28px;font-weight:bold;color:#0d6efd;letter-spacing:3px;'>{inviteCode}</div>
            </div>

            <h3 style='color:#333;'>How to Get Started</h3>
            <ol style='color:#555;line-height:1.8;'>
                <li>Click the button below to create your account</li>
                <li>After registering, go to <a href='{claimUrl}'>Link Athlete</a> and enter your invite code</li>
                <li>You'll see {gymnast.Name}'s charges, payment schedule, and more</li>
            </ol>

            <div style='text-align:center;margin:20px 0;'>
                <a href='{registerUrl}' style='display:inline-block;background:#1a6b3c;color:white;padding:14px 30px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:16px;'>Create Your Account</a>
            </div>

            <div style='background:#fff8e1;border-radius:8px;padding:15px;margin-top:20px;'>
                <h4 style='margin-top:0;color:#333;'>Add GymHub to Your Phone</h4>
                <p style='margin-bottom:8px;color:#555;'>For the best experience, add GymHub to your home screen:</p>
                <p style='margin-bottom:5px;'><strong>iPhone:</strong> Open <a href='{appUrl}'>{appUrl.Replace("https://", "")}</a> in Safari → tap the <strong>Share</strong> button (square with arrow) → tap <strong>Add to Home Screen</strong></p>
                <p style='margin-bottom:0;'><strong>Android:</strong> Open <a href='{appUrl}'>{appUrl.Replace("https://", "")}</a> in Chrome → tap the <strong>three dots</strong> menu → tap <strong>Add to Home Screen</strong></p>
            </div>
        </div>

        <p style='color:#999;font-size:12px;text-align:center;margin-top:15px;'>
            GymHub Parent Portal: <a href='{appUrl}' style='color:#999;'>{appUrl.Replace("https://", "")}</a>
        </p>
    </div>
</div>";

        try
        {
            await EmailSender.SendEmailAsync(inviteEmail, "You're invited to Top Notch Training", emailBody);
            inviteMessage = $"Invite sent to {inviteEmail} for {gymnast.Name} (Code: {inviteCode})";
        }
        catch (Exception ex)
        {
            inviteError = $"Email failed: {ex.Message}. Invite code {inviteCode} was still generated.";
        }

        showInviteForm = false;
        inviteGymnastId = 0;
        inviteEmail = "";
        await LoadData();
    }

    private async Task UpdateLevel(int gymnastId, string? newLevel)
    {
        if (string.IsNullOrEmpty(newLevel)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(gymnastId);
        if (entity != null)
        {
            entity.Level = newLevel;
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private int? deleteConfirmId;
    private string? deleteConfirmName;
    private bool deleteHasLink;

    private async Task ConfirmDeleteGymnast(int gymnastId, string name)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        deleteHasLink = await db.ParentLinks.AnyAsync(pl => pl.AthleteId == gymnastId && pl.IsClaimed);
        deleteConfirmId = gymnastId;
        deleteConfirmName = name;
    }

    private void CancelDelete()
    {
        deleteConfirmId = null;
        deleteConfirmName = null;
    }

    private async Task DeleteGymnast()
    {
        if (deleteConfirmId == null) return;
        var gymnastId = deleteConfirmId.Value;
        var name = deleteConfirmName ?? "";
        deleteConfirmId = null;
        deleteConfirmName = null;

        using var db = await DbFactory.CreateDbContextAsync();
        var links = await db.ParentLinks.Where(pl => pl.AthleteId == gymnastId).ToListAsync();
        db.ParentLinks.RemoveRange(links);
        var payments = await db.Payments.Where(p => p.AthleteId == gymnastId).ToListAsync();
        db.Payments.RemoveRange(payments);
        var apparelSels = await db.GymnastApparelSelections.Where(s => s.GymnastId == gymnastId).ToListAsync();
        db.GymnastApparelSelections.RemoveRange(apparelSels);
        var compSels = await db.GymnastCompetitionSelections.Where(s => s.GymnastId == gymnastId).ToListAsync();
        db.GymnastCompetitionSelections.RemoveRange(compSels);
        var gymnast = await db.Gymnasts.FindAsync(gymnastId);
        if (gymnast != null) db.Gymnasts.Remove(gymnast);
        await db.SaveChangesAsync();
        inviteMessage = $"Deleted {name}.";
        await LoadData();
    }

    private void ToggleProfile(int gymnastId)
    {
        profileSaveMessage = null;
        if (profileGymnastId == gymnastId)
        {
            profileGymnastId = null;
            return;
        }
        profileGymnastId = gymnastId;
        var gymnast = gymnasts?.FirstOrDefault(g => g.Id == gymnastId);
        if (gymnast != null)
        {
            profileParentEmail = gymnast.ParentEmail;
            profileParentEmail2 = gymnast.ParentEmail2;
            profileLeotardSize = gymnast.LeotardSize;
            profileLeggingsSize = gymnast.LeggingsSize;
            profilePantsSize = gymnast.PantsSize;
            profileShirtSize = gymnast.ShirtSize;
        }
    }

    private async Task SaveProfile()
    {
        if (profileGymnastId == null) return;
        profileSaveMessage = null;
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(profileGymnastId.Value);
        if (entity != null)
        {
            entity.ParentEmail = profileParentEmail;
            entity.ParentEmail2 = profileParentEmail2;
            entity.LeotardSize = profileLeotardSize;
            entity.LeggingsSize = profileLeggingsSize;
            entity.PantsSize = profilePantsSize;
            entity.ShirtSize = profileShirtSize;
            entity.ModifiedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
        }
        profileGymnastId = null;
        await LoadData();
    }
}
