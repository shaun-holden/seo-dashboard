@page "/athletes"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender
@inject NavigationManager NavigationManager

<h3>Athletes</h3>

@if (gymnasts == null)
{
    <p>Loading...</p>
}
else
{
    <p class="text-muted">Manage gymnasts on the <a href="/roster">Roster page</a>.</p>

    @if (gymnasts.Any(g => !parentLinks.Any(pl => pl.AthleteId == g.Id)))
    {
        <button class="btn btn-success mb-3" @onclick="GenerateAllCodes">
            <span class="oi oi-key me-1"></span> Generate All Missing Codes
        </button>
    }

    @if (bulkMessage != null)
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @bulkMessage
            <button type="button" class="btn-close" @onclick="() => bulkMessage = null"></button>
        </div>
    }

    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <input type="text" class="form-control" style="max-width: 200px;" placeholder="Search athlete..."
               @bind="searchText" @bind:event="oninput" />
        @if (allLevels.Count > 1)
        {
            <select class="form-select" style="max-width: 200px;" value="@filterLevel"
                    @onchange="OnFilterLevelChanged">
                <option value="">All Levels</option>
                @foreach (var level in allLevels)
                {
                    <option value="@level">@level</option>
                }
            </select>
        }
        @if (gymnasts.Any())
        {
            <span class="text-muted">@filteredGymnasts.Count athlete(s)</span>
        }
    </div>

    @if (inviteMessage != null)
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @inviteMessage
            <button type="button" class="btn-close" @onclick="() => inviteMessage = null"></button>
        </div>
    }
    @if (inviteError != null)
    {
        <div class="alert alert-danger alert-dismissible mb-3">
            @inviteError
            <button type="button" class="btn-close" @onclick="() => inviteError = null"></button>
        </div>
    }

    @foreach (var group in filteredGroups)
    {
        var levelGymnasts = group.Value;
        var levelName = group.Key;
        var isExpanded = expandedLevels.Contains(levelName);

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleLevel(levelName)" style="cursor: pointer;">
                <div>
                    <h5 class="mb-0 d-inline">@levelName</h5>
                    <span class="badge bg-primary ms-2">@levelGymnasts.Count athlete(s)</span>
                </div>
                <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>
            @if (isExpanded)
            {
            <div class="card-body p-0">
                @if (!levelGymnasts.Any())
                {
                    <div class="p-3 text-muted">No athletes in this level yet.</div>
                }
                else
                {
                    <div style="overflow-x: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Invite Code</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gymnast in levelGymnasts)
                            {
                                <tr>
                                    <td><strong>@gymnast.Name</strong></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(gymnast.ParentEmail))
                                        {
                                            <small class="text-muted me-2">@gymnast.ParentEmail</small>
                                        }
                                        @if (!string.IsNullOrEmpty(gymnast.ParentEmail2))
                                        {
                                            <small class="text-muted me-2">| @gymnast.ParentEmail2</small>
                                        }
                                        @{
                                            var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == gymnast.Id);
                                        }
                                        @if (link != null)
                                        {
                                            <span class="badge @(link.IsClaimed ? "bg-success" : "bg-secondary") font-monospace" title="@(link.IsClaimed ? "Claimed" : "Pending")">@link.InviteCode</span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => GenerateCodeOnly(gymnast.Id)">Code</button>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (link != null)
                                        {
                                            <button class="btn btn-sm btn-outline-warning me-1" title="Regenerate invite code" @onclick="() => ShowInviteForm(gymnast.Id)">
                                                <span class="oi oi-reload"></span>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ShowInviteForm(gymnast.Id)">Email Invite</button>
                                        @if (showInviteForm && inviteGymnastId == gymnast.Id)
                                        {
                                            <div class="d-inline-flex align-items-center gap-1 ms-1">
                                                <input type="email" class="form-control form-control-sm" style="width: 200px;"
                                                       placeholder="Parent email" @bind="inviteEmail" />
                                                <button class="btn btn-sm btn-success" @onclick="() => SendInviteEmail(gymnast)">Send</button>
                                                <button class="btn btn-sm btn-secondary" @onclick="CancelInviteForm">X</button>
                                            </div>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ToggleProfile(gymnast.Id)">Profile</button>
                                        <a class="btn btn-sm btn-outline-primary" href="/roster">Edit</a>
                                    </td>
                                </tr>
                                @if (profileGymnastId == gymnast.Id)
                                {
                                    <tr>
                                        <td colspan="8">
                                            <div class="card border-info m-2">
                                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                                    <strong>Profile - @gymnast.Name</strong>
                                                    <button class="btn btn-sm btn-light" @onclick="() => profileGymnastId = null">Close</button>
                                                </div>
                                                <div class="card-body">
                                                    <div class="row">
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Parent 1 Email</label>
                                                            <input type="email" class="form-control" @bind="profileParentEmail" placeholder="parent1@example.com" />
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Parent 2 Email</label>
                                                            <input type="email" class="form-control" @bind="profileParentEmail2" placeholder="parent2@example.com" />
                                                        </div>
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label fw-bold">Level</label>
                                                            <input type="text" class="form-control" value="@gymnast.Level" disabled />
                                                        </div>
                                                    </div>
                                                    <button class="btn btn-success" @onclick="SaveProfile">Save Profile</button>
                                                    @if (profileSaveMessage != null)
                                                    {
                                                        <span class="text-success ms-2">@profileSaveMessage</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>
            }
        </div>
    }
}

@code {
    private List<Gymnast>? gymnasts;
    private List<ParentLink> parentLinks = new();
    private List<string> allLevels = new();

    private string filterLevel = "";
    private string searchText = "";
    private HashSet<string> expandedLevels = new();

    private bool showInviteForm;
    private int inviteGymnastId;
    private string inviteEmail = "";
    private string? inviteMessage;
    private string? inviteError;

    // Profile state
    private int? profileGymnastId;
    private string? profileParentEmail;
    private string? profileParentEmail2;
    private string? profileSaveMessage;

    private void OnFilterLevelChanged(ChangeEventArgs e) { filterLevel = e.Value?.ToString() ?? ""; }

    private void ToggleLevel(string levelName)
    {
        if (!expandedLevels.Remove(levelName))
            expandedLevels.Add(levelName);
    }

    private List<Gymnast> filteredGymnasts
    {
        get
        {
            IEnumerable<Gymnast> list = gymnasts ?? new();
            if (!string.IsNullOrWhiteSpace(filterLevel))
                list = list.Where(g => string.Equals(g.Level, filterLevel, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(searchText))
                list = list.Where(g => g.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            return list.ToList();
        }
    }

    private List<KeyValuePair<string, List<Gymnast>>> filteredGroups
    {
        get
        {
            return filteredGymnasts
                .GroupBy(g => g.Level ?? "Unassigned")
                .OrderBy(g => g.Key)
                .Select(g => new KeyValuePair<string, List<Gymnast>>(g.Key, g.OrderBy(x => x.Name).ToList()))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        gymnasts = await db.Gymnasts.AsNoTracking().OrderBy(g => g.Name).ToListAsync();
        var gymnastIds = gymnasts.Select(g => g.Id).ToList();
        parentLinks = await db.ParentLinks.AsNoTracking().Where(pl => gymnastIds.Contains(pl.AthleteId)).ToListAsync();

        allLevels = gymnasts
            .Select(g => g.Level ?? "Unassigned")
            .Distinct()
            .OrderBy(l => l)
            .ToList();

        // Auto-expand levels that have gymnasts
        expandedLevels = allLevels.ToHashSet();
    }

    private void ShowInviteForm(int gymnastId)
    {
        inviteGymnastId = gymnastId;
        inviteEmail = "";
        showInviteForm = true;
    }

    private void CancelInviteForm()
    {
        showInviteForm = false;
        inviteGymnastId = 0;
        inviteEmail = "";
    }

    private string? bulkMessage;

    private async Task GenerateAllCodes()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var count = 0;
        foreach (var g in gymnasts)
        {
            if (!await db.ParentLinks.AnyAsync(pl => pl.AthleteId == g.Id))
            {
                db.ParentLinks.Add(new ParentLink { AthleteId = g.Id, InviteCode = ParentLink.GenerateCode() });
                count++;
            }
        }
        await db.SaveChangesAsync();
        bulkMessage = $"Generated {count} invite codes.";
        await LoadData();
    }

    private async Task GenerateCodeOnly(int gymnastId)
    {
        inviteMessage = null;
        inviteError = null;
        using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == gymnastId);
        if (existing != null) return;

        var code = ParentLink.GenerateCode();
        db.ParentLinks.Add(new ParentLink { AthleteId = gymnastId, InviteCode = code });
        await db.SaveChangesAsync();

        var gymnast = await db.Gymnasts.FindAsync(gymnastId);
        inviteMessage = $"Code generated for {gymnast?.Name ?? "athlete"}: {code}";
        await LoadData();
    }

    private async Task SendInviteEmail(Gymnast gymnast)
    {
        if (string.IsNullOrWhiteSpace(inviteEmail)) return;
        inviteMessage = null;
        inviteError = null;

        using var db = await DbFactory.CreateDbContextAsync();
        string inviteCode;

        var existingLink = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == gymnast.Id);
        if (existingLink != null)
        {
            existingLink.InviteCode = ParentLink.GenerateCode();
            existingLink.IsClaimed = false;
            existingLink.ParentUserId = null;
            existingLink.ClaimedAt = null;
            inviteCode = existingLink.InviteCode;
            await db.SaveChangesAsync();
        }
        else
        {
            inviteCode = ParentLink.GenerateCode();
            db.ParentLinks.Add(new ParentLink
            {
                AthleteId = gymnast.Id,
                InviteCode = inviteCode
            });
            await db.SaveChangesAsync();
        }

        var registerUrl = $"{NavigationManager.BaseUri}Identity/Account/Register";
        var emailBody = $@"
            <div style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;'>
                <h2>You're Invited to Top Notch Training!</h2>
                <p>You have been invited to manage <strong>{gymnast.Name}</strong>'s account on Top Notch Training.</p>
                <p>Your invite code is: <strong style='font-size: 1.2em; color: #0d6efd;'>{inviteCode}</strong></p>
                <p>To get started, create your account by clicking the link below:</p>
                <p><a href='{registerUrl}' style='display: inline-block; padding: 10px 20px; background-color: #0d6efd; color: #ffffff; text-decoration: none; border-radius: 5px;'>Register Now</a></p>
                <p>After registering, use your invite code to link to your athlete's account.</p>
                <hr style='border: none; border-top: 1px solid #dee2e6;' />
                <p style='color: #6c757d; font-size: 0.9em;'>Top Notch Training</p>
            </div>";

        try
        {
            await EmailSender.SendEmailAsync(inviteEmail, "You're invited to Top Notch Training", emailBody);
            inviteMessage = $"Invite sent to {inviteEmail} for {gymnast.Name} (Code: {inviteCode})";
        }
        catch (Exception ex)
        {
            inviteError = $"Email failed: {ex.Message}. Invite code {inviteCode} was still generated.";
        }

        showInviteForm = false;
        inviteGymnastId = 0;
        inviteEmail = "";
        await LoadData();
    }

    private void ToggleProfile(int gymnastId)
    {
        profileSaveMessage = null;
        if (profileGymnastId == gymnastId)
        {
            profileGymnastId = null;
            return;
        }
        profileGymnastId = gymnastId;
        var gymnast = gymnasts?.FirstOrDefault(g => g.Id == gymnastId);
        if (gymnast != null)
        {
            profileParentEmail = gymnast.ParentEmail;
            profileParentEmail2 = gymnast.ParentEmail2;
        }
    }

    private async Task SaveProfile()
    {
        if (profileGymnastId == null) return;
        profileSaveMessage = null;
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Gymnasts.FindAsync(profileGymnastId.Value);
        if (entity != null)
        {
            entity.ParentEmail = profileParentEmail;
            entity.ParentEmail2 = profileParentEmail2;
            entity.ModifiedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
        }
        profileGymnastId = null;
        await LoadData();
    }
}
