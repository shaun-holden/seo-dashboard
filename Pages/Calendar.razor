@page "/calendar"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<h3>Calendar</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id" selected="@(s.Id == selectedSeasonId)">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="d-flex align-items-center justify-content-between mb-3">
            <button class="btn btn-outline-secondary btn-sm" @onclick="PrevMonth">&laquo; Previous</button>
            <h5 class="mb-0">@currentDate.ToString("MMMM yyyy")</h5>
            <button class="btn btn-outline-secondary btn-sm" @onclick="NextMonth">Next &raquo;</button>
        </div>

        <div class="mb-2">
            <span class="badge bg-primary me-2">Meet</span>
            <span class="badge bg-success me-2">Practice</span>
            <span class="badge bg-warning text-dark">Payment Due</span>
        </div>

        <table class="calendar-grid">
            <thead>
                <tr>
                    <th>Sun</th>
                    <th>Mon</th>
                    <th>Tue</th>
                    <th>Wed</th>
                    <th>Thu</th>
                    <th>Fri</th>
                    <th>Sat</th>
                </tr>
            </thead>
            <tbody>
                @for (int week = 0; week < calendarWeeks.Count; week++)
                {
                    var weekDays = calendarWeeks[week];
                    <tr>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day = weekDays[d];
                            var isToday = day.Date == DateTime.Today;
                            var isOtherMonth = day.Month != currentDate.Month;
                            var isSelected = day == selectedDay;
                            var cssClass = (isToday ? "today " : "") + (isOtherMonth ? "other-month " : "") + (isSelected ? "selected " : "");
                            var eventsForDay = GetEventsForDay(day);
                            <td class="@cssClass" @onclick="() => SelectDay(day)">
                                <div class="calendar-day-num">@day.Day</div>
                                @foreach (var evt in eventsForDay.Take(3))
                                {
                                    <span class="calendar-event @evt.CssClass" title="@evt.Name">@evt.ShortName</span>
                                }
                                @if (eventsForDay.Count > 3)
                                {
                                    <span class="calendar-event" style="background: #e9ecef; color: #495057;">+@(eventsForDay.Count - 3) more</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        @if (selectedDay != default)
        {
            var selectedEvents = GetEventsForDay(selectedDay);
            <div class="card mt-3">
                <div class="card-header">
                    <strong>@selectedDay.ToString("dddd, MMMM d, yyyy")</strong>
                </div>
                <div class="card-body">
                    @if (!selectedEvents.Any())
                    {
                        <p class="text-muted mb-0">No events on this day.</p>
                    }
                    else
                    {
                        @foreach (var evt in selectedEvents)
                        {
                            <div class="mb-2">
                                <span class="badge bg-@evt.BadgeColor me-2">@evt.Type</span>
                                <strong>@evt.Name</strong>
                                @if (!string.IsNullOrEmpty(evt.Detail))
                                {
                                    <small class="text-muted ms-2">@evt.Detail</small>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
}

@code {
    private List<Season>? seasons;
    private int selectedSeasonId;
    private DateTime currentDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime selectedDay;
    private List<Meet> meets = new();
    private List<Practice> practices = new();
    private List<List<DateTime>> calendarWeeks = new();
    private List<CalendarEvent> allEvents = new();

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasons = await db.Seasons.AsNoTracking().OrderByDescending(s => s.IsActive).ThenBy(s => s.Name).ToListAsync();
        if (seasons.Any())
        {
            selectedSeasonId = seasons.First().Id;
            await LoadData();
        }
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            selectedSeasonId = id;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        meets = await db.Meets.AsNoTracking().Where(m => m.SeasonId == selectedSeasonId).ToListAsync();
        practices = await db.Practices.AsNoTracking().Where(p => p.SeasonId == selectedSeasonId).ToListAsync();
        BuildCalendar();
        BuildEvents();
    }

    private void BuildCalendar()
    {
        calendarWeeks = new List<List<DateTime>>();
        var firstDay = new DateTime(currentDate.Year, currentDate.Month, 1);
        var startDate = firstDay.AddDays(-(int)firstDay.DayOfWeek);
        var daysInMonth = DateTime.DaysInMonth(currentDate.Year, currentDate.Month);
        var lastDay = new DateTime(currentDate.Year, currentDate.Month, daysInMonth);
        var endDate = lastDay.AddDays(6 - (int)lastDay.DayOfWeek);

        var date = startDate;
        while (date <= endDate)
        {
            var week = new List<DateTime>();
            for (int i = 0; i < 7; i++)
            {
                week.Add(date);
                date = date.AddDays(1);
            }
            calendarWeeks.Add(week);
        }
    }

    private void BuildEvents()
    {
        allEvents = new List<CalendarEvent>();
        var meetsByDate = meets.GroupBy(m => m.Date.Date).ToList();
        foreach (var group in meetsByDate)
        {
            var i = 1;
            foreach (var meet in group)
            {
                var shortName = group.Count() > 1 ? $"Meet {i}" : "Meet";
                allEvents.Add(new CalendarEvent
                {
                    Date = meet.Date.Date,
                    Name = meet.Name,
                    ShortName = shortName,
                    Type = "Meet",
                    CssClass = "meet",
                    BadgeColor = "primary",
                    Detail = meet.TravelType.ToString()
                });
                i++;
            }
        }
        foreach (var practice in practices)
        {
            var detail = "";
            if (!string.IsNullOrEmpty(practice.StartTime))
            {
                detail = $"{practice.StartTime} - {practice.EndTime}";
            }
            allEvents.Add(new CalendarEvent
            {
                Date = practice.Date.Date,
                Name = practice.Name,
                ShortName = "Practice",
                Type = "Practice",
                CssClass = "practice",
                BadgeColor = "success",
                Detail = detail
            });
        }

        // Payment due dates on the 15th of each month that has events
        var monthsWithEvents = meets.Select(m => new DateTime(m.Date.Year, m.Date.Month, 1))
            .Union(practices.Select(p => new DateTime(p.Date.Year, p.Date.Month, 1)))
            .Distinct()
            .ToList();

        // Also include the current displayed month
        var displayMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
        if (!monthsWithEvents.Contains(displayMonth))
        {
            monthsWithEvents.Add(displayMonth);
        }

        foreach (var month in monthsWithEvents)
        {
            var paymentDate = new DateTime(month.Year, month.Month, 15);
            allEvents.Add(new CalendarEvent
            {
                Date = paymentDate,
                Name = "Payment Due",
                ShortName = "Payment Due",
                Type = "Payment",
                CssClass = "payment",
                BadgeColor = "warning",
                Detail = ""
            });
        }
    }

    private List<CalendarEvent> GetEventsForDay(DateTime day)
    {
        return allEvents.Where(e => e.Date == day.Date).ToList();
    }

    private void SelectDay(DateTime day)
    {
        selectedDay = day;
    }

    private async Task PrevMonth()
    {
        currentDate = currentDate.AddMonths(-1);
        BuildCalendar();
        BuildEvents();
    }

    private async Task NextMonth()
    {
        currentDate = currentDate.AddMonths(1);
        BuildCalendar();
        BuildEvents();
    }

    private class CalendarEvent
    {
        public DateTime Date { get; set; }
        public string Name { get; set; } = "";
        public string ShortName { get; set; } = "";
        public string Type { get; set; } = "";
        public string CssClass { get; set; } = "";
        public string BadgeColor { get; set; } = "";
        public string Detail { get; set; } = "";
    }
}
