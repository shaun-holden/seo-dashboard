@page "/parent/gallery"
@attribute [Authorize]
@layout GymBudgetApp.Shared.ParentLayout
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Photo Gallery</h3>

@if (!loaded)
{
    <p>Loading...</p>
}
else if (!albums.Any())
{
    <p class="text-muted">No photo albums available.</p>
}
else
{
    @foreach (var album in albums)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer" @onclick="() => ToggleAlbum(album.Id)">
                <div>
                    <strong>@album.Name</strong>
                    <span class="badge bg-secondary ms-2">@(albumPhotoCounts.GetValueOrDefault(album.Id, 0)) photo(s)</span>
                    @if (album.TeamLevelId.HasValue)
                    {
                        var levelName = levelNames.GetValueOrDefault(album.TeamLevelId.Value, "Level");
                        <span class="badge bg-info ms-1">@levelName</span>
                    }
                    else
                    {
                        <span class="badge bg-success ms-1">All Levels</span>
                    }
                    @if (album.MeetId.HasValue)
                    {
                        var meetName = meetNames.GetValueOrDefault(album.MeetId.Value, "Meet");
                        <span class="badge bg-warning text-dark ms-1">@meetName</span>
                    }
                </div>
                <span class="oi @(expandedAlbumId == album.Id ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>
            @if (expandedAlbumId == album.Id)
            {
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(album.Description))
                    {
                        <p class="text-muted">@album.Description</p>
                    }

                    @{ var photos = albumPhotos.GetValueOrDefault(album.Id, new()); }
                    @if (photos.Any())
                    {
                        <div class="row">
                            @foreach (var photo in photos)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100">
                                        <img src="@photo.ImageData" class="card-img-top" alt="@(photo.Caption ?? photo.FileName)" style="max-height:250px; object-fit:cover;" />
                                        @if (!string.IsNullOrEmpty(photo.Caption))
                                        {
                                            <div class="card-body p-2">
                                                <small class="text-muted">@photo.Caption</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No photos in this album yet.</p>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<PhotoAlbum> albums = new();
    private Dictionary<int, string> levelNames = new();
    private Dictionary<int, string> meetNames = new();
    private Dictionary<int, int> albumPhotoCounts = new();
    private Dictionary<int, List<Photo>> albumPhotos = new();
    private int? expandedAlbumId;
    private bool loaded;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId == null) { loaded = true; return; }

        using var db = await DbFactory.CreateDbContextAsync();

        // Find published seasons
        var seasonIds = await db.Seasons.AsNoTracking()
            .Where(s => s.IsPublished)
            .Select(s => s.Id)
            .ToListAsync();

        if (!seasonIds.Any()) { loaded = true; return; }

        // Get albums without loading photos
        albums = await db.PhotoAlbums
            .Where(a => seasonIds.Contains(a.SeasonId))
            .OrderByDescending(a => a.CreatedAt)
            .ToListAsync();

        // Load photo counts
        var albumIds = albums.Select(a => a.Id).ToList();
        albumPhotoCounts = await db.Photos
            .Where(p => albumIds.Contains(p.AlbumId))
            .GroupBy(p => p.AlbumId)
            .ToDictionaryAsync(g => g.Key, g => g.Count());

        // Load level and meet names for badges
        var allLevelIds = albums.Where(a => a.TeamLevelId.HasValue).Select(a => a.TeamLevelId!.Value).Distinct().ToList();
        var allMeetIds = albums.Where(a => a.MeetId.HasValue).Select(a => a.MeetId!.Value).Distinct().ToList();

        if (allLevelIds.Any())
        {
            levelNames = await db.TeamLevels
                .Where(t => allLevelIds.Contains(t.Id))
                .ToDictionaryAsync(t => t.Id, t => t.Name);
        }

        if (allMeetIds.Any())
        {
            meetNames = await db.Meets
                .Where(m => allMeetIds.Contains(m.Id))
                .ToDictionaryAsync(m => m.Id, m => m.Name);
        }

        loaded = true;
    }

    private async Task ToggleAlbum(int albumId)
    {
        if (expandedAlbumId == albumId)
        {
            expandedAlbumId = null;
        }
        else
        {
            expandedAlbumId = albumId;
            if (!albumPhotos.ContainsKey(albumId))
            {
                using var db = await DbFactory.CreateDbContextAsync();
                albumPhotos[albumId] = await db.Photos.AsNoTracking()
                    .Where(p => p.AlbumId == albumId)
                    .OrderByDescending(p => p.UploadedAt)
                    .ToListAsync();
            }
        }
    }
}
