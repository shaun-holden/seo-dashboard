@page "/seasons"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.AuditService AuditService

<h3>Seasons</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Seasons</div>
                    <div class="display-6 fw-semibold">@seasons.Count</div>
                    <div class="text-muted small">@activeSeasonCount active, @publishedSeasonCount published</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Budget Locks</div>
                    <div class="display-6 fw-semibold">@budgetLockedSeasonCount</div>
                    <div class="text-muted small">@draftSeasonCount draft season(s) still editable</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Published Athletes</div>
                    <div class="display-6 fw-semibold">@publishedAthleteCount</div>
                    <div class="text-muted small">Across all published seasons</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Recent Activity</div>
                    <div class="display-6 fw-semibold">@recentSeasonAuditLogs.Count</div>
                    <div class="text-muted small">Season changes in the latest history feed</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label class="form-label fw-semibold mb-1">Search Seasons</label>
                <input class="form-control" style="min-width: 220px;" placeholder="Find by season name" @bind="seasonSearchText" @bind:event="oninput" />
            </div>
            <div>
                <label class="form-label fw-semibold mb-1">Status Filter</label>
                <select class="form-select" style="min-width: 200px;" @bind="seasonFilter">
                    <option value="All">All Seasons</option>
                    <option value="Active">Active</option>
                    <option value="Published">Published</option>
                    <option value="BudgetLocked">Budget Locked</option>
                    <option value="Draft">Draft</option>
                </select>
            </div>
            <div class="ms-auto">
                <button class="btn btn-primary" @onclick="ShowForm">+ New Season</button>
            </div>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card mb-4 p-3">
            <h5>@(editingSeason == null ? "Add Season" : "Edit Season")</h5>

            <div class="mb-2">
                <label>Project Type</label>
                <select class="form-select" @bind="formProjectType">
                    <option value="@ProjectType.Competition">Competition</option>
                    <option value="@ProjectType.Custom">Custom</option>
                </select>
            </div>

            <div class="mb-2">
                <label>Season Name (e.g. 2026-2027)</label>
                <input class="form-control" @bind="formName" />
            </div>
            <div class="mb-2">
                <label>Total Athlete Count</label>
                <input type="number" class="form-control" @bind="formAthleteCount" />
            </div>
            <div class="mb-2">
                <input type="checkbox" @bind="formIsActive" /> Active Season
            </div>
            <div class="mb-2">
                <input type="checkbox" @bind="formIsLocked" /> Lock Budget Calculator
                <div class="form-text">Prevents edits in Budget Calculator only. Other season pages stay editable.</div>
            </div>

            @if (formProjectType == ProjectType.Custom)
            {
                <hr />
                <h6>Custom Labels</h6>
                <p class="text-muted small">Rename entities to match your project. Defaults are gym terms.</p>
                <div class="row mb-2">
                    <div class="col-6">
                        <label class="form-label small">What do you call "Meets"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Events" @bind="formMeetLabel" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small">What do you call "Coaches"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Staff" @bind="formCoachLabel" />
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-6">
                        <label class="form-label small">What do you call "Team Levels"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Groups" @bind="formTeamLevelLabel" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small">What do you call "Athlete Items"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Resources" @bind="formAthleteItemLabel" />
                    </div>
                </div>

                <hr />
                <h6>Features</h6>
                <p class="text-muted small">Choose which features to enable for this season.</p>
                <div class="mb-1">
                    <input type="checkbox" @bind="formEnableTeamLevels" /> Enable @formTeamLevelLabel
                </div>
                <div class="mb-1">
                    <input type="checkbox" @bind="formEnablePerDiem" /> Enable Per Diem
                </div>
                <div class="mb-2">
                    <input type="checkbox" @bind="formEnableMileage" /> Enable Mileage
                </div>
            }

            <button class="btn btn-success me-2" @onclick="SaveSeason">Save</button>
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pb-0">
            <h5 class="mb-1">Season Control Center</h5>
            <p class="text-muted mb-3">Use Active for staff-facing dropdown priority, Published for parent visibility, and Budget Locked to freeze the calculator only.</p>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Season</th>
                            <th>Type</th>
                            <th class="text-end">Athletes</th>
                            <th class="text-end">Levels</th>
                            <th class="text-end">Meets</th>
                            <th class="text-end">Budget Lines</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var season in filteredSeasons)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@season.Name</div>
                                    <div class="text-muted small">Updated @season.ModifiedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</div>
                                </td>
                                <td>
                                    @if (season.ProjectType == ProjectType.Custom)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">Custom</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">Competition</span>
                                    }
                                </td>
                                <td class="text-end fw-semibold">@season.AthleteCount</td>
                                <td class="text-end">@GetSeasonMetric(levelCountBySeason, season.Id)</td>
                                <td class="text-end">@GetSeasonMetric(meetCountBySeason, season.Id)</td>
                                <td class="text-end">@GetSeasonMetric(budgetEntryCountBySeason, season.Id)</td>
                                <td>
                                    @if (season.IsActive)
                                    {
                                        <span class="badge bg-success me-1">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary me-1">Inactive</span>
                                    }
                                    @if (season.IsPublished)
                                    {
                                        <span class="badge bg-primary me-1">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border me-1">Draft</span>
                                    }
                                    @if (season.IsLocked)
                                    {
                                        <span class="badge bg-dark">Budget Locked</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @if (season.IsActive)
                                        {
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => SetActive(season)">
                                                <span class="oi oi-ban"></span> Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => SetActive(season)">
                                                <span class="oi oi-star"></span> Activate
                                            </button>
                                        }
                                        @if (season.IsPublished)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => TogglePublish(season)">Unpublish</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => TogglePublish(season)">Publish</button>
                                        }
                                        <button class="btn btn-sm btn-outline-dark" @onclick="() => ToggleLock(season)">
                                            @(season.IsLocked ? "Unlock Budget" : "Lock Budget")
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditSeason(season)">Edit</button>
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => StartCopy(season)">Copy</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSeason(season)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!filteredSeasons.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No seasons match the current filters.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0">
            <h5 class="mb-1">Recent Season Activity</h5>
            <p class="text-muted mb-0">The latest season, publish, and budget-lock changes.</p>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in recentSeasonAuditLogs)
                        {
                            <tr>
                                <td>@entry.Timestamp.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                                <td>@entry.UserEmail</td>
                                <td><span class="badge bg-secondary">@entry.Action</span></td>
                                <td>@entry.Details</td>
                            </tr>
                        }
                        @if (!recentSeasonAuditLogs.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No season activity yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <hr />

    @if (copySource != null)
    {
        <div class="card mb-4 p-3" style="max-width: 600px;">
            <h5>Copy Structure from "@copySource.Name"</h5>
            <p class="text-muted">Copies coaches, meets, and team levels (no budget amounts).</p>

            <div class="mb-3">
                <label class="form-label fw-semibold">Copy into</label>
                <select class="form-select" @bind="copyTargetId" @bind:after="UpdateCopyPreview">
                    <option value="0">-- Select Target Season --</option>
                    @foreach (var s in seasons!.Where(s => s.Id != copySource.Id))
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>

            @if (copyTargetId > 0 && copyPreview != null)
            {
                <div class="alert alert-info">
                    <strong>Will copy:</strong>
                    <ul class="mb-0 mt-1">
                        <li>@copyPreview.CoachCount coach(es)</li>
                        <li>@copyPreview.MeetCount meet(s)</li>
                        <li>@copyPreview.TeamLevelCount team level(s) with @copyPreview.AthleteItemCount athlete item(s)</li>
                    </ul>
                </div>
            }

            @if (copyError != null)
            {
                <div class="alert alert-danger py-2">@copyError</div>
            }

            @if (copySuccess)
            {
                <div class="alert alert-success py-2">Structure copied successfully!</div>
            }

            <div>
                @if (!copySuccess && copyTargetId > 0 && copyPreview != null)
                {
                    <button class="btn btn-success me-2" @onclick="DoClone" disabled="@isCopying">
                        @if (isCopying) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Copy
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CancelCopy">Cancel</button>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private List<AuditLog> recentSeasonAuditLogs = new();
    private Dictionary<int, int> levelCountBySeason = new();
    private Dictionary<int, int> meetCountBySeason = new();
    private Dictionary<int, int> budgetEntryCountBySeason = new();
    private bool showForm = false;
    private Season? editingSeason;
    private string? userId;
    private string? userEmail;
    private string seasonSearchText = "";
    private string seasonFilter = "All";

    private string formName = "";
    private int formAthleteCount = 0;
    private bool formIsActive = true;
    private bool formIsLocked;
    private ProjectType formProjectType = ProjectType.Competition;
    private string formMeetLabel = "Meet";
    private string formCoachLabel = "Coach";
    private string formTeamLevelLabel = "Team Level";
    private string formAthleteItemLabel = "Athlete Item";
    private bool formEnableTeamLevels = true;
    private bool formEnablePerDiem = true;
    private bool formEnableMileage = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value
                    ?? authState.User.Identity?.Name;
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        seasons = await Db.Seasons.AsNoTracking()
            .OrderByDescending(s => s.IsActive)
            .ThenByDescending(s => s.IsPublished)
            .ThenByDescending(s => s.Name)
            .ToListAsync();

        levelCountBySeason = await Db.TeamLevels.AsNoTracking()
            .GroupBy(t => t.SeasonId)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Key, x => x.Count);

        meetCountBySeason = await Db.Meets.AsNoTracking()
            .GroupBy(m => m.SeasonId)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Key, x => x.Count);

        budgetEntryCountBySeason = await Db.BudgetCalculatorEntries.AsNoTracking()
            .GroupBy(e => e.SeasonId)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Key, x => x.Count);

        recentSeasonAuditLogs = await Db.AuditLogs.AsNoTracking()
            .Where(a => a.Action.StartsWith("Season"))
            .OrderByDescending(a => a.Timestamp)
            .Take(12)
            .ToListAsync();
    }

    private int activeSeasonCount => seasons?.Count(s => s.IsActive) ?? 0;
    private int publishedSeasonCount => seasons?.Count(s => s.IsPublished) ?? 0;
    private int budgetLockedSeasonCount => seasons?.Count(s => s.IsLocked) ?? 0;
    private int draftSeasonCount => seasons?.Count(s => !s.IsPublished) ?? 0;
    private int publishedAthleteCount => seasons?.Where(s => s.IsPublished).Sum(s => s.AthleteCount) ?? 0;

    private IEnumerable<Season> filteredSeasons =>
        (seasons ?? Enumerable.Empty<Season>())
            .Where(s => string.IsNullOrWhiteSpace(seasonSearchText)
                || s.Name.Contains(seasonSearchText, StringComparison.OrdinalIgnoreCase))
            .Where(MatchesSeasonFilter);

    private bool MatchesSeasonFilter(Season season) => seasonFilter switch
    {
        "Active" => season.IsActive,
        "Published" => season.IsPublished,
        "BudgetLocked" => season.IsLocked,
        "Draft" => !season.IsPublished,
        _ => true
    };

    private static int GetSeasonMetric(Dictionary<int, int> metrics, int seasonId) =>
        metrics.TryGetValue(seasonId, out var value) ? value : 0;

    private void ShowForm()
    {
        editingSeason = null;
        formName = "";
        formAthleteCount = 0;
        formIsActive = true;
        formIsLocked = false;
        formProjectType = ProjectType.Competition;
        formMeetLabel = "Meet";
        formCoachLabel = "Coach";
        formTeamLevelLabel = "Team Level";
        formAthleteItemLabel = "Athlete Item";
        formEnableTeamLevels = true;
        formEnablePerDiem = true;
        formEnableMileage = true;
        showForm = true;
    }

    private void EditSeason(Season season)
    {
        editingSeason = season;
        formName = season.Name;
        formAthleteCount = season.AthleteCount;
        formIsActive = season.IsActive;
        formIsLocked = season.IsLocked;
        formProjectType = season.ProjectType;
        formMeetLabel = season.MeetLabel;
        formCoachLabel = season.CoachLabel;
        formTeamLevelLabel = season.TeamLevelLabel;
        formAthleteItemLabel = season.AthleteItemLabel;
        formEnableTeamLevels = season.EnableTeamLevels;
        formEnablePerDiem = season.EnablePerDiem;
        formEnableMileage = season.EnableMileage;
        showForm = true;
    }

    private async Task SaveSeason()
    {
        string auditAction;
        string auditDetails;

        if (editingSeason == null)
        {
            var newSeason = new Season
            {
                Name = formName,
                AthleteCount = formAthleteCount,
                IsActive = formIsActive,
                IsLocked = formIsLocked,
                UserId = userId ?? string.Empty,
                ProjectType = formProjectType,
                MeetLabel = formProjectType == ProjectType.Custom ? formMeetLabel : "Meet",
                CoachLabel = formProjectType == ProjectType.Custom ? formCoachLabel : "Coach",
                TeamLevelLabel = formProjectType == ProjectType.Custom ? formTeamLevelLabel : "Team Level",
                AthleteItemLabel = formProjectType == ProjectType.Custom ? formAthleteItemLabel : "Athlete Item",
                EnableTeamLevels = formProjectType == ProjectType.Custom ? formEnableTeamLevels : true,
                EnablePerDiem = formProjectType == ProjectType.Custom ? formEnablePerDiem : true,
                EnableMileage = formProjectType == ProjectType.Custom ? formEnableMileage : true
            };
            Db.Seasons.Add(newSeason);
            auditAction = "SeasonCreated";
            auditDetails = $"Created season {newSeason.Name} ({newSeason.ProjectType}) with {newSeason.AthleteCount} athletes.";
        }
        else
        {
            var originalName = editingSeason.Name;
            editingSeason.Name = formName;
            editingSeason.AthleteCount = formAthleteCount;
            editingSeason.IsActive = formIsActive;
            editingSeason.IsLocked = formIsLocked;
            editingSeason.ProjectType = formProjectType;
            editingSeason.MeetLabel = formProjectType == ProjectType.Custom ? formMeetLabel : "Meet";
            editingSeason.CoachLabel = formProjectType == ProjectType.Custom ? formCoachLabel : "Coach";
            editingSeason.TeamLevelLabel = formProjectType == ProjectType.Custom ? formTeamLevelLabel : "Team Level";
            editingSeason.AthleteItemLabel = formProjectType == ProjectType.Custom ? formAthleteItemLabel : "Athlete Item";
            editingSeason.EnableTeamLevels = formProjectType == ProjectType.Custom ? formEnableTeamLevels : true;
            editingSeason.EnablePerDiem = formProjectType == ProjectType.Custom ? formEnablePerDiem : true;
            editingSeason.EnableMileage = formProjectType == ProjectType.Custom ? formEnableMileage : true;
            Db.Seasons.Update(editingSeason);
            auditAction = "SeasonUpdated";
            auditDetails = $"Updated season {originalName} to {editingSeason.Name}. Active={editingSeason.IsActive}, Published={editingSeason.IsPublished}, BudgetLocked={editingSeason.IsLocked}.";
        }

        await Db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", auditAction, auditDetails);
        await LoadSeasons();
        showForm = false;
    }

    private async Task SetActive(Season season)
    {
        season.IsActive = !season.IsActive;
        await Db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "SeasonActivationChanged", $"{season.Name} marked {(season.IsActive ? "active" : "inactive")}.");
        await LoadSeasons();
    }

    private async Task ToggleLock(Season season)
    {
        season.IsLocked = !season.IsLocked;
        await Db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "SeasonBudgetLockChanged", $"{season.Name} budget calculator {(season.IsLocked ? "locked" : "unlocked")}.");
        await LoadSeasons();
    }

    private async Task TogglePublish(Season season)
    {
        season.IsPublished = !season.IsPublished;
        Db.Seasons.Update(season);
        await Db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "SeasonPublishChanged", $"{season.Name} {(season.IsPublished ? "published" : "unpublished")}.");
        await LoadSeasons();
    }

    private async Task DeleteSeason(Season season)
    {
        var seasonName = season.Name;
        Db.Seasons.Remove(season);
        await Db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "SeasonDeleted", $"Deleted season {seasonName}.");
        await LoadSeasons();
    }

    private void CancelForm()
    {
        showForm = false;
    }

    // --- Copy Structure ---
    private Season? copySource;
    private int copyTargetId;
    private bool isCopying;
    private bool copySuccess;
    private string? copyError;
    private CopyPreview? copyPreview;

    private class CopyPreview
    {
        public int CoachCount { get; set; }
        public int MeetCount { get; set; }
        public int TeamLevelCount { get; set; }
        public int AthleteItemCount { get; set; }
    }

    private void StartCopy(Season season)
    {
        copySource = season;
        copyTargetId = 0;
        copyPreview = null;
        copySuccess = false;
        copyError = null;
    }

    private void CancelCopy()
    {
        copySource = null;
        copyPreview = null;
        copySuccess = false;
        copyError = null;
    }

    private void UpdateCopyPreview()
    {
        copyPreview = null;
        copySuccess = false;
        copyError = null;
        if (copySource == null || copyTargetId <= 0) return;

        var levelIds = Db.TeamLevels.Where(t => t.SeasonId == copySource.Id).Select(t => t.Id).ToList();
        copyPreview = new CopyPreview
        {
            CoachCount = Db.Coaches.Count(c => c.SeasonId == copySource.Id),
            MeetCount = Db.Meets.Count(m => m.SeasonId == copySource.Id),
            TeamLevelCount = levelIds.Count,
            AthleteItemCount = Db.AthleteItems.Count(a => levelIds.Contains(a.TeamLevelId))
        };
    }

    private async Task DoClone()
    {
        if (copySource == null || copyTargetId <= 0) return;
        copyError = null;
        copySuccess = false;
        isCopying = true;

        try
        {
            var srcId = copySource.Id;

            // 1. Copy coaches
            var srcCoaches = Db.Coaches.Where(c => c.SeasonId == srcId).ToList();
            foreach (var c in srcCoaches)
            {
                Db.Coaches.Add(new Coach { Name = c.Name, Role = c.Role, IsActive = c.IsActive, SeasonId = copyTargetId });
            }
            await Db.SaveChangesAsync();

            // 2. Copy meets
            var srcMeets = Db.Meets.Where(m => m.SeasonId == srcId).ToList();
            foreach (var m in srcMeets)
            {
                Db.Meets.Add(new Meet { Name = m.Name, Date = m.Date, TravelType = m.TravelType, SeasonId = copyTargetId });
            }
            await Db.SaveChangesAsync();

            // 3. Copy team levels + athlete items
            var srcLevels = Db.TeamLevels.Where(t => t.SeasonId == srcId).ToList();
            var srcLevelIds = srcLevels.Select(t => t.Id).ToList();
            var srcAthleteItems = Db.AthleteItems.Where(a => srcLevelIds.Contains(a.TeamLevelId)).ToList();

            foreach (var level in srcLevels)
            {
                var newLevel = new TeamLevel { Name = level.Name, AthleteCount = level.AthleteCount, PaymentPlanMonths = level.PaymentPlanMonths, SeasonId = copyTargetId };
                Db.TeamLevels.Add(newLevel);
                await Db.SaveChangesAsync();

                foreach (var item in srcAthleteItems.Where(a => a.TeamLevelId == level.Id))
                {
                    Db.AthleteItems.Add(new AthleteItem { Name = item.Name, Cost = item.Cost, IsRequired = item.IsRequired, TeamLevelId = newLevel.Id });
                }
                await Db.SaveChangesAsync();
            }

            copySuccess = true;
            var targetSeasonName = Db.Seasons.AsNoTracking().Where(s => s.Id == copyTargetId).Select(s => s.Name).FirstOrDefault() ?? $"Season {copyTargetId}";
            await AuditService.LogAsync(userId ?? "", userEmail ?? "", "SeasonStructureCopied", $"Copied structure from {copySource.Name} into {targetSeasonName}.");
            await LoadSeasons();
        }
        catch (Exception ex)
        {
            copyError = $"Copy failed: {ex.Message}";
        }
        finally
        {
            isCopying = false;
        }
    }
}
