@page "/seasons"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@inject AppDbContext Db
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Seasons</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ShowForm">+ New Season</button>

    @if (showForm)
    {
        <div class="card mb-4 p-3">
            <h5>@(editingSeason == null ? "Add Season" : "Edit Season")</h5>

            <div class="mb-2">
                <label>Project Type</label>
                <select class="form-select" @bind="formProjectType">
                    <option value="@ProjectType.Competition">Competition</option>
                    <option value="@ProjectType.Custom">Custom</option>
                </select>
            </div>

            <div class="mb-2">
                <label>Season Name (e.g. 2026-2027)</label>
                <input class="form-control" @bind="formName" />
            </div>
            <div class="mb-2">
                <label>Total Athlete Count</label>
                <input type="number" class="form-control" @bind="formAthleteCount" />
            </div>
            <div class="mb-2">
                <input type="checkbox" @bind="formIsActive" /> Active Season
            </div>

            @if (formProjectType == ProjectType.Custom)
            {
                <hr />
                <h6>Custom Labels</h6>
                <p class="text-muted small">Rename entities to match your project. Defaults are gym terms.</p>
                <div class="row mb-2">
                    <div class="col-6">
                        <label class="form-label small">What do you call "Meets"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Events" @bind="formMeetLabel" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small">What do you call "Coaches"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Staff" @bind="formCoachLabel" />
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-6">
                        <label class="form-label small">What do you call "Team Levels"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Groups" @bind="formTeamLevelLabel" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small">What do you call "Athlete Items"?</label>
                        <input class="form-control form-control-sm" placeholder="e.g. Resources" @bind="formAthleteItemLabel" />
                    </div>
                </div>

                <hr />
                <h6>Features</h6>
                <p class="text-muted small">Choose which features to enable for this season.</p>
                <div class="mb-1">
                    <input type="checkbox" @bind="formEnableTeamLevels" /> Enable @formTeamLevelLabel
                </div>
                <div class="mb-1">
                    <input type="checkbox" @bind="formEnablePerDiem" /> Enable Per Diem
                </div>
                <div class="mb-2">
                    <input type="checkbox" @bind="formEnableMileage" /> Enable Mileage
                </div>
            }

            <button class="btn btn-success me-2" @onclick="SaveSeason">Save</button>
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
        </div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Season</th>
                <th>Type</th>
                <th>Athletes</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var season in seasons)
            {
                <tr>
                    <td>@season.Name</td>
                    <td>
                        @if (season.ProjectType == ProjectType.Custom)
                        {
                            <span class="badge bg-info">Custom</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Competition</span>
                        }
                    </td>
                    <td>@season.AthleteCount</td>
                    <td>
                        @if (season.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                        @if (season.IsPublished)
                        {
                            <span class="badge bg-success ms-1">Published</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-1">Draft</span>
                        }
                    </td>
                    <td>
                        @if (!season.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => SetActive(season)">
                                <span class="oi oi-star"></span> Set Active
                            </button>
                        }
                        @if (season.IsPublished)
                        {
                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => TogglePublish(season)">Unpublish</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success me-1" @onclick="() => TogglePublish(season)">Publish</button>
                        }
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditSeason(season)">Edit</button>
                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => StartCopy(season)">Copy</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSeason(season)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <hr />

    @if (copySource != null)
    {
        <div class="card mb-4 p-3" style="max-width: 600px;">
            <h5>Copy Structure from "@copySource.Name"</h5>
            <p class="text-muted">Copies coaches, meets, and team levels (no budget amounts).</p>

            <div class="mb-3">
                <label class="form-label fw-semibold">Copy into</label>
                <select class="form-select" @bind="copyTargetId" @bind:after="UpdateCopyPreview">
                    <option value="0">-- Select Target Season --</option>
                    @foreach (var s in seasons!.Where(s => s.Id != copySource.Id))
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>

            @if (copyTargetId > 0 && copyPreview != null)
            {
                <div class="alert alert-info">
                    <strong>Will copy:</strong>
                    <ul class="mb-0 mt-1">
                        <li>@copyPreview.CoachCount coach(es)</li>
                        <li>@copyPreview.MeetCount meet(s)</li>
                        <li>@copyPreview.TeamLevelCount team level(s) with @copyPreview.AthleteItemCount athlete item(s)</li>
                    </ul>
                </div>
            }

            @if (copyError != null)
            {
                <div class="alert alert-danger py-2">@copyError</div>
            }

            @if (copySuccess)
            {
                <div class="alert alert-success py-2">Structure copied successfully!</div>
            }

            <div>
                @if (!copySuccess && copyTargetId > 0 && copyPreview != null)
                {
                    <button class="btn btn-success me-2" @onclick="DoClone" disabled="@isCopying">
                        @if (isCopying) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Copy
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CancelCopy">Cancel</button>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private bool showForm = false;
    private Season? editingSeason;
    private string? userId;

    private string formName = "";
    private int formAthleteCount = 0;
    private bool formIsActive = true;
    private ProjectType formProjectType = ProjectType.Competition;
    private string formMeetLabel = "Meet";
    private string formCoachLabel = "Coach";
    private string formTeamLevelLabel = "Team Level";
    private string formAthleteItemLabel = "Athlete Item";
    private bool formEnableTeamLevels = true;
    private bool formEnablePerDiem = true;
    private bool formEnableMileage = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        seasons = await Task.FromResult(Db.Seasons.OrderByDescending(s => s.Name).ToList());
    }

    private void ShowForm()
    {
        editingSeason = null;
        formName = "";
        formAthleteCount = 0;
        formIsActive = true;
        formProjectType = ProjectType.Competition;
        formMeetLabel = "Meet";
        formCoachLabel = "Coach";
        formTeamLevelLabel = "Team Level";
        formAthleteItemLabel = "Athlete Item";
        formEnableTeamLevels = true;
        formEnablePerDiem = true;
        formEnableMileage = true;
        showForm = true;
    }

    private void EditSeason(Season season)
    {
        editingSeason = season;
        formName = season.Name;
        formAthleteCount = season.AthleteCount;
        formIsActive = season.IsActive;
        formProjectType = season.ProjectType;
        formMeetLabel = season.MeetLabel;
        formCoachLabel = season.CoachLabel;
        formTeamLevelLabel = season.TeamLevelLabel;
        formAthleteItemLabel = season.AthleteItemLabel;
        formEnableTeamLevels = season.EnableTeamLevels;
        formEnablePerDiem = season.EnablePerDiem;
        formEnableMileage = season.EnableMileage;
        showForm = true;
    }

    private async Task SaveSeason()
    {
        // Deactivate all other seasons when setting one as active
        if (formIsActive)
        {
            var activeSeasons = Db.Seasons.Where(s => s.IsActive);
            foreach (var s in activeSeasons)
                s.IsActive = false;
        }

        if (editingSeason == null)
        {
            var newSeason = new Season
            {
                Name = formName,
                AthleteCount = formAthleteCount,
                IsActive = formIsActive,
                UserId = userId ?? string.Empty,
                ProjectType = formProjectType,
                MeetLabel = formProjectType == ProjectType.Custom ? formMeetLabel : "Meet",
                CoachLabel = formProjectType == ProjectType.Custom ? formCoachLabel : "Coach",
                TeamLevelLabel = formProjectType == ProjectType.Custom ? formTeamLevelLabel : "Team Level",
                AthleteItemLabel = formProjectType == ProjectType.Custom ? formAthleteItemLabel : "Athlete Item",
                EnableTeamLevels = formProjectType == ProjectType.Custom ? formEnableTeamLevels : true,
                EnablePerDiem = formProjectType == ProjectType.Custom ? formEnablePerDiem : true,
                EnableMileage = formProjectType == ProjectType.Custom ? formEnableMileage : true
            };
            Db.Seasons.Add(newSeason);
        }
        else
        {
            editingSeason.Name = formName;
            editingSeason.AthleteCount = formAthleteCount;
            editingSeason.IsActive = formIsActive;
            editingSeason.ProjectType = formProjectType;
            editingSeason.MeetLabel = formProjectType == ProjectType.Custom ? formMeetLabel : "Meet";
            editingSeason.CoachLabel = formProjectType == ProjectType.Custom ? formCoachLabel : "Coach";
            editingSeason.TeamLevelLabel = formProjectType == ProjectType.Custom ? formTeamLevelLabel : "Team Level";
            editingSeason.AthleteItemLabel = formProjectType == ProjectType.Custom ? formAthleteItemLabel : "Athlete Item";
            editingSeason.EnableTeamLevels = formProjectType == ProjectType.Custom ? formEnableTeamLevels : true;
            editingSeason.EnablePerDiem = formProjectType == ProjectType.Custom ? formEnablePerDiem : true;
            editingSeason.EnableMileage = formProjectType == ProjectType.Custom ? formEnableMileage : true;
            Db.Seasons.Update(editingSeason);
        }

        await Db.SaveChangesAsync();
        await LoadSeasons();
        showForm = false;
    }

    private async Task SetActive(Season season)
    {
        // Deactivate all seasons
        foreach (var s in Db.Seasons.Where(s => s.IsActive))
            s.IsActive = false;
        // Activate the selected one
        season.IsActive = true;
        await Db.SaveChangesAsync();
        await LoadSeasons();
    }

    private async Task TogglePublish(Season season)
    {
        season.IsPublished = !season.IsPublished;
        Db.Seasons.Update(season);
        await Db.SaveChangesAsync();
        await LoadSeasons();
    }

    private async Task DeleteSeason(Season season)
    {
        Db.Seasons.Remove(season);
        await Db.SaveChangesAsync();
        await LoadSeasons();
    }

    private void CancelForm()
    {
        showForm = false;
    }

    // --- Season Groups ---
    private int groupSeasonId;
    private List<SeasonGroup> seasonGroupsList = new();
    private bool showGroupForm;
    private SeasonGroup? editingGroup;
    private string groupFormName = "";
    private int groupFormSortOrder;

    private async Task LoadGroups()
    {
        seasonGroupsList = groupSeasonId > 0
            ? Db.SeasonGroups.Where(g => g.SeasonId == groupSeasonId).OrderBy(g => g.SortOrder).ToList()
            : new();
        await Task.CompletedTask;
    }

    private void ShowGroupForm() { editingGroup = null; groupFormName = ""; groupFormSortOrder = seasonGroupsList.Count; showGroupForm = true; }
    private void CancelGroupForm() { showGroupForm = false; }

    private void EditGroup(SeasonGroup g)
    {
        editingGroup = g; groupFormName = g.Name; groupFormSortOrder = g.SortOrder; showGroupForm = true;
    }

    private async Task SaveGroup()
    {
        if (string.IsNullOrWhiteSpace(groupFormName)) return;
        if (editingGroup == null)
        {
            Db.SeasonGroups.Add(new SeasonGroup { Name = groupFormName, SortOrder = groupFormSortOrder, SeasonId = groupSeasonId });
        }
        else
        {
            editingGroup.Name = groupFormName; editingGroup.SortOrder = groupFormSortOrder;
            Db.SeasonGroups.Update(editingGroup);
        }
        await Db.SaveChangesAsync();
        await LoadGroups();
        showGroupForm = false;
    }

    private async Task DeleteGroup(SeasonGroup g)
    {
        Db.SeasonGroups.Remove(g);
        await Db.SaveChangesAsync();
        await LoadGroups();
    }

    // --- Copy Structure ---
    private Season? copySource;
    private int copyTargetId;
    private bool isCopying;
    private bool copySuccess;
    private string? copyError;
    private CopyPreview? copyPreview;

    private class CopyPreview
    {
        public int CoachCount { get; set; }
        public int MeetCount { get; set; }
        public int TeamLevelCount { get; set; }
        public int AthleteItemCount { get; set; }
    }

    private void StartCopy(Season season)
    {
        copySource = season;
        copyTargetId = 0;
        copyPreview = null;
        copySuccess = false;
        copyError = null;
    }

    private void CancelCopy()
    {
        copySource = null;
        copyPreview = null;
        copySuccess = false;
        copyError = null;
    }

    private void UpdateCopyPreview()
    {
        copyPreview = null;
        copySuccess = false;
        copyError = null;
        if (copySource == null || copyTargetId <= 0) return;

        var levelIds = Db.TeamLevels.Where(t => t.SeasonId == copySource.Id).Select(t => t.Id).ToList();
        copyPreview = new CopyPreview
        {
            CoachCount = Db.Coaches.Count(c => c.SeasonId == copySource.Id),
            MeetCount = Db.Meets.Count(m => m.SeasonId == copySource.Id),
            TeamLevelCount = levelIds.Count,
            AthleteItemCount = Db.AthleteItems.Count(a => levelIds.Contains(a.TeamLevelId))
        };
    }

    private async Task DoClone()
    {
        if (copySource == null || copyTargetId <= 0) return;
        copyError = null;
        copySuccess = false;
        isCopying = true;

        try
        {
            var srcId = copySource.Id;

            // 1. Copy coaches
            var srcCoaches = Db.Coaches.Where(c => c.SeasonId == srcId).ToList();
            foreach (var c in srcCoaches)
            {
                Db.Coaches.Add(new Coach { Name = c.Name, Role = c.Role, IsActive = c.IsActive, SeasonId = copyTargetId });
            }
            await Db.SaveChangesAsync();

            // 2. Copy meets
            var srcMeets = Db.Meets.Where(m => m.SeasonId == srcId).ToList();
            foreach (var m in srcMeets)
            {
                Db.Meets.Add(new Meet { Name = m.Name, Date = m.Date, TravelType = m.TravelType, SeasonId = copyTargetId });
            }
            await Db.SaveChangesAsync();

            // 3. Copy team levels + athlete items
            var srcLevels = Db.TeamLevels.Where(t => t.SeasonId == srcId).ToList();
            var srcLevelIds = srcLevels.Select(t => t.Id).ToList();
            var srcAthleteItems = Db.AthleteItems.Where(a => srcLevelIds.Contains(a.TeamLevelId)).ToList();

            foreach (var level in srcLevels)
            {
                var newLevel = new TeamLevel { Name = level.Name, AthleteCount = level.AthleteCount, PaymentPlanMonths = level.PaymentPlanMonths, SeasonId = copyTargetId };
                Db.TeamLevels.Add(newLevel);
                await Db.SaveChangesAsync();

                foreach (var item in srcAthleteItems.Where(a => a.TeamLevelId == level.Id))
                {
                    Db.AthleteItems.Add(new AthleteItem { Name = item.Name, Cost = item.Cost, IsRequired = item.IsRequired, TeamLevelId = newLevel.Id });
                }
                await Db.SaveChangesAsync();
            }

            copySuccess = true;
        }
        catch (Exception ex)
        {
            copyError = $"Copy failed: {ex.Message}";
        }
        finally
        {
            isCopying = false;
        }
    }
}
