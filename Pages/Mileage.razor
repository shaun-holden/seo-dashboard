@page "/mileage"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.JSInterop
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState

<h3>Mileage</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex align-items-center gap-4 mb-3 flex-wrap">
        <div>
            <label>Select Season</label>
            <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
                <option value="">-- Select Season --</option>
                @foreach (var s in seasons)
                {
                    <option value="@s.Id" selected="@(s.Id == selectedSeasonId)">@s.Name</option>
                }
            </select>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label class="mb-0 fw-semibold">Default Rate/Mile ($)</label>
            <input type="number" step="0.001" class="form-control" style="width:110px"
                   @bind="defaultRate" @bind:event="oninput" />
        </div>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="mb-3">
            <label>Select @labels.Meet</label>
            <select class="form-select w-auto d-inline-block ms-2" @onchange="OnMeetChanged">
                <option value="0">-- Select @labels.Meet --</option>
                @foreach (var m in meets)
                {
                    <option value="@m.Id">@m.Name</option>
                }
            </select>
        </div>
    }

    @if (selectedMeetId > 0)
    {
        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-primary" @onclick="ShowForm">+ Add Entry</button>
            <button class="btn btn-outline-secondary" @onclick="ExportCsv">Export CSV</button>
        </div>

        @if (showForm)
        {
            <div class="card mb-4 p-3">
                <h5>@(editingEntry == null ? "Add Mileage Entry" : "Edit Entry")</h5>
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <label>@labels.Coach</label>
                        <select class="form-select" @bind="formCoachId">
                            <option value="0">-- Select @labels.Coach --</option>
                            @foreach (var c in coaches)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Miles</label>
                        <input type="number" step="0.1" class="form-control" @bind="formMiles" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Rate Per Mile ($)</label>
                        <input type="number" step="0.001" class="form-control" @bind="formRatePerMile" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Type</label>
                        <select class="form-select" @bind="formIsActual">
                            <option value="false">Budgeted</option>
                            <option value="true">Actual</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="SaveEntry">Save</button>
                <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        }

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>@labels.Coach</th>
                    <th>Miles</th>
                    <th>Rate/Mile</th>
                    <th>Total</th>
                    <th>Type</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in entries)
                {
                    <tr>
                        <td>@coaches.FirstOrDefault(c => c.Id == entry.CoachId)?.Name</td>
                        <td>@entry.Miles.ToString("N1")</td>
                        <td>$@entry.RatePerMile.ToString("N3")</td>
                        <td>$@entry.Total.ToString("N2")</td>
                        <td>@(entry.IsActual ? "Actual" : "Budgeted")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditEntry(entry)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(entry)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold">
                    <td colspan="3">Total</td>
                    <td>$@entries.Sum(e => e.Total).ToString("N2")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    }
}

@code {
    private List<Season>? seasons;
    private List<Meet> meets = new();
    private List<Coach> coaches = new();
    private List<MileageEntry> entries = new();
    private int selectedSeasonId;
    private int selectedMeetId;
    private bool showForm;
    private MileageEntry? editingEntry;
    private int formCoachId = 0;
    private decimal formMiles = 0;
    private decimal defaultRate = 0.67m;
    private decimal formRatePerMile = 0.67m;
    private bool formIsActual = false;
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Task.FromResult(Db.Seasons.OrderByDescending(s => s.Name).ToList());
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        selectedMeetId = 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadMeets();
    }

    private async Task OnMeetChanged(ChangeEventArgs e)
    {
        selectedMeetId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await LoadEntries();
    }

    private async Task LoadMeets()
    {
        Db.ChangeTracker.Clear();
        meets = Db.Meets.Where(m => m.SeasonId == selectedSeasonId).OrderBy(m => m.Date).ToList();
        coaches = Db.Coaches.Where(c => c.SeasonId == selectedSeasonId).ToList();
    }

    private async Task LoadEntries()
    {
        entries = await Task.FromResult(Db.MileageEntries.Where(m => m.MeetId == selectedMeetId).ToList());
    }

    private void ShowForm() { editingEntry = null; formCoachId = 0; formMiles = 0; formRatePerMile = defaultRate; formIsActual = false; showForm = true; }
    private void CancelForm() { showForm = false; }

    private void EditEntry(MileageEntry entry)
    {
        editingEntry = entry; formCoachId = entry.CoachId; formMiles = entry.Miles;
        formRatePerMile = entry.RatePerMile; formIsActual = entry.IsActual; showForm = true;
    }

    private async Task SaveEntry()
    {
        if (editingEntry == null)
        {
            Db.MileageEntries.Add(new MileageEntry
            {
                CoachId = formCoachId, Miles = formMiles,
                RatePerMile = formRatePerMile, IsActual = formIsActual,
                MeetId = selectedMeetId
            });
        }
        else
        {
            editingEntry.CoachId = formCoachId; editingEntry.Miles = formMiles;
            editingEntry.RatePerMile = formRatePerMile; editingEntry.IsActual = formIsActual;
            Db.MileageEntries.Update(editingEntry);
        }
        await Db.SaveChangesAsync();
        await LoadEntries();
        showForm = false;
    }

    private async Task DeleteEntry(MileageEntry entry)
    {
        Db.MileageEntries.Remove(entry);
        await Db.SaveChangesAsync();
        await LoadEntries();
    }

    private async Task ExportCsv()
    {
        var meet = meets.FirstOrDefault(m => m.Id == selectedMeetId);
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Coach,Miles,Rate Per Mile,Total,Type");
        foreach (var e in entries)
        {
            var name = coaches.FirstOrDefault(c => c.Id == e.CoachId)?.Name ?? "";
            sb.AppendLine($"{name},{e.Miles:N1},${e.RatePerMile:N3},${e.Total:N2},{(e.IsActual ? "Actual" : "Budgeted")}");
        }
        var filename = $"mileage_{meet?.Name ?? "export"}_{DateTime.Today:yyyyMMdd}.csv"
            .Replace(" ", "_");
        await JS.InvokeVoidAsync("downloadFile", filename, sb.ToString());
    }
}
