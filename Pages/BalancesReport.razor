@page "/reports/balances"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Text
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<div class="d-flex align-items-center gap-2 mb-2">
    <a href="/reports" class="btn btn-sm btn-outline-secondary">
        <span class="oi oi-arrow-left"></span> Back
    </a>
    <h3 class="mb-0">Outstanding Balances Report</h3>
</div>

<div class="row g-2 align-items-center mb-3">
    @if (levels.Any())
    {
        <div class="col-auto">
            <label class="col-form-label fw-semibold">Level</label>
        </div>
        <div class="col-auto">
            <select class="form-select" @onchange="OnLevelChanged">
                <option value="">All Levels</option>
                @foreach (var level in levels)
                {
                    <option value="@level">@level</option>
                }
            </select>
        </div>
    }
    @if (balanceRows.Any())
    {
        <div class="col-auto ms-auto">
            <button class="btn btn-outline-success btn-sm" @onclick="ExportCsv">
                <span class="oi oi-data-transfer-download me-1"></span>CSV
            </button>
        </div>
    }
</div>

@if (loading)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h6>Total Outstanding</h6>
                    <h4>$@filteredRows.Where(r => r.Balance > 0).Sum(r => r.Balance).ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h6>With Balance</h6>
                    <h4>@filteredRows.Count(r => r.Balance > 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h6>Average Balance</h6>
                    @if (filteredRows.Any(r => r.Balance > 0))
                    {
                        <h4>$@(filteredRows.Where(r => r.Balance > 0).Average(r => r.Balance).ToString("N2"))</h4>
                    }
                    else
                    {
                        <h4>$0.00</h4>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!filteredRows.Any())
    {
        <p class="text-muted">No gymnast data found.</p>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Level</th>
                            <th class="text-end">Total Fees</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Credits</th>
                            <th class="text-end">Balance</th>
                            <th>Parent Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in filteredRows)
                        {
                            <tr class="@(row.Balance > 0 ? "table-warning" : "")">
                                <td>@row.Name</td>
                                <td>@row.Level</td>
                                <td class="text-end">$@row.TotalFees.ToString("N2")</td>
                                <td class="text-end">$@row.Paid.ToString("N2")</td>
                                <td class="text-end">$@row.Credits.ToString("N2")</td>
                                <td class="text-end fw-bold @(row.Balance > 0 ? "text-danger" : "text-success")">$@row.Balance.ToString("N2")</td>
                                <td>@row.ParentEmail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private bool loading = true;
    private string filterLevel = "";
    private List<string> levels = new();
    private List<BalanceRow> balanceRows = new();

    private List<BalanceRow> filteredRows =>
        !string.IsNullOrEmpty(filterLevel)
            ? balanceRows.Where(r => r.Level == filterLevel).ToList()
            : balanceRows;

    private record BalanceRow(string Name, string Level, decimal TotalFees, decimal Paid, decimal Credits, decimal Balance, string ParentEmail);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void OnLevelChanged(ChangeEventArgs e)
    {
        filterLevel = e.Value?.ToString() ?? "";
    }

    private async Task LoadData()
    {
        loading = true;
        balanceRows.Clear();
        levels.Clear();

        using var db = await DbFactory.CreateDbContextAsync();

        // Get active published season for cost-per-gymnast calculation
        var season = await db.Seasons
            .Where(s => s.IsActive)
            .OrderByDescending(s => s.Name)
            .FirstOrDefaultAsync();

        decimal costPerGymnast = 0;
        if (season != null)
        {
            var calcTotal = await db.BudgetCalculatorEntries
                .Where(e => e.SeasonId == season.Id)
                .SumAsync(e => e.CalculatedTotal);
            costPerGymnast = season.AthleteCount > 0 ? calcTotal / season.AthleteCount : 0;
        }
        else
        {
            loading = false;
            return;
        }

        // Load all gymnasts
        var gymnasts = await db.Gymnasts.ToListAsync();

        // Load athletes for payment matching (payments reference AthleteId)
        var seasonLevelIds = await db.TeamLevels
            .Where(t => t.SeasonId == season.Id)
            .Select(t => t.Id)
            .ToListAsync();
        var athletes = await db.Athletes
            .Where(a => seasonLevelIds.Contains(a.TeamLevelId))
            .ToListAsync();
        var athleteIds = athletes.Select(a => a.Id).ToList();
        var payments = await db.Payments
            .Where(p => p.SeasonId == season.Id && athleteIds.Contains(p.AthleteId) && p.Status == PaymentStatus.Paid)
            .ToListAsync();

        // Build name-to-payments lookup
        var athleteByName = athletes
            .GroupBy(a => a.Name, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

        var rows = new List<BalanceRow>();
        var seasonLevelNames = await db.TeamLevels
            .Where(t => t.SeasonId == season.Id)
            .Select(t => t.Name)
            .ToListAsync();
        foreach (var gymnast in gymnasts.Where(g => !string.IsNullOrWhiteSpace(g.Level) && seasonLevelNames.Contains(g.Level!)))
        {
            var level = string.IsNullOrWhiteSpace(gymnast.Level) ? "Unassigned" : gymnast.Level;

            // Find matching athlete(s) for payment lookup
            decimal paid = 0;
            decimal credits = 0;
            if (athleteByName.TryGetValue(gymnast.Name, out var matchedAthletes))
            {
                var matchedIds = matchedAthletes.Select(a => a.Id).ToHashSet();
                paid = payments
                    .Where(p => matchedIds.Contains(p.AthleteId) && p.Type == PaymentType.Payment)
                    .Sum(p => p.Amount);
                credits = payments
                    .Where(p => matchedIds.Contains(p.AthleteId) && p.Type == PaymentType.Credit)
                    .Sum(p => p.Amount);
            }

            var totalFees = costPerGymnast;
            var balance = totalFees - paid - credits;

            rows.Add(new BalanceRow(
                gymnast.Name,
                level,
                totalFees,
                paid,
                credits,
                balance,
                gymnast.ParentEmail ?? ""
            ));
        }

        balanceRows = rows.OrderByDescending(r => r.Balance).ToList();
        levels = balanceRows
            .Select(r => r.Level)
            .Distinct()
            .OrderBy(l => l)
            .ToList();

        loading = false;
    }

    private async Task ExportPdf()
    {
        await JS.InvokeVoidAsync("exportPdf");
    }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name,Level,Total Fees,Paid,Credits,Balance,Parent Email");
        foreach (var row in filteredRows)
        {
            sb.AppendLine($"{EscapeCsv(row.Name)},{EscapeCsv(row.Level)},{row.TotalFees:F2},{row.Paid:F2},{row.Credits:F2},{row.Balance:F2},{EscapeCsv(row.ParentEmail)}");
        }
        await JS.InvokeVoidAsync("downloadFile", "balances-report.csv", sb.ToString());
    }

    private string EscapeCsv(string val)
    {
        if (val.Contains(',') || val.Contains('"'))
            return $"\"{val.Replace("\"", "\"\"")}\"";
        return val;
    }
}
