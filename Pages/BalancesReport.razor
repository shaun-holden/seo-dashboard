@page "/reports/balances"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Text
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<h3 class="mb-3">Outstanding Balances Report</h3>

<div class="row g-2 align-items-center mb-3">
    <div class="col-auto">
        <label class="col-form-label fw-semibold">Season</label>
    </div>
    <div class="col-auto">
        <select class="form-select" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @if (seasons != null)
            {
                @foreach (var s in seasons)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            }
        </select>
    </div>
    @if (teamLevels.Any())
    {
        <div class="col-auto">
            <label class="col-form-label fw-semibold">Level</label>
        </div>
        <div class="col-auto">
            <select class="form-select" @onchange="OnLevelChanged">
                <option value="0">All Levels</option>
                @foreach (var level in teamLevels)
                {
                    <option value="@level.Id">@level.Name</option>
                }
            </select>
        </div>
    }
    @if (balanceRows.Any())
    {
        <div class="col-auto ms-auto">
            <button class="btn btn-outline-success btn-sm" @onclick="ExportCsv">
                <span class="oi oi-data-transfer-download me-1"></span>Export CSV
            </button>
        </div>
    }
</div>

@if (selectedSeasonId > 0)
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h6>Total Outstanding</h6>
                    <h4>$@filteredRows.Where(r => r.Balance > 0).Sum(r => r.Balance).ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h6>With Balance</h6>
                    <h4>@filteredRows.Count(r => r.Balance > 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h6>Average Balance</h6>
                    @if (filteredRows.Any(r => r.Balance > 0))
                    {
                        <h4>$@(filteredRows.Where(r => r.Balance > 0).Average(r => r.Balance).ToString("N2"))</h4>
                    }
                    else
                    {
                        <h4>$0.00</h4>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!filteredRows.Any())
    {
        <p class="text-muted">No gymnast data found for this season.</p>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Level</th>
                            <th class="text-end">Total Fees</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Credits</th>
                            <th class="text-end">Balance</th>
                            <th>Parent Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in filteredRows)
                        {
                            <tr class="@(row.Balance > 0 ? "table-warning" : "")">
                                <td>@row.Name</td>
                                <td>@row.Level</td>
                                <td class="text-end">$@row.TotalFees.ToString("N2")</td>
                                <td class="text-end">$@row.Paid.ToString("N2")</td>
                                <td class="text-end">$@row.Credits.ToString("N2")</td>
                                <td class="text-end fw-bold @(row.Balance > 0 ? "text-danger" : "text-success")">$@row.Balance.ToString("N2")</td>
                                <td>@row.ParentEmail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private int selectedSeasonId;
    private int filterLevelId;
    private List<TeamLevel> teamLevels = new();
    private List<BalanceRow> balanceRows = new();

    private List<BalanceRow> filteredRows =>
        filterLevelId > 0
            ? balanceRows.Where(r => r.TeamLevelId == filterLevelId).ToList()
            : balanceRows;

    private record BalanceRow(string Name, string Level, int TeamLevelId, decimal TotalFees, decimal Paid, decimal Credits, decimal Balance, string ParentEmail);

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasons = await db.Seasons.Where(s => s.IsActive).OrderByDescending(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        filterLevelId = 0;
        await LoadData();
    }

    private void OnLevelChanged(ChangeEventArgs e)
    {
        filterLevelId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
    }

    private async Task LoadData()
    {
        balanceRows.Clear();
        teamLevels.Clear();
        if (selectedSeasonId <= 0) return;

        using var db = await DbFactory.CreateDbContextAsync();

        var season = await db.Seasons.FindAsync(selectedSeasonId);
        if (season == null) return;

        teamLevels = await db.TeamLevels
            .Where(t => t.SeasonId == selectedSeasonId)
            .ToListAsync();

        // Calculate cost per gymnast from budget calculator
        var calcTotal = await db.BudgetCalculatorEntries
            .Where(e => e.SeasonId == selectedSeasonId)
            .SumAsync(e => e.CalculatedTotal);
        var costPerGymnast = season.AthleteCount > 0 ? calcTotal / season.AthleteCount : 0;

        var athletes = await db.Athletes
            .Include(a => a.TeamLevel)
            .Where(a => a.TeamLevel.SeasonId == selectedSeasonId)
            .ToListAsync();

        var athleteIds = athletes.Select(a => a.Id).ToList();
        var payments = await db.Payments
            .Where(p => athleteIds.Contains(p.AthleteId) && p.Status == PaymentStatus.Paid)
            .ToListAsync();

        // Also pull gymnast data for parent emails
        var gymnasts = await db.Gymnasts.ToListAsync();

        var rows = new List<BalanceRow>();
        foreach (var athlete in athletes)
        {
            var athletePayments = payments.Where(p => p.AthleteId == athlete.Id).ToList();
            var paid = athletePayments.Where(p => p.Type == PaymentType.Payment).Sum(p => p.Amount);
            var credits = athletePayments.Where(p => p.Type == PaymentType.Credit).Sum(p => p.Amount);
            var totalFees = costPerGymnast;
            var balance = totalFees - paid - credits;
            var parentEmail = gymnasts.FirstOrDefault(g =>
                string.Equals(g.Name, athlete.Name, StringComparison.OrdinalIgnoreCase))?.ParentEmail ?? "";

            rows.Add(new BalanceRow(
                athlete.Name,
                athlete.TeamLevel?.Name ?? "",
                athlete.TeamLevelId,
                totalFees,
                paid,
                credits,
                balance,
                parentEmail
            ));
        }

        balanceRows = rows.OrderByDescending(r => r.Balance).ToList();
    }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name,Level,Total Fees,Paid,Credits,Balance,Parent Email");
        foreach (var row in filteredRows)
        {
            sb.AppendLine($"{EscapeCsv(row.Name)},{EscapeCsv(row.Level)},{row.TotalFees:F2},{row.Paid:F2},{row.Credits:F2},{row.Balance:F2},{EscapeCsv(row.ParentEmail)}");
        }
        await JS.InvokeVoidAsync("downloadFile", "balances-report.csv", sb.ToString());
    }

    private string EscapeCsv(string val)
    {
        if (val.Contains(',') || val.Contains('"'))
            return $"\"{val.Replace("\"", "\"\"")}\"";
        return val;
    }
}
