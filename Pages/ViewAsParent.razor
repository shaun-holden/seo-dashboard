@page "/view-as-parent"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<IdentityUser> UserManager
@inject NavigationManager Navigation

<h3>View as Parent</h3>
<p class="text-muted">Select a parent to preview their dashboard exactly as they see it.</p>

@if (!isAdmin)
{
    <div class="alert alert-danger">You do not have permission to access this page.</div>
}
else
{
    <div class="mb-3" style="max-width: 400px;">
        <input class="form-control" placeholder="Search by parent email or athlete name..."
               @bind="searchText" @bind:event="oninput" />
    </div>

    @if (!parentGroups.Any())
    {
        <p class="text-muted">No parents have claimed invite codes yet.</p>
    }
    else
    {
        <div class="row">
            @foreach (var parent in filteredParents)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title mb-1">@parent.Email</h6>
                            <div class="mb-2">
                                @foreach (var athlete in parent.Athletes)
                                {
                                    <span class="badge bg-primary me-1">@athlete</span>
                                }
                            </div>
                            <a href="/parent?viewAs=@parent.UserId" class="btn btn-sm btn-outline-info">
                                <span class="oi oi-eye me-1"></span> View Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private bool isAdmin;
    private string searchText = "";
    private List<ParentGroup> parentGroups = new();

    private List<ParentGroup> filteredParents => string.IsNullOrWhiteSpace(searchText)
        ? parentGroups
        : parentGroups.Where(p =>
            p.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || p.Athletes.Any(a => a.Contains(searchText, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        isAdmin = authState.User.IsInRole("Employee")
            || (!string.IsNullOrEmpty(email) && string.Equals(email, "deshaun@tntgym.org", StringComparison.OrdinalIgnoreCase));

        if (!isAdmin) return;

        using var db = await DbFactory.CreateDbContextAsync();
        var claimedLinks = await db.ParentLinks.AsNoTracking()
            .Where(pl => pl.IsClaimed && pl.ParentUserId != null)
            .ToListAsync();

        var gymnasts = await db.Gymnasts.AsNoTracking()
            .Where(g => !g.IsArchived)
            .ToDictionaryAsync(g => g.Id, g => g.Name);

        var parentUserIds = claimedLinks.Select(pl => pl.ParentUserId!).Distinct().ToList();
        var users = await UserManager.Users
            .Where(u => parentUserIds.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.Email ?? u.UserName ?? "Unknown");

        parentGroups = claimedLinks
            .GroupBy(pl => pl.ParentUserId!)
            .Select(g => new ParentGroup
            {
                UserId = g.Key,
                Email = users.GetValueOrDefault(g.Key, "Unknown"),
                Athletes = g.Select(pl => gymnasts.GetValueOrDefault(pl.AthleteId, "Unknown")).OrderBy(n => n).ToList()
            })
            .OrderBy(p => p.Email)
            .ToList();
    }

    private record ParentGroup
    {
        public string UserId { get; init; } = "";
        public string Email { get; init; } = "";
        public List<string> Athletes { get; init; } = new();
    }
}
