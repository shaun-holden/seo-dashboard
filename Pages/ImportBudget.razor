@page "/import-budget"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<IdentityUser> UserManager

<h3>Import Budget</h3>
<p class="text-muted">Copy a season's data (meets, coaches, team levels, and budget items) from another user's account into one of your seasons.</p>

<!-- Your Import PIN -->
<div class="card mb-4 p-3" style="max-width: 600px;">
    <h5>Your Import PIN</h5>
    <p class="text-muted small mb-2">Set a 4-digit PIN so other users can import your data. Without a PIN, no one can import from your account.</p>
    @if (myPin != null && !isEditingPin)
    {
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-success fs-6 font-monospace">@myPin.Pin</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { isEditingPin = true; newPin = myPin.Pin; }">Change</button>
            <button class="btn btn-sm btn-outline-danger" @onclick="RemovePin">Remove</button>
        </div>
    }
    else
    {
        <div class="input-group" style="max-width: 260px;">
            <input class="form-control" placeholder="4-digit PIN" @bind="newPin" maxlength="4" />
            <button class="btn btn-primary" @onclick="SavePin">Save</button>
            @if (isEditingPin)
            {
                <button class="btn btn-outline-secondary" @onclick="() => { isEditingPin = false; newPin = string.Empty; pinError = null; }">Cancel</button>
            }
        </div>
        @if (pinError != null)
        {
            <div class="text-danger small mt-1">@pinError</div>
        }
    }
</div>

<!-- Step 1: Find Employee -->
<div class="card mb-4 p-3" style="max-width: 600px;">
    <h5>Step 1: Find Employee</h5>
    <div class="input-group mb-2">
        <input class="form-control" placeholder="Employee email address" @bind="searchEmail" @bind:event="oninput" />
        <button class="btn btn-primary" @onclick="SearchUser" disabled="@isSearching">
            @if (isSearching) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Search
        </button>
    </div>
    @if (searchError != null)
    {
        <div class="alert alert-danger py-2">@searchError</div>
    }
</div>

<!-- Step 2: Enter PIN -->
@if (requiresPin)
{
    <div class="card mb-4 p-3" style="max-width: 600px;">
        <h5>Step 2: Enter Import PIN</h5>
        <p class="text-muted small mb-2">This user requires a PIN to import their data. Ask them for their 4-digit import PIN.</p>
        @if (pinAttempts >= 3)
        {
            <div class="alert alert-danger py-2">Too many incorrect attempts. Please search for the user again.</div>
        }
        else
        {
            <div class="input-group" style="max-width: 260px;">
                <input class="form-control" placeholder="4-digit PIN" @bind="enteredPin" maxlength="4" />
                <button class="btn btn-primary" @onclick="VerifyPin">Verify</button>
            </div>
            @if (pinVerifyError != null)
            {
                <div class="text-danger small mt-1">@pinVerifyError</div>
            }
        }
    </div>
}

<!-- Step 3: Select Seasons -->
@if (employeeSeasons != null && pinVerified)
{
    <div class="card mb-4 p-3" style="max-width: 600px;">
        <h5>Step @(requiresPin ? "3" : "2"): Select Seasons</h5>
        <div class="mb-3">
            <label class="form-label fw-semibold">Import from (employee season)</label>
            <select class="form-select" @bind="srcSeasonId" @bind:after="UpdatePreview">
                <option value="0">-- Select Season --</option>
                @foreach (var s in employeeSeasons)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Import into (your season)</label>
            <select class="form-select" @bind="targetSeasonId" @bind:after="OnTargetSeasonChanged">
                <option value="0">-- Select Season --</option>
                @foreach (var s in mySeasons)
                {
                    <option value="@s.Id">@s.Name</option>
                }
                <option value="-1">+ Create New Season</option>
            </select>
        </div>

        @if (isCreatingNewSeason)
        {
            <div class="card bg-light p-3 mb-3">
                <h6>New Season</h6>
                <div class="mb-2">
                    <input class="form-control" placeholder="Season name (e.g. 2026-2027)" @bind="newSeasonName" />
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-primary" @onclick="CreateSeason">Create</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelNewSeason">Cancel</button>
                </div>
                @if (newSeasonError != null)
                {
                    <div class="text-danger small mt-1">@newSeasonError</div>
                }
            </div>
        }

        @if (srcSeasonId > 0 && targetSeasonId > 0 && preview != null)
        {
            <div class="alert alert-info">
                <strong>Preview — what will be imported:</strong>
                <ul class="mb-0 mt-1">
                    <li>@preview.MeetCount @(labels.Meet)(s)</li>
                    <li>@preview.CoachCount @(labels.Coach)(es)</li>
                    <li>@preview.TeamLevelCount @(labels.TeamLevel)(s) with @preview.AthleteItemCount @(labels.AthleteItem)(s)</li>
                    <li>@preview.BudgetItemCount budget line item(s)</li>
                </ul>
            </div>

            @if (preview.OverlapMeets.Any() || preview.OverlapCoaches.Any() || preview.OverlapLevels.Any())
            {
                <div class="alert alert-warning">
                    <strong>⚠️ The following items already exist and will be replaced:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var name in preview.OverlapMeets) { <li>@labels.Meet: @name</li> }
                        @foreach (var name in preview.OverlapCoaches) { <li>@labels.Coach: @name</li> }
                        @foreach (var name in preview.OverlapLevels) { <li>@labels.TeamLevel: @name</li> }
                    </ul>
                </div>
            }

            @if (importError != null)
            {
                <div class="alert alert-danger py-2">@importError</div>
            }

            @if (importSuccess)
            {
                <div class="alert alert-success py-2">
                    Import complete! @preview.MeetCount @labels.Meets.ToLower(), @preview.CoachCount @labels.Coaches.ToLower(), @preview.TeamLevelCount @labels.TeamLevels.ToLower(), and @preview.BudgetItemCount budget items were imported to your season.
                </div>
            }
            else if (showOverrideConfirm)
            {
                <div class="alert alert-danger">
                    <strong>Are you sure?</strong> This will delete and replace the existing items listed above with the imported data. This cannot be undone.
                    <div class="mt-2">
                        <button class="btn btn-danger me-2" @onclick="ConfirmImport" disabled="@isImporting">
                            @if (isImporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Yes, Replace &amp; Import
                        </button>
                        <button class="btn btn-secondary" @onclick="() => showOverrideConfirm = false">Cancel</button>
                    </div>
                </div>
            }
            else
            {
                <button class="btn btn-success" @onclick="DoImport" disabled="@isImporting">
                    @if (isImporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Import
                </button>
            }
        }
    </div>
}

@code {
    private string searchEmail = "";
    private bool isSearching;
    private string? searchError;
    private List<Season>? employeeSeasons;
    private List<Season> mySeasons = new();
    private string? employeeUserId;
    private string? currentUserId;

    private int srcSeasonId;
    private int targetSeasonId;
    private ImportPreview? preview;

    private bool isImporting;
    private bool importSuccess;
    private string? importError;

    // PIN management
    private UserImportPin? myPin;
    private string newPin = "";
    private string? pinError;
    private bool isEditingPin;

    // PIN verification
    private bool requiresPin;
    private bool pinVerified;
    private string enteredPin = "";
    private string? pinVerifyError;
    private int pinAttempts;
    private string? employeePinHash;

    // Create new season
    private bool isCreatingNewSeason;
    private string newSeasonName = "";
    private string? newSeasonError;

    // Override confirmation
    private bool showOverrideConfirm;

    private ProjectLabels labels = ProjectLabels.Default;

    private class ImportPreview
    {
        public int MeetCount { get; set; }
        public int CoachCount { get; set; }
        public int TeamLevelCount { get; set; }
        public int AthleteItemCount { get; set; }
        public int BudgetItemCount { get; set; }
        public List<string> OverlapMeets { get; set; } = new();
        public List<string> OverlapCoaches { get; set; } = new();
        public List<string> OverlapLevels { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        mySeasons = Db.Seasons.Where(s => s.UserId == currentUserId).OrderByDescending(s => s.Name).ToList();
        myPin = Db.UserImportPins.FirstOrDefault(p => p.UserId == currentUserId);
        var activeSeason = mySeasons.FirstOrDefault(s => s.IsActive);
        labels = new ProjectLabels(activeSeason);
    }

    private async Task SavePin()
    {
        pinError = null;
        if (string.IsNullOrWhiteSpace(newPin) || newPin.Length != 4 || !newPin.All(char.IsDigit))
        {
            pinError = "PIN must be exactly 4 digits.";
            return;
        }

        if (myPin == null)
        {
            myPin = new UserImportPin { UserId = currentUserId!, Pin = newPin };
            Db.UserImportPins.Add(myPin);
        }
        else
        {
            myPin.Pin = newPin;
        }
        await Db.SaveChangesAsync();
        isEditingPin = false;
        newPin = "";
    }

    private async Task RemovePin()
    {
        if (myPin != null)
        {
            Db.UserImportPins.Remove(myPin);
            await Db.SaveChangesAsync();
            myPin = null;
        }
    }

    private async Task SearchUser()
    {
        searchError = null;
        employeeSeasons = null;
        srcSeasonId = 0;
        targetSeasonId = 0;
        preview = null;
        importSuccess = false;
        requiresPin = false;
        pinVerified = false;
        enteredPin = "";
        pinVerifyError = null;
        pinAttempts = 0;
        employeePinHash = null;

        if (string.IsNullOrWhiteSpace(searchEmail)) { searchError = "Please enter an email address."; return; }

        isSearching = true;
        var user = await UserManager.FindByEmailAsync(searchEmail.Trim());
        isSearching = false;

        if (user == null) { searchError = "No account found with that email address."; return; }
        if (user.Id == currentUserId) { searchError = "You cannot import from your own account."; return; }

        // Check if the user has an import PIN set
        var userPin = Db.UserImportPins.FirstOrDefault(p => p.UserId == user.Id);
        if (userPin == null)
        {
            searchError = "This user has not enabled imports. They need to set an Import PIN on their account first.";
            return;
        }

        employeeUserId = user.Id;
        employeePinHash = userPin.Pin;
        requiresPin = true;
    }

    private void VerifyPin()
    {
        pinVerifyError = null;

        if (string.IsNullOrWhiteSpace(enteredPin))
        {
            pinVerifyError = "Please enter the PIN.";
            return;
        }

        if (enteredPin == employeePinHash)
        {
            pinVerified = true;
            employeeSeasons = Db.Seasons.Where(s => s.UserId == employeeUserId).OrderByDescending(s => s.Name).ToList();
            if (!employeeSeasons.Any())
            {
                searchError = "That user has no seasons to import from.";
                employeeSeasons = null;
                requiresPin = false;
                pinVerified = false;
            }
        }
        else
        {
            pinAttempts++;
            if (pinAttempts >= 3)
            {
                pinVerifyError = null; // The "too many attempts" message handles this
            }
            else
            {
                pinVerifyError = $"Incorrect PIN. {3 - pinAttempts} attempt(s) remaining.";
            }
        }
    }

    private void OnTargetSeasonChanged()
    {
        if (targetSeasonId == -1)
        {
            isCreatingNewSeason = true;
            targetSeasonId = 0;
        }
        else
        {
            isCreatingNewSeason = false;
        }
        UpdatePreview();
    }

    private async Task CreateSeason()
    {
        newSeasonError = null;
        if (string.IsNullOrWhiteSpace(newSeasonName))
        {
            newSeasonError = "Please enter a season name.";
            return;
        }

        var season = new Season { Name = newSeasonName.Trim(), UserId = currentUserId!, IsActive = true };
        Db.Seasons.Add(season);
        await Db.SaveChangesAsync();

        mySeasons = Db.Seasons.Where(s => s.UserId == currentUserId).OrderByDescending(s => s.Name).ToList();
        targetSeasonId = season.Id;
        isCreatingNewSeason = false;
        newSeasonName = "";
        UpdatePreview();
    }

    private void CancelNewSeason()
    {
        isCreatingNewSeason = false;
        newSeasonName = "";
        newSeasonError = null;
        targetSeasonId = 0;
    }

    private void UpdatePreview()
    {
        preview = null;
        importSuccess = false;
        importError = null;
        showOverrideConfirm = false;
        if (srcSeasonId <= 0 || targetSeasonId <= 0) return;

        var srcMeetNames = Db.Meets.Where(m => m.SeasonId == srcSeasonId).Select(m => m.Name).ToList();
        var srcCoachNames = Db.Coaches.Where(c => c.SeasonId == srcSeasonId).Select(c => c.Name).ToList();
        var srcLevelNames = Db.TeamLevels.Where(t => t.SeasonId == srcSeasonId).Select(t => t.Name).ToList();
        var levelIds = Db.TeamLevels.Where(t => t.SeasonId == srcSeasonId).Select(t => t.Id).ToList();

        var existingMeetNames = Db.Meets.Where(m => m.SeasonId == targetSeasonId).Select(m => m.Name).ToList();
        var existingCoachNames = Db.Coaches.Where(c => c.SeasonId == targetSeasonId).Select(c => c.Name).ToList();
        var existingLevelNames = Db.TeamLevels.Where(t => t.SeasonId == targetSeasonId).Select(t => t.Name).ToList();

        preview = new ImportPreview
        {
            MeetCount = srcMeetNames.Count,
            CoachCount = srcCoachNames.Count,
            TeamLevelCount = srcLevelNames.Count,
            AthleteItemCount = Db.AthleteItems.Count(a => levelIds.Contains(a.TeamLevelId)),
            BudgetItemCount = Db.BudgetLineItems.Count(b => b.SeasonId == srcSeasonId),
            OverlapMeets = srcMeetNames.Where(n => existingMeetNames.Contains(n)).ToList(),
            OverlapCoaches = srcCoachNames.Where(n => existingCoachNames.Contains(n)).ToList(),
            OverlapLevels = srcLevelNames.Where(n => existingLevelNames.Contains(n)).ToList()
        };
    }

    private async Task DoImport()
    {
        // If there are overlaps, show confirmation first
        if (preview != null && (preview.OverlapMeets.Any() || preview.OverlapCoaches.Any() || preview.OverlapLevels.Any()))
        {
            showOverrideConfirm = true;
            return;
        }
        await ConfirmImport();
    }

    private async Task ConfirmImport()
    {
        importError = null;
        importSuccess = false;
        isImporting = true;
        showOverrideConfirm = false;

        try
        {
            // Load source data
            var srcCoaches = Db.Coaches.Where(c => c.SeasonId == srcSeasonId).ToList();
            var srcMeets = Db.Meets.Where(m => m.SeasonId == srcSeasonId).ToList();
            var srcLevels = Db.TeamLevels.Where(t => t.SeasonId == srcSeasonId).ToList();
            var srcLevelIds = srcLevels.Select(t => t.Id).ToList();
            var srcAthleteItems = Db.AthleteItems.Where(a => srcLevelIds.Contains(a.TeamLevelId)).ToList();
            var srcItems = Db.BudgetLineItems.Where(b => b.SeasonId == srcSeasonId).ToList();

            // Remove existing items that overlap by name
            if (preview != null)
            {
                // Remove overlapping meets (and their related budget line items)
                if (preview.OverlapMeets.Any())
                {
                    var existingMeets = Db.Meets.Where(m => m.SeasonId == targetSeasonId && preview.OverlapMeets.Contains(m.Name)).ToList();
                    var existingMeetIds = existingMeets.Select(m => m.Id).ToList();
                    var relatedBudgetItems = Db.BudgetLineItems.Where(b => b.MeetId.HasValue && existingMeetIds.Contains(b.MeetId.Value)).ToList();
                    Db.BudgetLineItems.RemoveRange(relatedBudgetItems);
                    var relatedMeetGroups = Db.MeetGroupAssignments.Where(a => existingMeetIds.Contains(a.MeetId)).ToList();
                    Db.MeetGroupAssignments.RemoveRange(relatedMeetGroups);
                    var relatedMeetLevels = Db.MeetTeamLevelAssignments.Where(a => existingMeetIds.Contains(a.MeetId)).ToList();
                    Db.MeetTeamLevelAssignments.RemoveRange(relatedMeetLevels);
                    var relatedCoachMeets = Db.CoachMeetAssignments.Where(a => existingMeetIds.Contains(a.MeetId)).ToList();
                    Db.CoachMeetAssignments.RemoveRange(relatedCoachMeets);
                    Db.Meets.RemoveRange(existingMeets);
                }

                // Remove overlapping coaches (and their related data)
                if (preview.OverlapCoaches.Any())
                {
                    var existingCoaches = Db.Coaches.Where(c => c.SeasonId == targetSeasonId && preview.OverlapCoaches.Contains(c.Name)).ToList();
                    var existingCoachIds = existingCoaches.Select(c => c.Id).ToList();
                    var relatedBudgetItems = Db.BudgetLineItems.Where(b => b.CoachId.HasValue && existingCoachIds.Contains(b.CoachId.Value)).ToList();
                    Db.BudgetLineItems.RemoveRange(relatedBudgetItems);
                    var relatedCoachGroups = Db.CoachGroupAssignments.Where(a => existingCoachIds.Contains(a.CoachId)).ToList();
                    Db.CoachGroupAssignments.RemoveRange(relatedCoachGroups);
                    var relatedCoachMeets = Db.CoachMeetAssignments.Where(a => existingCoachIds.Contains(a.CoachId)).ToList();
                    Db.CoachMeetAssignments.RemoveRange(relatedCoachMeets);
                    Db.Coaches.RemoveRange(existingCoaches);
                }

                // Remove overlapping team levels (and their athlete items, assignments)
                if (preview.OverlapLevels.Any())
                {
                    var existingLevels = Db.TeamLevels.Where(t => t.SeasonId == targetSeasonId && preview.OverlapLevels.Contains(t.Name)).ToList();
                    var existingLevelIds = existingLevels.Select(t => t.Id).ToList();
                    var relatedAthleteItems = Db.AthleteItems.Where(a => existingLevelIds.Contains(a.TeamLevelId)).ToList();
                    Db.AthleteItems.RemoveRange(relatedAthleteItems);
                    var relatedGroupAssigns = Db.TeamLevelGroupAssignments.Where(a => existingLevelIds.Contains(a.TeamLevelId)).ToList();
                    Db.TeamLevelGroupAssignments.RemoveRange(relatedGroupAssigns);
                    var relatedMeetAssigns = Db.MeetTeamLevelAssignments.Where(a => existingLevelIds.Contains(a.TeamLevelId)).ToList();
                    Db.MeetTeamLevelAssignments.RemoveRange(relatedMeetAssigns);
                    Db.TeamLevels.RemoveRange(existingLevels);
                }

                await Db.SaveChangesAsync();
            }

            // 1. Copy coaches
            var coachMap = new Dictionary<int, int>();
            foreach (var c in srcCoaches)
            {
                var newCoach = new Coach { Name = c.Name, Role = c.Role, IsActive = c.IsActive, SeasonId = targetSeasonId };
                Db.Coaches.Add(newCoach);
                await Db.SaveChangesAsync();
                coachMap[c.Id] = newCoach.Id;
            }

            // 2. Copy meets
            var meetMap = new Dictionary<int, int>();
            foreach (var m in srcMeets)
            {
                var newMeet = new Meet { Name = m.Name, Date = m.Date, TravelType = m.TravelType, SeasonId = targetSeasonId };
                Db.Meets.Add(newMeet);
                await Db.SaveChangesAsync();
                meetMap[m.Id] = newMeet.Id;
            }

            // 3. Copy team levels + athlete items
            foreach (var level in srcLevels)
            {
                var newLevel = new TeamLevel { Name = level.Name, AthleteCount = level.AthleteCount, PaymentPlanMonths = level.PaymentPlanMonths, SeasonId = targetSeasonId };
                Db.TeamLevels.Add(newLevel);
                await Db.SaveChangesAsync();
                foreach (var item in srcAthleteItems.Where(a => a.TeamLevelId == level.Id))
                {
                    Db.AthleteItems.Add(new AthleteItem { Name = item.Name, Cost = item.Cost, IsRequired = item.IsRequired, TeamLevelId = newLevel.Id });
                }
                await Db.SaveChangesAsync();
            }

            // 4. Copy budget line items (remap MeetId and CoachId)
            foreach (var item in srcItems)
            {
                Db.BudgetLineItems.Add(new BudgetLineItem
                {
                    Category = item.Category,
                    EntryFeeType = item.EntryFeeType,
                    IsActual = item.IsActual,
                    Rate = item.Rate,
                    Quantity = item.Quantity,
                    Notes = item.Notes,
                    SeasonId = targetSeasonId,
                    MeetId = item.MeetId.HasValue && meetMap.TryGetValue(item.MeetId.Value, out var newMeetId) ? newMeetId : null,
                    CoachId = item.CoachId.HasValue && coachMap.TryGetValue(item.CoachId.Value, out var newCoachId) ? newCoachId : null
                });
            }
            await Db.SaveChangesAsync();

            importSuccess = true;
        }
        catch (Exception ex)
        {
            importError = $"Import failed: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }
}
