@page "/emergency-contacts"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<h3 class="mb-3">Emergency Contacts</h3>

@if (loading)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <input type="text" class="form-control" style="max-width: 300px;" placeholder="Search athlete..."
               @bind="searchText" @bind:event="oninput" />
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Athlete</th>
                        <th>Level</th>
                        <th>Emergency Contact</th>
                        <th>Phone</th>
                        <th>Relationship</th>
                        <th>Medical Notes</th>
                        <th>Parent Email</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in filtered)
                    {
                        <tr>
                            <td><strong>@g.Name</strong></td>
                            <td>@(g.Level ?? "")</td>
                            <td>@(g.EmergencyContactName ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(g.EmergencyContactPhone))
                                {
                                    <a href="tel:@g.EmergencyContactPhone">@g.EmergencyContactPhone</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@(g.EmergencyContactRelationship ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(g.MedicalNotes))
                                {
                                    <span class="badge bg-warning text-dark" title="@g.MedicalNotes" style="cursor: help;">Has Notes</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@(g.ParentEmail ?? "—")</td>
                        </tr>
                    }
                    @if (!filtered.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-3">No athletes found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-muted small">
        @filtered.Count(g => !string.IsNullOrEmpty(g.EmergencyContactName)) of @filtered.Count athletes have emergency contacts on file.
    </div>
}

@code {
    private bool loading = true;
    private List<Gymnast> gymnasts = new();
    private string searchText = "";

    private List<Gymnast> filtered => string.IsNullOrWhiteSpace(searchText)
        ? gymnasts
        : gymnasts.Where(g => g.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        gymnasts = await db.Gymnasts.AsNoTracking().OrderBy(g => g.Name).ToListAsync();
        loading = false;
    }
}
