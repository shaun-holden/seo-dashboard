@page "/teamlevels"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState

<h3>@labels.TeamLevels</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
        @if (selectedSeasonId > 0)
        {
            <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="RefreshData" title="Refresh data"><span class="oi oi-reload"></span></button>
        }
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="card mb-4 p-3">
            <h5>Athletes in Season</h5>
            <p class="text-muted small">Check athletes who belong to this season. Changes are saved immediately.</p>
            @if (!allGymnasts.Any())
            {
                <p class="text-muted">No gymnasts found in roster.</p>
            }
            else
            {
                <div class="d-flex align-items-center gap-2 mb-3">
                    <button class="btn btn-sm btn-outline-primary" @onclick="SelectAllGymnasts">Select All</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DeselectAllGymnasts">Deselect All</button>
                    <input class="form-control form-control-sm" style="max-width: 250px;"
                           placeholder="Search by name..."
                           @bind="manageAthletesSearch" @bind:event="oninput" />
                    <span class="text-muted small ms-2">@seasonGymnastIds.Count selected</span>
                </div>
                <div class="row">
                    @foreach (var gymnast in filteredManageAthletes)
                    {
                        var gId = gymnast.Id;
                        var isChecked = seasonGymnastIds.Contains(gId);
                        <div class="col-md-4 col-sm-6 mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="sg-@gId"
                                       checked="@isChecked"
                                       @onchange="e => ToggleGymnastInSeason(gId, (bool)e.Value!)" />
                                <label class="form-check-label" for="sg-@gId">
                                    @gymnast.Name
                                    @if (!string.IsNullOrWhiteSpace(gymnast.Level))
                                    {
                                        <span class="text-muted small">(@gymnast.Level)</span>
                                    }
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<SeasonGroup> seasonGroups = new();
    private List<TeamLevelGroupAssignment> levelGroupAssignments = new();
    private List<Meet> meets = new();
    private List<MeetTeamLevelAssignment> meetLevelAssignments = new();
    private int selectedSeasonId;
    private bool showForm;
    private TeamLevel? editingLevel;
    private string formName = "";
    private int formAthleteCount = 0;
    private int formPaymentMonths = 5;
    private HashSet<int> formGroupIds = new();
    private HashSet<int> formMeetIds = new();
    private string newItemName = "";
    private decimal newItemCost = 0;
    private bool newItemRequired = true;
    private int? editingItemId;
    private string editItemName = "";
    private decimal editItemCost = 0;
    private bool editItemRequired = true;
    private bool editItemAllLevels = false;
    private string editItemOriginalName = "";
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;
    private HashSet<int> expandedLevels = new();

    private void ToggleLevelExpand(int levelId)
    {
        if (!expandedLevels.Remove(levelId))
            expandedLevels.Add(levelId);
    }

    private RenderFragment RenderLevelCard(TeamLevel level) => __builder =>
    {
        var levelGroups = levelGroupAssignments.Where(a => a.TeamLevelId == level.Id).ToList();
        var assignedGroups = seasonGroups.Where(g => levelGroups.Any(a => a.SeasonGroupId == g.Id)).ToList();
        var assignedMeetIds = meetLevelAssignments.Where(a => a.TeamLevelId == level.Id).Select(a => a.MeetId).ToHashSet();
        var assignedMeets = meets.Where(m => assignedMeetIds.Contains(m.Id)).ToList();
        var isExpanded = expandedLevels.Contains(level.Id);
        var levelItems = athleteItems.Where(i => i.TeamLevelId == level.Id).ToList();

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleLevelExpand(level.Id)" style="cursor: pointer;">
                <div>
                    <h5 class="mb-0 d-inline">@level.Name</h5>
                    @if (assignedGroups.Any())
                    {
                        <span class="badge bg-success ms-2">@assignedGroups.Count group(s)</span>
                    }
                    @if (assignedMeets.Any())
                    {
                        <span class="badge bg-info ms-2">@assignedMeets.Count @labels.Meets</span>
                    }
                    <span class="badge bg-secondary ms-2">@levelItems.Count @labels.AthleteItems — $@levelItems.Sum(i => i.Cost).ToString("N2")</span>
                </div>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditLevel(level)" @onclick:stopPropagation="true">Edit</button>
                    <button class="btn btn-sm btn-outline-danger me-2" @onclick="() => DeleteLevel(level)" @onclick:stopPropagation="true">Delete</button>
                    <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                </div>
            </div>
            @if (isExpanded)
            {
            <div class="card-body">
                @if (assignedMeets.Any())
                {
                    <h6>@labels.Meets</h6>
                    <table class="table table-sm mb-3">
                        <thead><tr><th>@labels.Meet</th><th>Date</th><th>Budget</th></tr></thead>
                        <tbody>
                            @foreach (var m in assignedMeets)
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.Date.ToString("MMM dd, yyyy")</td>
                                    <td>$@m.BudgetAmount.ToString("N2")</td>
                                </tr>
                            }
                            <tr class="fw-bold">
                                <td colspan="2">Total @labels.Meets Budget</td>
                                <td>$@assignedMeets.Sum(m => m.BudgetAmount).ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                }
                <h6>@labels.AthleteItems</h6>
                <table class="table table-sm">
                    <thead><tr><th>Item</th><th>Cost</th><th>Required</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var item in levelItems)
                        {
                            var itemId = item.Id;
                            @if (editingItemId == itemId)
                            {
                                <tr class="@(editItemAllLevels ? "table-info" : "")">
                                    <td><input class="form-control form-control-sm" @bind="editItemName" /></td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="editItemCost" /></td>
                                    <td><input type="checkbox" @bind="editItemRequired" /> Yes</td>
                                    <td>
                                        <button class="btn btn-sm btn-success me-1" @onclick="SaveEditItem">
                                            @(editItemAllLevels ? "Save All" : "Save")
                                        </button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditItem">Cancel</button>
                                    </td>
                                </tr>
                                @if (editItemAllLevels)
                                {
                                    <tr class="table-info"><td colspan="4"><small class="text-info">Editing "@editItemOriginalName" across all @labels.TeamLevels.ToLower()</small></td></tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>$@item.Cost.ToString("N2")</td>
                                    <td>@(item.IsRequired ? "Yes" : "No")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditItem(item)">Edit</button>
                                        <button class="btn btn-sm btn-outline-info me-1" @onclick="() => StartEditItemAllLevels(item)">Edit All</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAthleteItem(item)">Remove</button>
                                    </td>
                                </tr>
                            }
                        }
                        <tr class="fw-bold">
                            <td>Total @labels.AthleteItems</td>
                            <td>$@levelItems.Sum(i => i.Cost).ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                    </tbody>
                </table>
                <div class="row mt-2">
                    <div class="col-md-4">
                        <input class="form-control" placeholder="Item name" @bind="newItemName" />
                    </div>
                    <div class="col-md-3">
                        <input type="number" step="0.01" class="form-control" placeholder="Cost" @bind="newItemCost" />
                    </div>
                    <div class="col-md-2">
                        <input type="checkbox" @bind="newItemRequired" /> Required
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-sm btn-success" @onclick="() => AddAthleteItem(level.Id)">+ Add @labels.AthleteItem</button>
                    </div>
                </div>
            </div>
            }
        </div>
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Task.FromResult(Db.Seasons.OrderByDescending(s => s.IsActive).ThenByDescending(s => s.Name).ToList());
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadData();
    }

    private async Task RefreshData() => await LoadData();

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasonGroups = await db.SeasonGroups.AsNoTracking().Where(g => g.SeasonId == selectedSeasonId).OrderBy(g => g.SortOrder).ToListAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var levelIds = teamLevels.Select(t => t.Id).ToList();
        levelGroupAssignments = await db.TeamLevelGroupAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();

        // Auto-create a team level for each season group that doesn't have one
        var groupsWithLevels = levelGroupAssignments.Select(a => a.SeasonGroupId).ToHashSet();
        var groupsNeedingLevels = seasonGroups.Where(g => !groupsWithLevels.Contains(g.Id)).ToList();
        if (groupsNeedingLevels.Any())
        {
            using var writeDb = await DbFactory.CreateDbContextAsync();
            foreach (var group in groupsNeedingLevels)
            {
                var newLevel = new TeamLevel { Name = group.Name, SeasonId = selectedSeasonId };
                writeDb.TeamLevels.Add(newLevel);
                await writeDb.SaveChangesAsync();
                writeDb.TeamLevelGroupAssignments.Add(new TeamLevelGroupAssignment { TeamLevelId = newLevel.Id, SeasonGroupId = group.Id });
            }
            await writeDb.SaveChangesAsync();
            // Reload with fresh context
            using var db2 = await DbFactory.CreateDbContextAsync();
            teamLevels = await db2.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
            levelIds = teamLevels.Select(t => t.Id).ToList();
            levelGroupAssignments = await db2.TeamLevelGroupAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        }

        athleteItems = await db.AthleteItems.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        meets = await db.Meets.AsNoTracking().Where(m => m.SeasonId == selectedSeasonId).OrderBy(m => m.Date).ToListAsync();
        meetLevelAssignments = await db.MeetTeamLevelAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();

        // Load athletes for season management
        allGymnasts = await db.Gymnasts.AsNoTracking()
            .Where(g => !g.IsArchived)
            .OrderBy(g => g.Name)
            .ToListAsync();
        seasonGymnastIds = (await db.SeasonGymnasts.AsNoTracking()
            .Where(sg => sg.SeasonId == selectedSeasonId)
            .Select(sg => sg.GymnastId)
            .ToListAsync())
            .ToHashSet();

        StateHasChanged();
    }

    private void ToggleFormGroup(int groupId, bool isChecked)
    {
        if (isChecked) formGroupIds.Add(groupId);
        else formGroupIds.Remove(groupId);
    }

    private void ToggleFormMeet(int meetId, bool isChecked)
    {
        if (isChecked) formMeetIds.Add(meetId);
        else formMeetIds.Remove(meetId);
    }

    private void ShowForm() { editingLevel = null; formName = ""; formAthleteCount = 0; formPaymentMonths = 5; formGroupIds.Clear(); formMeetIds.Clear(); showForm = true; }
    private void CancelForm() { showForm = false; }

    private void EditLevel(TeamLevel level)
    {
        editingLevel = level; formName = level.Name; formAthleteCount = level.AthleteCount; formPaymentMonths = level.PaymentPlanMonths;
        formGroupIds = levelGroupAssignments.Where(a => a.TeamLevelId == level.Id).Select(a => a.SeasonGroupId).ToHashSet();
        formMeetIds = meetLevelAssignments.Where(a => a.TeamLevelId == level.Id).Select(a => a.MeetId).ToHashSet();
        showForm = true;
    }

    private async Task SaveLevel()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        TeamLevel level;
        if (editingLevel == null)
        {
            level = new TeamLevel { Name = formName, AthleteCount = formAthleteCount, PaymentPlanMonths = formPaymentMonths, SeasonId = selectedSeasonId };
            db.TeamLevels.Add(level);
            await db.SaveChangesAsync();
        }
        else
        {
            level = await db.TeamLevels.FindAsync(editingLevel.Id) ?? new TeamLevel { Id = editingLevel.Id };
            level.Name = formName;
            level.AthleteCount = formAthleteCount;
            level.PaymentPlanMonths = formPaymentMonths;
            var existing = db.TeamLevelGroupAssignments.Where(a => a.TeamLevelId == level.Id).ToList();
            db.TeamLevelGroupAssignments.RemoveRange(existing);
            await db.SaveChangesAsync();
        }
        foreach (var gId in formGroupIds)
        {
            if (!db.TeamLevelGroupAssignments.Any(a => a.TeamLevelId == level.Id && a.SeasonGroupId == gId))
                db.TeamLevelGroupAssignments.Add(new TeamLevelGroupAssignment { TeamLevelId = level.Id, SeasonGroupId = gId });
        }
        var existingMeets = db.MeetTeamLevelAssignments.Where(a => a.TeamLevelId == level.Id).ToList();
        db.MeetTeamLevelAssignments.RemoveRange(existingMeets);
        foreach (var mId in formMeetIds)
        {
            db.MeetTeamLevelAssignments.Add(new MeetTeamLevelAssignment { TeamLevelId = level.Id, MeetId = mId });
        }
        await db.SaveChangesAsync();

        // Auto-sync gymnasts to this season based on matching level names
        await SyncSeasonGymnasts(db, selectedSeasonId);

        await LoadData();
        showForm = false;
    }

    private async Task DeleteLevel(TeamLevel level)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.TeamLevels.FindAsync(level.Id);
        if (entity != null) { db.TeamLevels.Remove(entity); await db.SaveChangesAsync(); }
        await LoadData();
    }

    private async Task AddAthleteItem(int levelId)
    {
        if (string.IsNullOrWhiteSpace(newItemName)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.AthleteItems.Add(new AthleteItem { Name = newItemName, Cost = newItemCost, IsRequired = newItemRequired, TeamLevelId = levelId });
        await db.SaveChangesAsync();
        newItemName = ""; newItemCost = 0; newItemRequired = true;
        await LoadData();
    }

    private void StartEditItem(AthleteItem item)
    {
        editingItemId = item.Id;
        editItemName = item.Name;
        editItemCost = item.Cost;
        editItemRequired = item.IsRequired;
        editItemAllLevels = false;
        editItemOriginalName = item.Name;
    }

    private void StartEditItemAllLevels(AthleteItem item)
    {
        editingItemId = item.Id;
        editItemName = item.Name;
        editItemCost = item.Cost;
        editItemRequired = item.IsRequired;
        editItemAllLevels = true;
        editItemOriginalName = item.Name;
    }

    private void CancelEditItem() { editingItemId = null; editItemAllLevels = false; }

    private async Task SaveEditItem()
    {
        if (editingItemId == null || string.IsNullOrWhiteSpace(editItemName)) return;
        using var db = await DbFactory.CreateDbContextAsync();

        if (editItemAllLevels)
        {
            // Update all items with the same original name across all levels in this season
            var levelIds = teamLevels.Select(t => t.Id).ToList();
            var matchingItems = await db.AthleteItems
                .Where(a => levelIds.Contains(a.TeamLevelId) && a.Name == editItemOriginalName)
                .ToListAsync();
            foreach (var item in matchingItems)
            {
                item.Name = editItemName;
                item.Cost = editItemCost;
                item.IsRequired = editItemRequired;
            }
        }
        else
        {
            var entity = await db.AthleteItems.FindAsync(editingItemId.Value);
            if (entity != null)
            {
                entity.Name = editItemName;
                entity.Cost = editItemCost;
                entity.IsRequired = editItemRequired;
            }
        }

        await db.SaveChangesAsync();
        editingItemId = null;
        editItemAllLevels = false;
        await LoadData();
    }

    private async Task DeleteAthleteItem(AthleteItem item)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.AthleteItems.FindAsync(item.Id);
        if (entity != null) { db.AthleteItems.Remove(entity); await db.SaveChangesAsync(); }
        await LoadData();
    }


    // --- Manage Athletes (SeasonGymnast) ---
    private List<Gymnast> allGymnasts = new();
    private HashSet<int> seasonGymnastIds = new();
    private string manageAthletesSearch = "";
    private List<Gymnast> filteredManageAthletes => string.IsNullOrWhiteSpace(manageAthletesSearch)
        ? allGymnasts
        : allGymnasts.Where(g => g.Name.Contains(manageAthletesSearch, StringComparison.OrdinalIgnoreCase)).ToList();

    private async Task ToggleGymnastInSeason(int gymnastId, bool isChecked)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        if (isChecked)
        {
            if (!await db.SeasonGymnasts.AnyAsync(sg => sg.SeasonId == selectedSeasonId && sg.GymnastId == gymnastId))
            {
                db.SeasonGymnasts.Add(new SeasonGymnast { SeasonId = selectedSeasonId, GymnastId = gymnastId });
                await db.SaveChangesAsync();
            }
            seasonGymnastIds.Add(gymnastId);
        }
        else
        {
            var existing = await db.SeasonGymnasts
                .FirstOrDefaultAsync(sg => sg.SeasonId == selectedSeasonId && sg.GymnastId == gymnastId);
            if (existing != null)
            {
                db.SeasonGymnasts.Remove(existing);
                await db.SaveChangesAsync();
            }
            seasonGymnastIds.Remove(gymnastId);
        }
    }

    private async Task SelectAllGymnasts()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var toAdd = allGymnasts
            .Where(g => !seasonGymnastIds.Contains(g.Id))
            .Select(g => new SeasonGymnast { SeasonId = selectedSeasonId, GymnastId = g.Id })
            .ToList();
        if (toAdd.Any())
        {
            db.SeasonGymnasts.AddRange(toAdd);
            await db.SaveChangesAsync();
        }
        seasonGymnastIds = allGymnasts.Select(g => g.Id).ToHashSet();
    }

    private async Task DeselectAllGymnasts()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var toRemove = await db.SeasonGymnasts
            .Where(sg => sg.SeasonId == selectedSeasonId)
            .ToListAsync();
        if (toRemove.Any())
        {
            db.SeasonGymnasts.RemoveRange(toRemove);
            await db.SaveChangesAsync();
        }
        seasonGymnastIds.Clear();
    }

    private async Task SyncSeasonGymnasts(AppDbContext db, int seasonId)
    {
        if (string.IsNullOrEmpty(userId) || seasonId == 0) return;

        var seasonTeamLevels = await db.TeamLevels.AsNoTracking()
            .Where(tl => tl.SeasonId == seasonId)
            .ToListAsync();
        var gymnasts = await db.Gymnasts.AsNoTracking()
            .Where(g => !g.IsArchived && g.Level != null)
            .ToListAsync();
        var existing = await db.SeasonGymnasts
            .Where(sg => sg.SeasonId == seasonId)
            .ToListAsync();

        var matchingGymnastIds = gymnasts
            .Where(g => seasonTeamLevels.Any(tl =>
                string.Equals(tl.Name, g.Level, StringComparison.OrdinalIgnoreCase)))
            .Select(g => g.Id)
            .ToHashSet();

        // Add missing assignments
        foreach (var gId in matchingGymnastIds)
        {
            if (!existing.Any(e => e.GymnastId == gId))
                db.SeasonGymnasts.Add(new SeasonGymnast { SeasonId = seasonId, GymnastId = gId });
        }

        await db.SaveChangesAsync();
    }
}
