@page "/budget"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState

<h3>Budget</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" @onclick="ExpandAll">
                    <span class="oi oi-fullscreen-enter me-1"></span> Expand All
                </button>
                <button class="btn btn-outline-secondary" @onclick="CollapseAll">
                    <span class="oi oi-fullscreen-exit me-1"></span> Collapse All
                </button>
            </div>
            @if (teamLevels.Count > 1)
            {
                <select class="form-select" style="max-width: 200px;" value="@filterLevelId"
                        @onchange="OnFilterLevelChanged">
                    <option value="0">All @labels.TeamLevels</option>
                    @foreach (var level in teamLevels)
                    {
                        <option value="@level.Id">@level.Name</option>
                    }
                </select>
            }
            @if (seasonGroups.Any())
            {
                <select class="form-select" style="max-width: 200px;" value="@filterGroupId"
                        @onchange="OnFilterGroupChanged">
                    <option value="0">All Groups</option>
                    @foreach (var g in seasonGroups)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            }
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6>Total Budget</h6>
                        <h4>$@budgetTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6>Total Shared Fees</h6>
                        <h4>$@sharedFeesTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            @if (calculatorTotal > 0)
            {
                <div class="col-md-3">
                    <div class="card text-white bg-info">
                        <div class="card-body">
                            <h6>Calculator Total</h6>
                            <h4>$@calculatorTotal.ToString("N2")</h4>
                            <small><a href="/budget-calculator" class="text-white">Edit Calculator</a></small>
                        </div>
                    </div>
                </div>
            }
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6>Cost Per Gymnast</h6>
                        @if (totalAthletes > 0)
                        {
                            <h4>$@avgCostPerAthlete.ToString("N2")</h4>
                            <small>@totalAthletes athlete(s)</small>
                        }
                        else
                        {
                            <h4 class="text-white-50">--</h4>
                            <small>Set athlete counts</small>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (sharedFees.Any())
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning bg-opacity-25 d-flex justify-content-between align-items-center"
                     @onclick="() => showBudgetSharedFees = !showBudgetSharedFees" style="cursor: pointer;">
                    <div>
                        <h5 class="mb-0 d-inline">Shared Fees</h5>
                        <span class="badge bg-warning text-dark ms-2">@sharedFees.Count fee(s)</span>
                    </div>
                    <div>
                        <span class="fw-bold me-2">$@sharedFeesTotal.ToString("N2")</span>
                        <span class="oi @(showBudgetSharedFees ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                    </div>
                </div>
                @if (showBudgetSharedFees)
                {
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Category</th><th>Name</th><th>Total</th><th>Per Athlete</th><th>Shared Across</th></tr></thead>
                        <tbody>
                            @foreach (var fee in sharedFees)
                            {
                                var assignedLevelIds = sharedFeeAssignments.Where(a => a.SharedFeeId == fee.Id).Select(a => a.TeamLevelId).ToList();
                                var assignedLevels = assignedLevelIds.Any() ? teamLevels.Where(t => assignedLevelIds.Contains(t.Id)).ToList() : teamLevels;
                                var totalAssignedAthletes = assignedLevels.Sum(t => t.AthleteCount);
                                var perAthlete = totalAssignedAthletes > 0 ? fee.Amount / totalAssignedAthletes : fee.Amount;
                                var assignedNames = assignedLevels.Select(t => t.Name);
                                <tr>
                                    <td>@fee.DisplayName</td>
                                    <td>@fee.Name</td>
                                    <td>$@fee.Amount.ToString("N2")</td>
                                    <td class="fw-bold text-primary">$@perAthlete.ToString("N2") <small class="text-muted fw-normal">(@totalAssignedAthletes athletes)</small></td>
                                    <td><small class="text-muted">@(assignedLevelIds.Any() ? string.Join(", ", assignedNames) : "All")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                }
            </div>
        }

        @if (calculatorCategories.Any())
        {
            <div class="card mb-4 border-info">
                <div class="card-header bg-info bg-opacity-25 d-flex justify-content-between align-items-center"
                     @onclick="() => showCalculatorBreakdown = !showCalculatorBreakdown" style="cursor: pointer;">
                    <div>
                        <h5 class="mb-0 d-inline">Budget Breakdown</h5>
                        <span class="badge bg-info text-dark ms-2">@calculatorCategories.Count categories</span>
                    </div>
                    <div>
                        <span class="fw-bold me-2">$@calculatorTotal.ToString("N2")</span>
                        <span class="oi @(showCalculatorBreakdown ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                    </div>
                </div>
                @if (showCalculatorBreakdown)
                {
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Category</th><th class="text-end">Total</th><th class="text-end">Per Gymnast</th></tr></thead>
                        <tbody>
                            @foreach (var cat in calculatorCategories)
                            {
                                var perGymnast = totalAthletes > 0 ? cat.Total / totalAthletes : 0;
                                <tr>
                                    <td>@cat.Label</td>
                                    <td class="text-end">$@cat.Total.ToString("N2")</td>
                                    <td class="text-end fw-bold text-primary">$@perGymnast.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td>Total Budget</td>
                                <td class="text-end">$@calculatorTotal.ToString("N2")</td>
                                <td class="text-end text-primary">$@avgCostPerAthlete.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="p-2 text-end">
                        <a href="/budget-calculator" class="btn btn-sm btn-outline-info">Edit in Calculator</a>
                    </div>
                </div>
                }
            </div>
        }

        @* Per-level budget breakdown *@
        @if (seasonGroups.Any())
        {
            var allGroupedLevelIds = levelGroupAssignments.Select(a => a.TeamLevelId).ToHashSet();

            @foreach (var group in seasonGroups)
            {
                var groupLevelIds = levelGroupAssignments.Where(a => a.SeasonGroupId == group.Id).Select(a => a.TeamLevelId).ToHashSet();
                var groupLevels = filteredTeamLevels.Where(t => groupLevelIds.Contains(t.Id)).ToList();
                if (groupLevels.Any())
                {
                    @if (groupLevels.Count == 1 && string.Equals(groupLevels[0].Name?.Trim(), group.Name?.Trim(), StringComparison.OrdinalIgnoreCase))
                    {
                        @RenderLevelBudget(groupLevels[0])
                    }
                    else
                    {
                        var groupTotal = groupLevels.Sum(l => GetLevelTotal(l.Id));
                        var gId = group.Id;
                        var groupExpanded = expandedGroups.Contains(gId);
                        <div class="card mb-4 border-primary">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center"
                                 @onclick="() => ToggleGroup(gId)" style="cursor: pointer;">
                                <div>
                                    <h5 class="mb-0 d-inline">@group.Name</h5>
                                    <span class="badge bg-primary ms-2">@groupLevels.Count @labels.TeamLevels</span>
                                </div>
                                <div>
                                    <span class="fw-bold me-2">$@groupTotal.ToString("N2")</span>
                                    <span class="oi @(groupExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                                </div>
                            </div>
                            @if (groupExpanded)
                            {
                            <div class="card-body">
                                @foreach (var level in groupLevels)
                                {
                                    @RenderLevelBudget(level)
                                }
                            </div>
                            }
                        </div>
                    }
                }
            }
        }
        else
        {
            @foreach (var level in filteredTeamLevels)
            {
                @RenderLevelBudget(level)
            }
        }

        <div class="fw-bold mt-2 p-2 bg-light rounded">
            Grand Total: $@budgetTotal.ToString("N2")
        </div>
    }
}

@implements IDisposable

@code {
    private List<Season>? seasons;
    private List<SeasonGroup> seasonGroups = new();
    private List<SharedFee> sharedFees = new();
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<TeamLevelGroupAssignment> levelGroupAssignments = new();
    private List<SharedFeeTeamLevelAssignment> sharedFeeAssignments = new();
    private int selectedSeasonId;
    private Season? selectedSeason;
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;
    private System.Threading.Timer? _refreshTimer;

    private Dictionary<int, int> scenarioAthletes = new();
    private int filterLevelId = 0;
    private int filterGroupId = 0;
    private bool showBudgetSharedFees = true;
    private HashSet<int> expandedGroups = new();
    private HashSet<int> expandedLevels = new();

    private void ToggleGroup(int groupId)
    {
        if (!expandedGroups.Remove(groupId))
            expandedGroups.Add(groupId);
    }

    private void ToggleLevel(int levelId)
    {
        if (!expandedLevels.Remove(levelId))
            expandedLevels.Add(levelId);
    }

    private void ExpandAll()
    {
        showBudgetSharedFees = true;
        expandedGroups = seasonGroups.Select(g => g.Id).ToHashSet();
        expandedLevels = teamLevels.Select(t => t.Id).ToHashSet();
    }

    private void CollapseAll()
    {
        showBudgetSharedFees = false;
        expandedGroups.Clear();
        expandedLevels.Clear();
    }

    private List<TeamLevel> filteredTeamLevels
    {
        get
        {
            var result = teamLevels.AsEnumerable();
            if (filterLevelId > 0)
                result = result.Where(t => t.Id == filterLevelId);
            if (filterGroupId > 0)
            {
                var groupLevelIds = levelGroupAssignments
                    .Where(a => a.SeasonGroupId == filterGroupId)
                    .Select(a => a.TeamLevelId)
                    .ToHashSet();
                result = result.Where(t => groupLevelIds.Contains(t.Id));
            }
            return result.ToList();
        }
    }

    private decimal sharedFeesTotal => sharedFees.Where(f => f.IsIncludedInBudget).Sum(f => f.Amount);
    private decimal athleteItemsTotal => athleteItems.Sum(a => a.Cost);
    private decimal calculatorTotal;
    private bool showCalculatorBreakdown = true;
    private List<CalcCategory> calculatorCategories = new();
    private record CalcCategory(string Label, decimal Total);
    private decimal budgetTotal => calculatorTotal > 0 ? calculatorTotal : (sharedFeesTotal + athleteItemsTotal);
    private int totalAthletes => selectedSeason?.AthleteCount ?? 0;
    private decimal avgCostPerAthlete => totalAthletes > 0 ? budgetTotal / totalAthletes : 0;

    private decimal GetSharedFeeShareForLevel(int teamLevelId, Dictionary<int, int>? athleteOverrides = null)
    {
        decimal total = 0;
        var level = teamLevels.FirstOrDefault(t => t.Id == teamLevelId);
        if (level == null) return 0;
        int levelAthletes = athleteOverrides != null && athleteOverrides.ContainsKey(teamLevelId) ? athleteOverrides[teamLevelId] : level.AthleteCount;
        foreach (var fee in sharedFees.Where(f => f.IsIncludedInBudget))
        {
            var assignedLevelIds = sharedFeeAssignments.Where(a => a.SharedFeeId == fee.Id).Select(a => a.TeamLevelId).ToList();
            if (assignedLevelIds.Count == 0)
                assignedLevelIds = teamLevels.Select(t => t.Id).ToList();
            if (!assignedLevelIds.Contains(teamLevelId)) continue;
            var totalAssignedAthletes = teamLevels.Where(t => assignedLevelIds.Contains(t.Id))
                .Sum(t => athleteOverrides != null && athleteOverrides.ContainsKey(t.Id) ? athleteOverrides[t.Id] : t.AthleteCount);
            if (totalAssignedAthletes > 0)
                total += Math.Round(fee.Amount * levelAthletes / totalAssignedAthletes, 2);
            else
                total += Math.Round(fee.Amount / assignedLevelIds.Count, 2);
        }
        return total;
    }

    private decimal GetLevelTotal(int teamLevelId)
    {
        var feeShare = GetSharedFeeShareForLevel(teamLevelId);
        var itemsTotal = athleteItems.Where(a => a.TeamLevelId == teamLevelId).Sum(a => a.Cost);
        return feeShare + itemsTotal;
    }

    private RenderFragment RenderLevelBudget(TeamLevel level) => __builder =>
    {
        var feeShare = GetSharedFeeShareForLevel(level.Id);
        var items = athleteItems.Where(a => a.TeamLevelId == level.Id).ToList();
        var itemsTotal = items.Sum(a => a.Cost);
        var levelTotal = feeShare + itemsTotal;
        var costPerAthlete = level.AthleteCount > 0 ? levelTotal / level.AthleteCount : 0;
        var monthly = level.PaymentPlanMonths > 0 ? costPerAthlete / level.PaymentPlanMonths : 0;
        var hasScenario = scenarioAthletes.ContainsKey(level.Id);
        var scenarioCount = hasScenario ? scenarioAthletes[level.Id] : -1;
        var scenarioOverrides = new Dictionary<int, int>(scenarioAthletes);
        var scenarioFeeShare = hasScenario ? GetSharedFeeShareForLevel(level.Id, scenarioOverrides) : 0;
        var scenarioLevelTotal = scenarioFeeShare + (scenarioCount > 0 ? itemsTotal : 0);
        var scenarioCost = scenarioCount > 0 ? scenarioLevelTotal / scenarioCount : 0;
        var scenarioMonthly = scenarioCount > 0 && level.PaymentPlanMonths > 0 ? scenarioCost / level.PaymentPlanMonths : 0;

        var levelExpanded = expandedLevels.Contains(level.Id);

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleLevel(level.Id)" style="cursor: pointer;">
                <div>
                    <strong>@level.Name</strong>
                    <small class="text-muted ms-2">@level.AthleteCount athletes | @level.PaymentPlanMonths mo plan</small>
                </div>
                <div>
                    <span class="fw-bold me-2">$@levelTotal.ToString("N2")</span>
                    <span class="oi @(levelExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                </div>
            </div>
            @if (levelExpanded)
            {
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr class="table-warning">
                            <td><strong>Shared Fee Share</strong></td>
                            <td class="text-end"><strong>$@feeShare.ToString("N2")</strong></td>
                        </tr>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td>@item.Name @(item.IsRequired ? "" : "(optional)")</td>
                                <td class="text-end">$@item.Cost.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold"><td>Level Total</td><td class="text-end">$@levelTotal.ToString("N2")</td></tr>
                        @if (level.AthleteCount > 0)
                        {
                            <tr class="text-primary fw-bold"><td>Cost Per Athlete (@level.AthleteCount)</td><td class="text-end">$@costPerAthlete.ToString("N2")</td></tr>
                            @if (level.PaymentPlanMonths > 0)
                            {
                                <tr class="text-success fw-bold"><td>Payment Plan (@level.PaymentPlanMonths mo)</td><td class="text-end">$@monthly.ToString("N2")/month</td></tr>
                            }
                        }
                        else
                        {
                            <tr class="text-muted"><td>Cost Per Athlete</td><td class="text-end"><em>Set athlete count in @labels.TeamLevels</em></td></tr>
                        }
                    </tfoot>
                </table>
                <div class="p-2 bg-light border-top">
                    <div class="d-flex align-items-center gap-2">
                        <small class="fw-bold text-muted">What if only</small>
                        <input type="number" min="0" class="form-control form-control-sm" style="width: 70px;"
                               value="@(hasScenario ? scenarioCount : "")"
                               @onchange="(e) => UpdateScenario(level.Id, e)" />
                        <small class="fw-bold text-muted">gymnast(s) qualify?</small>
                        @if (hasScenario && scenarioCount == 0)
                        {
                            <span class="ms-auto">
                                <span class="badge bg-danger">$0.00 — fees shift to other levels</span>
                            </span>
                        }
                        else if (scenarioCount > 0)
                        {
                            <span class="ms-auto">
                                <span class="badge bg-primary">$@scenarioCost.ToString("N2")/athlete</span>
                                @if (level.PaymentPlanMonths > 0)
                                {
                                    <span class="badge bg-success ms-1">$@scenarioMonthly.ToString("N2")/mo</span>
                                }
                            </span>
                        }
                    </div>
                </div>
            </div>
            }
        </div>
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Db.Seasons.Where(s => s.IsActive).OrderByDescending(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        selectedSeason = seasons?.FirstOrDefault(s => s.Id == selectedSeasonId);
        labels = new ProjectLabels(selectedSeason);
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadData();
        _refreshTimer?.Dispose();
        if (selectedSeasonId > 0)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () => { await LoadData(); });
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasonGroups = await db.SeasonGroups.AsNoTracking().Where(g => g.SeasonId == selectedSeasonId).OrderBy(g => g.SortOrder).ToListAsync();
        sharedFees = await db.SharedFees.AsNoTracking().Where(f => f.SeasonId == selectedSeasonId).ToListAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var levelIds = teamLevels.Select(t => t.Id).ToList();
        athleteItems = await db.AthleteItems.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        levelGroupAssignments = await db.TeamLevelGroupAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        var sharedFeeIds = sharedFees.Select(f => f.Id).ToList();
        sharedFeeAssignments = await db.SharedFeeTeamLevelAssignments.AsNoTracking().Where(a => sharedFeeIds.Contains(a.SharedFeeId)).ToListAsync();

        // Load calculator totals by category
        var calcEntries = await db.BudgetCalculatorEntries.AsNoTracking()
            .Where(e => e.SeasonId == selectedSeasonId)
            .ToListAsync();
        calculatorTotal = calcEntries.Sum(e => e.CalculatedTotal);
        calculatorCategories = calcEntries
            .GroupBy(e => e.Category)
            .Where(g => g.Sum(e => e.CalculatedTotal) != 0)
            .Select(g => new CalcCategory(GetCalcLabel(g.Key), g.Sum(e => e.CalculatedTotal)))
            .OrderByDescending(c => c.Total)
            .ToList();

        StateHasChanged();
    }

    private string GetCalcLabel(string category) => category switch
    {
        "TeamEntry" => "Team Entry",
        "SessionCost" => "Session Cost",
        "CarRental" => "Car Rental",
        "BankFees" => "Bank / Processing Fees",
        _ => category
    };

    private void OnFilterLevelChanged(ChangeEventArgs e) { filterLevelId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; }
    private void OnFilterGroupChanged(ChangeEventArgs e) { filterGroupId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; }

    private void UpdateScenario(int levelId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var count) && count >= 0)
            scenarioAthletes[levelId] = count;
        else
            scenarioAthletes.Remove(levelId);
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
