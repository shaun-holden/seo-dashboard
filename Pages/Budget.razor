@page "/budget"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState

<h3>Budget</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6>Total Budget</h6>
                        <h4>$@budgetTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6>Total Shared Fees</h6>
                        <h4>$@sharedFeesTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6>Total @labels.AthleteItems</h6>
                        <h4>$@athleteItemsTotal.ToString("N2")</h4>
                    </div>
                </div>
            </div>
        </div>

        @if (sharedFees.Any())
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning bg-opacity-25 d-flex justify-content-between">
                    <h5 class="mb-0">Shared Fees</h5>
                    <span class="fw-bold">$@sharedFeesTotal.ToString("N2")</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Category</th><th>Name</th><th>Amount</th></tr></thead>
                        <tbody>
                            @foreach (var fee in sharedFees)
                            {
                                <tr>
                                    <td>@fee.DisplayName</td>
                                    <td>@fee.Name</td>
                                    <td>$@fee.Amount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @foreach (var group in seasonGroups)
        {
            var groupLevelIds = levelGroupAssignments.Where(a => a.SeasonGroupId == group.Id).Select(a => a.TeamLevelId).ToHashSet();
            var groupLevels = teamLevels.Where(t => groupLevelIds.Contains(t.Id)).ToList();
            var groupAthleteItems = athleteItems.Where(a => groupLevelIds.Contains(a.TeamLevelId)).ToList();
            @if (groupLevels.Any())
            {
                <div class="card mb-3 border-primary">
                    <div class="card-header bg-light d-flex justify-content-between">
                        <h5 class="mb-0">@group.Name</h5>
                        <span class="fw-bold">$@groupAthleteItems.Sum(a => a.Cost).ToString("N2")</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>@labels.TeamLevel</th><th>@labels.AthleteItem</th><th>Cost</th><th>Required</th></tr></thead>
                            <tbody>
                                @foreach (var level in groupLevels)
                                {
                                    var items = athleteItems.Where(a => a.TeamLevelId == level.Id).ToList();
                                    @if (items.Any())
                                    {
                                        @foreach (var item in items)
                                        {
                                            <tr>
                                                <td>@level.Name</td>
                                                <td>@item.Name</td>
                                                <td>$@item.Cost.ToString("N2")</td>
                                                <td>@(item.IsRequired ? "Yes" : "No")</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td>@level.Name</td><td colspan="3" class="text-muted fst-italic">No items</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        var ungroupedLevelIds = teamLevels.Select(t => t.Id).Except(levelGroupAssignments.Select(a => a.TeamLevelId)).ToList();
        var ungroupedLevels = teamLevels.Where(t => ungroupedLevelIds.Contains(t.Id)).ToList();
        @if (ungroupedLevels.Any())
        {
            @if (seasonGroups.Any()) { <h5 class="mt-3 text-muted">Ungrouped</h5> }
            <div class="card mb-3">
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>@labels.TeamLevel</th><th>@labels.AthleteItem</th><th>Cost</th><th>Required</th></tr></thead>
                        <tbody>
                            @foreach (var level in ungroupedLevels)
                            {
                                var items = athleteItems.Where(a => a.TeamLevelId == level.Id).ToList();
                                @if (items.Any())
                                {
                                    @foreach (var item in items)
                                    {
                                        <tr>
                                            <td>@level.Name</td>
                                            <td>@item.Name</td>
                                            <td>$@item.Cost.ToString("N2")</td>
                                            <td>@(item.IsRequired ? "Yes" : "No")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td>@level.Name</td><td colspan="3" class="text-muted fst-italic">No items</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="fw-bold mt-2 p-2 bg-light rounded">
            Grand Total: $@budgetTotal.ToString("N2")
        </div>
    }
}

@implements IDisposable

@code {
    private List<Season>? seasons;
    private List<SeasonGroup> seasonGroups = new();
    private List<SharedFee> sharedFees = new();
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<TeamLevelGroupAssignment> levelGroupAssignments = new();
    private int selectedSeasonId;
    private Season? selectedSeason;
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;
    private System.Threading.Timer? _refreshTimer;

    private decimal sharedFeesTotal => sharedFees.Sum(f => f.Amount);
    private decimal athleteItemsTotal => athleteItems.Sum(a => a.Cost);
    private decimal budgetTotal => sharedFeesTotal + athleteItemsTotal;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Task.FromResult(Db.Seasons.Where(s => s.UserId == userId).OrderByDescending(s => s.Name).ToList());
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        selectedSeason = seasons?.FirstOrDefault(s => s.Id == selectedSeasonId);
        labels = new ProjectLabels(selectedSeason);
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadData();
        _refreshTimer?.Dispose();
        if (selectedSeasonId > 0)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () => { await LoadData(); });
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasonGroups = await db.SeasonGroups.AsNoTracking().Where(g => g.SeasonId == selectedSeasonId).OrderBy(g => g.SortOrder).ToListAsync();
        sharedFees = await db.SharedFees.AsNoTracking().Where(f => f.SeasonId == selectedSeasonId).ToListAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var levelIds = teamLevels.Select(t => t.Id).ToList();
        athleteItems = await db.AthleteItems.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        levelGroupAssignments = await db.TeamLevelGroupAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
