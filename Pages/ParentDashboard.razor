@page "/parent"
@attribute [Authorize]
@layout GymBudgetApp.Shared.ParentLayout
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject GymBudgetApp.Services.NotificationService NotificationService

@if (!loading && !hasProfile)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <span>Set up your profile so coaches can see your name in chat!</span>
        <a href="parent/profile" class="btn btn-sm btn-primary">Set Up Profile</a>
    </div>
}

@if (!loading && announcements.Any())
{
    <div class="mb-4">
        <h5>Announcements</h5>
        @foreach (var ann in displayedAnnouncements)
        {
            var isNew = !readAnnouncementIds.Contains(ann.Id);
            <div class="card mb-2 @(ann.IsPinned ? "border-warning" : "")">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            @if (ann.IsPinned)
                            {
                                <span class="oi oi-pin text-warning me-1" style="font-size: 0.75rem;"></span>
                            }
                            <strong>@ann.Title</strong>
                            @if (isNew)
                            {
                                <span class="badge bg-danger ms-1">New</span>
                            }
                        </div>
                        <small class="text-muted">@ann.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</small>
                    </div>
                    <div class="mt-1" style="white-space: pre-wrap; word-break: break-word;">@ann.Content</div>
                    <small class="text-muted">— @ann.AuthorEmail</small>
                </div>
            </div>
        }
        @if (announcements.Count > announcementDisplayCount)
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowMoreAnnouncements">
                View All (@announcements.Count total)
            </button>
        }
    </div>
}

<h3>My Athletes</h3>

@if (maintenanceMode)
{
    <div class="text-center py-5">
        <div style="font-size: 3rem;">🔧</div>
        <h4 class="mt-3">We're Updating GymHub</h4>
        <p class="text-muted">We're making improvements to give you a better experience.<br/>Please check back shortly.</p>
    </div>
}
else if (loading)
{
    <p>Loading...</p>
}
else if (!athletes.Any() && !budgetNotReady)
{
    <div class="text-center py-5">
        <h4 class="text-muted">No athletes linked yet</h4>
        <p>Enter your invite code to get started.</p>
        <a href="/claim" class="btn btn-primary">Link an Athlete</a>
    </div>
}
else if (budgetNotReady)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Your budget is being prepared. Check back soon.</h4>
        <p>Your season information has not been published yet. Please check back later.</p>
    </div>
}
else if (needsCommitment)
{
    <div class="text-center py-5">
        <h4>Complete Your Commitment Form</h4>
        <p class="text-muted">Before accessing your athlete's budget and payment information, please review and sign the team commitment form.</p>
        <a href="/parent/commitment" class="btn btn-primary btn-lg">Review & Sign Commitment Form</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-muted">@athletes.Count athlete(s)</span>
        <a href="/claim" class="btn btn-sm btn-outline-primary">+ Link Another Athlete</a>
    </div>

    @foreach (var athlete in athletes)
    {
        var athleteLevel = parentGymnasts.FirstOrDefault(g => g.Id == athlete.Id)?.Level ?? teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "";
        var sharedFeeCost = parentCostPerGymnast;
        var apparelCost = GetParentApparelCost(athlete.Id, athleteLevel);
        var compCost = GetParentCompCost(athlete.Id, athleteLevel);
        var totalCost = sharedFeeCost + apparelCost + compCost;
        var athletePayments = payments.Where(p => p.AthleteId == athlete.Id && p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).ToList();
        var athleteCredits = payments.Where(p => p.AthleteId == athlete.Id && p.Type == PaymentType.Credit).ToList();
        var totalPaid = athletePayments.Sum(p => p.Amount);
        var totalCredits = athleteCredits.Sum(p => p.Amount);
        var balance = totalCost - totalPaid - totalCredits;
        var isExpanded = expandedAthletes.Contains(athlete.Id);

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleAthlete(athlete.Id)" style="cursor: pointer;">
                <div>
                    <h5 class="mb-0 d-inline">@athlete.Name</h5>
                    <span class="badge bg-primary ms-2">@(teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? parentGymnasts.FirstOrDefault(g => g.Id == athlete.Id)?.Level ?? "")</span>
                    @if (balance <= 0)
                    {
                        <span class="badge bg-success ms-1">Paid in Full</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark ms-1">$@balance.ToString("N2") due</span>
                    }
                </div>
                <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>

            @if (isExpanded)
            {
            <div class="card-body">
                <!-- Fee Breakdown -->
                <h6>Fee Breakdown</h6>
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr><th>Item</th><th>Type</th><th class="text-end">Cost</th></tr>
                    </thead>
                    <tbody>
                        <!-- Shared Fees (from budget calculator) -->
                        @if (sharedFeeCost > 0)
                        {
                            <tr>
                                <td><input type="checkbox" class="form-check-input me-2" checked disabled /> Shared Fees</td>
                                <td><span class="badge bg-secondary">Required</span></td>
                                <td class="text-end">$@sharedFeeCost.ToString("N2")</td>
                            </tr>
                        }

                        <!-- Apparel Items -->
                        @foreach (var col in parentApparelColumns)
                        {
                            var appApplies = DoesApparelApplyToLevel(col.Name, athleteLevel);
                            if (!appApplies) continue;
                            var appPrice = GetApparelPrice(col.Name, athleteLevel);
                            var appSelected = IsParentApparelSelected(athlete.Id, col.Name);
                            var appDeadline = GetApparelDeadline(col.Name);
                            var appLocked = appDeadline.HasValue && appDeadline.Value < DateTime.Today;
                            var appAthId = athlete.Id;
                            var appName = col.Name;
                            if (col.IsRequired)
                            {
                                <tr>
                                    <td><input type="checkbox" class="form-check-input me-2" checked disabled /> @col.Name</td>
                                    <td><span class="badge bg-success">Required</span></td>
                                    <td class="text-end">$@appPrice.ToString("N2")</td>
                                </tr>
                            }
                            else
                            {
                                <tr class="@(appSelected ? "" : "table-secondary")">
                                    <td>
                                        <input type="checkbox" class="form-check-input me-2" checked="@appSelected"
                                               disabled="@appLocked"
                                               @onchange="(e) => ToggleApparelSelection(appAthId, appName, (bool)e.Value!)" />
                                        @col.Name
                                        @if (appLocked)
                                        {
                                            <small class="text-danger ms-1">Locked</small>
                                        }
                                        else if (appDeadline.HasValue)
                                        {
                                            <small class="text-warning ms-1">Due @appDeadline.Value.ToString("MMM dd")</small>
                                        }
                                    </td>
                                    <td><span class="badge bg-info">Optional</span></td>
                                    <td class="text-end">@(appSelected ? $"${appPrice:N2}" : "—")</td>
                                </tr>
                            }
                        }

                        <!-- Competition Items -->
                        @foreach (var col in parentCompColumns)
                        {
                            var compApplies2 = DoesCompApplyToLevel2(col.Name, athleteLevel);
                            if (!compApplies2) continue;
                            var compPrice2 = GetCompPrice2(col.Name, athleteLevel);
                            var compSelected2 = IsParentCompSelected(athlete.Id, col.Name);
                            var compDeadline = GetCompDeadline(col.Name);
                            var compLocked = compDeadline.HasValue && compDeadline.Value < DateTime.Today;
                            var compAthId = athlete.Id;
                            var compName = col.Name;
                            if (col.IsRequired)
                            {
                                <tr>
                                    <td><input type="checkbox" class="form-check-input me-2" checked disabled /> @col.Name</td>
                                    <td><span class="badge bg-danger">Required</span></td>
                                    <td class="text-end">$@compPrice2.ToString("N2")</td>
                                </tr>
                            }
                            else
                            {
                                <tr class="@(compSelected2 ? "" : "table-secondary")">
                                    <td>
                                        <input type="checkbox" class="form-check-input me-2" checked="@compSelected2"
                                               disabled="@compLocked"
                                               @onchange="(e) => ToggleCompSelection(compAthId, compName, (bool)e.Value!)" />
                                        @col.Name
                                        @if (compLocked)
                                        {
                                            <small class="text-danger ms-1">Locked</small>
                                        }
                                        else if (compDeadline.HasValue)
                                        {
                                            <small class="text-warning ms-1">Due @compDeadline.Value.ToString("MMM dd")</small>
                                        }
                                    </td>
                                    <td><span class="badge bg-info">Optional</span></td>
                                    <td class="text-end">@(compSelected2 ? $"${compPrice2:N2}" : "—")</td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr class="fw-bold">
                            <td colspan="2">Total Fees</td>
                            <td class="text-end">$@totalCost.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Payment Summary -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Total Fees</small>
                                <h5 class="mb-0">$@totalCost.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Total Paid</small>
                                <h5 class="mb-0 text-success">$@totalPaid.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                    @if (totalCredits > 0)
                    {
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-2">
                                    <small class="text-muted">Credits</small>
                                    <h5 class="mb-0 text-info">-$@totalCredits.ToString("N2")</h5>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-3">
                        <div class="card @(balance <= 0 ? "bg-success text-white" : "bg-warning")">
                            <div class="card-body text-center py-2">
                                <small>Balance Due</small>
                                <h5 class="mb-0">$@balance.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                </div>

                @{
                    var athleteLevelObj = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId);
                    var gymnastRecord = parentGymnasts.FirstOrDefault(g => g.Id == athlete.Id);
                    var seasonPayMonths = seasons.FirstOrDefault()?.PaymentMonths ?? 8;
                    var planMonths = gymnastRecord?.PaymentPlanMonths ?? seasonPayMonths;
                    if (planMonths <= 0) planMonths = 8;
                    var rawSeasonStart = seasons.FirstOrDefault()?.PaymentStartMonth ?? 0;
                    var seasonStartMonth = rawSeasonStart > 0 ? rawSeasonStart : 8;
                    var startMonthNum = gymnastRecord?.PaymentStartMonth ?? seasonStartMonth;
                    var monthlyAmount = Math.Round(balance / planMonths, 2);
                    var scheduleYear = startMonthNum <= DateTime.Today.Month ? DateTime.Today.Year : DateTime.Today.Year - 1;
                    var scheduleStart = new DateTime(scheduleYear, startMonthNum, 15);
                    var payLink = parentLinksData.FirstOrDefault(pl => pl.AthleteId == athlete.Id);
                    var usesExternalBilling = payLink?.UseExternalBilling == true;
                }

                @if (balance > 0)
                {
                    <!-- Payment Schedule -->
                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <h6 class="card-title">Payment Plan</h6>
                            <p class="text-muted mb-2">@planMonths monthly payments of <strong>$@monthlyAmount.ToString("N2")</strong>, due on the 15th</p>
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr><th>#</th><th>Due Date</th><th class="text-end">Amount</th><th>Status</th></tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < planMonths; i++)
                                        {
                                            var dueDate = scheduleStart.AddMonths(i);
                                            var installmentNum = i + 1;
                                            var cumulativeDue = monthlyAmount * installmentNum;
                                            var isPaid = totalPaid >= cumulativeDue;
                                            var isPartial = !isPaid && totalPaid > monthlyAmount * i;
                                            var isPastDue = dueDate < DateTime.Today && !isPaid;
                                            <tr class="@(isPastDue ? "table-danger" : isPaid ? "table-success" : "")">
                                                <td>@installmentNum</td>
                                                <td>@dueDate.ToString("MMM 15, yyyy")</td>
                                                <td class="text-end">$@monthlyAmount.ToString("N2")</td>
                                                <td>
                                                    @if (isPaid)
                                                    {
                                                        <span class="badge bg-success">Paid</span>
                                                    }
                                                    else if (isPartial)
                                                    {
                                                        <span class="badge bg-info">Partial</span>
                                                    }
                                                    else if (isPastDue)
                                                    {
                                                        <span class="badge bg-danger">Past Due</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Upcoming</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                @if (balance > 0 && stripeEnabled)
                {
                    @if (usesExternalBilling)
                    {
                        <div class="alert alert-info mb-2 d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Payments managed through iClassPro</strong>
                                <br/><small class="text-muted">Your account is set up for automatic billing through our studio management system.</small>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ToggleExternalBilling(athlete.Id, false)">
                                Switch to Online Payment
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Payment Options -->
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <button class="btn btn-success w-100" @onclick="() => StartPayment(athlete, monthlyAmount)" disabled="@isProcessing">
                                    @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Pay Monthly ($@monthlyAmount.ToString("N2"))
                                </button>
                            </div>
                            <div class="col-md-4">
                                <button class="btn btn-primary w-100" @onclick="() => StartPayment(athlete, balance)" disabled="@isProcessing">
                                    @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Pay in Full ($@balance.ToString("N2"))
                                </button>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" placeholder="Amount"
                                           min="1" max="@balance" step="0.01"
                                           @bind="customAmounts[athlete.Id]" />
                                    <button class="btn btn-outline-success" disabled="@(isProcessing || !customAmounts.ContainsKey(athlete.Id) || customAmounts[athlete.Id] <= 0)"
                                            @onclick="() => StartPayment(athlete, customAmounts.GetValueOrDefault(athlete.Id, 0))">
                                        Pay
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Auto-Pay / External Billing Toggle -->
                        @if (balance > 0 && payLink != null)
                        {
                            <div class="mt-2">
                                @if (payLink.AutoPayEnabled)
                                {
                                    <div class="alert alert-success py-2 mb-0 d-flex justify-content-between align-items-center">
                                        <span>Auto-Pay is <strong>enabled</strong> — $@monthlyAmount.ToString("N2") on the 15th monthly</span>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DisableAutoPay(athlete.Id)" disabled="@isProcessing">
                                            Disable Auto-Pay
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-outline-primary w-100 mb-2" @onclick="() => EnableAutoPay(athlete, monthlyAmount)" disabled="@isProcessing">
                                        @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Enable Auto-Pay ($@monthlyAmount.ToString("N2")/month on the 15th)
                                    </button>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm w-100" @onclick="() => ToggleExternalBilling(athlete.Id, true)">
                                Bill through iClassPro instead
                            </button>
                        }
                    }
                }
                else if (balance > 0 && !stripeEnabled)
                {
                    <div class="alert alert-info mb-0">
                        Online payments are not yet enabled. Please contact your program administrator.
                    </div>
                }

                @if (showExternalBillingConfirm)
                {
                    <div class="alert alert-warning mt-2">
                        <h6 class="alert-heading">Switch to iClassPro Billing?</h6>
                        <p class="mb-2">By choosing this option, online payments through this portal will be <strong>disabled</strong>. Your account will be <strong>automatically charged by Top Notch Training through iClassPro</strong>.</p>
                        <p class="mb-3"><small>Any existing auto-pay subscription will be cancelled. You can switch back to online payment at any time.</small></p>
                        <button class="btn btn-warning me-2" @onclick="ConfirmExternalBilling">Yes, bill through iClassPro</button>
                        <button class="btn btn-secondary" @onclick="() => showExternalBillingConfirm = false">Cancel</button>
                    </div>
                }

                @if (paymentError != null)
                {
                    <div class="alert alert-danger mt-2">@paymentError</div>
                }

                <!-- Payment History -->
                @{
                    var athletePending = payments.Where(p => p.AthleteId == athlete.Id && p.Status == PaymentStatus.Pending && p.Type == PaymentType.Payment).ToList();
                    var allAthleteTransactions = athletePayments.Cast<Payment>().Concat(athleteCredits).Concat(athletePending).OrderByDescending(p => p.PaidAt ?? p.CreatedAt).ToList();
                }
                @if (allAthleteTransactions.Any())
                {
                    <h6 class="mt-3">Payment History</h6>
                    <table class="table table-sm">
                        <thead class="table-light"><tr><th>Date</th><th>Description</th><th>Amount</th><th>Type</th></tr></thead>
                        <tbody>
                            @foreach (var p in allAthleteTransactions)
                            {
                                var isCredit = p.Type == PaymentType.Credit;
                                <tr class="@(isCredit ? "table-info" : "")">
                                    <td>@(p.PaidAt?.ToString("MMM dd, yyyy") ?? p.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                    <td>@(p.Description ?? (isCredit ? "Credit" : "Payment"))</td>
                                    <td class="@(isCredit ? "text-info" : "")">@(isCredit ? "-" : "")$@p.Amount.ToString("N2")</td>
                                    <td>
                                        @if (isCredit)
                                        {
                                            <span class="badge bg-info">Credit</span>
                                        }
                                        else if (p.Status == PaymentStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Payment</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <!-- Upcoming Meets -->
                @{
                    var athleteMeetIds = meetLevelAssignments
                        .Where(a => a.TeamLevelId == athlete.TeamLevelId)
                        .Select(a => a.MeetId).ToHashSet();
                    var upcomingMeets = meets
                        .Where(m => athleteMeetIds.Contains(m.Id) && m.Date >= DateTime.Today)
                        .OrderBy(m => m.Date).ToList();
                }
                @if (upcomingMeets.Any())
                {
                    <h6 class="mt-3">Upcoming Events</h6>
                    <div class="list-group">
                        @foreach (var meet in upcomingMeets)
                        {
                            var daysUntil = (meet.Date - DateTime.Today).Days;
                            var currentRsvp = eventRsvps.FirstOrDefault(r => r.MeetId == meet.Id && r.AthleteId == athlete.Id);
                            var currentStatus = currentRsvp?.Status ?? RsvpStatus.NoResponse;
                            var rsvpNoteKey = $"meet-{meet.Id}-{athlete.Id}";
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@meet.Name</strong>
                                        <br/><small class="text-muted">@meet.Date.ToString("dddd, MMMM d, yyyy")</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-@(meet.TravelType == TravelType.Fly ? "info" : "secondary")">@meet.TravelType</span>
                                        <br/><small class="text-muted">@daysUntil day(s) away</small>
                                    </div>
                                </div>
                                <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
                                    <span class="me-1">RSVP:</span>
                                    <button class="btn btn-sm @(currentStatus == RsvpStatus.Going ? "btn-success" : "btn-outline-success")"
                                            @onclick="() => SetMeetRsvp(meet.Id, athlete.Id, RsvpStatus.Going)">Going</button>
                                    <button class="btn btn-sm @(currentStatus == RsvpStatus.Maybe ? "btn-warning" : "btn-outline-warning")"
                                            @onclick="() => SetMeetRsvp(meet.Id, athlete.Id, RsvpStatus.Maybe)">Maybe</button>
                                    <button class="btn btn-sm @(currentStatus == RsvpStatus.NotGoing ? "btn-danger" : "btn-outline-danger")"
                                            @onclick="() => SetMeetRsvp(meet.Id, athlete.Id, RsvpStatus.NotGoing)">Not Going</button>
                                    @if (currentStatus != RsvpStatus.NoResponse)
                                    {
                                        <span class="badge bg-info ms-1">@currentStatus</span>
                                    }
                                </div>
                                <div class="mt-1">
                                    <input class="form-control form-control-sm" placeholder="Add a note (optional)"
                                           value="@(currentRsvp?.Note ?? GetRsvpNote(rsvpNoteKey))"
                                           @onchange="(e) => SetRsvpNote(rsvpNoteKey, e.Value?.ToString())" />
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Upcoming Practices -->
                @{
                    var athletePractices = upcomingPractices
                        .Where(p => p.TeamLevelId == null || p.TeamLevelId == athlete.TeamLevelId)
                        .OrderBy(p => p.Date).ToList();
                }
                @if (athletePractices.Any())
                {
                    <h6 class="mt-3">Upcoming Practices</h6>
                    <div class="list-group">
                        @foreach (var practice in athletePractices)
                        {
                            var daysUntil = (practice.Date - DateTime.Today).Days;
                            var currentPRsvp = practiceRsvpList.FirstOrDefault(r => r.PracticeId == practice.Id && r.AthleteId == athlete.Id);
                            var currentPStatus = currentPRsvp?.Status ?? RsvpStatus.NoResponse;
                            var pNoteKey = $"practice-{practice.Id}-{athlete.Id}";
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@practice.Name</strong>
                                        <br/><small class="text-muted">@practice.Date.ToString("dddd, MMMM d, yyyy") @practice.StartTime - @practice.EndTime</small>
                                        @if (!string.IsNullOrEmpty(practice.Location))
                                        {
                                            <br/><small class="text-muted">@practice.Location</small>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <small class="text-muted">@daysUntil day(s) away</small>
                                    </div>
                                </div>
                                <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
                                    <span class="me-1">RSVP:</span>
                                    <button class="btn btn-sm @(currentPStatus == RsvpStatus.Going ? "btn-success" : "btn-outline-success")"
