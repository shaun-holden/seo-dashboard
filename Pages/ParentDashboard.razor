@code {
    private bool loading = true;
    private bool hasProfile;
    private string? userId;
    private List<Athlete> athletes = new();
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<AthleteItemSelection> selections = new();
    private List<Payment> payments = new();
    private List<Meet> meets = new();
    private List<MeetTeamLevelAssignment> meetLevelAssignments = new();
    private List<SharedFee> sharedFees = new();
    private List<SharedFeeTeamLevelAssignment> sharedFeeAssignments = new();
    private List<TeamLevel> allSeasonLevels = new();
    private List<Season> seasons = new();
    private HashSet<int> expandedAthletes = new();
    private bool isProcessing;
    private string? paymentError;
    private bool stripeEnabled;
    private Dictionary<int, decimal> customAmounts = new();
    private List<ParentLink> parentLinksData = new();
    private Dictionary<int, DateTime> lastPaymentAttempt = new();
    private List<CompetitionItem> parentCompetitionItems = new();
    private List<GymnastCompetitionSelection> parentCompSelections = new();
    private List<ApparelItem> parentApparelItems = new();
    private List<GymnastApparelSelection> parentApparelSelections = new();
    private decimal parentCostPerGymnast;
    private List<Gymnast> parentGymnasts = new();

    private record ParentItemCol(string Name, bool IsRequired);
    private List<ParentItemCol> parentApparelColumns = new();
    private List<ParentItemCol> parentCompColumns = new();
    private List<Announcement> announcements = new();
    private HashSet<int> readAnnouncementIds = new();
    private int announcementDisplayCount = 10;
    private List<EventRsvp> eventRsvps = new();
    private List<Practice> upcomingPractices = new();
    private List<PracticeRsvp> practiceRsvpList = new();
    private Dictionary<string, string> rsvpNotes = new();

    // Profile state
    private HashSet<int> expandedProfiles = new();
    private Dictionary<int, Dictionary<string, string?>> profileEdits = new();
    private Dictionary<int, string> profileSaveMessages = new();

    private List<Announcement> displayedAnnouncements =>
        announcements
            .OrderByDescending(a => a.IsPinned)
            .ThenByDescending(a => a.CreatedAt)
            .Take(announcementDisplayCount)
            .ToList();

    private void ShowMoreAnnouncements()
    {
        announcementDisplayCount = announcements.Count;
    }

    private void ToggleAthlete(int athleteId)
    {
        if (!expandedAthletes.Remove(athleteId))
            expandedAthletes.Add(athleteId);
    }

    private bool budgetNotReady;
    private bool maintenanceMode;
    private int parentLinkCount;
    private int gymnastCount;
    private bool needsCommitment;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;

        var adminEmails = Configuration.GetSection("AdminEmails").Get<List<string>>() ?? new() { Configuration["AdminEmail"] ?? "deshaun@tntgym.org" };
        var isAdmin = adminEmails.Any(ae => string.Equals(userEmail, ae, StringComparison.OrdinalIgnoreCase));
        maintenanceMode = Configuration.GetValue<bool>("MaintenanceMode") && !isAdmin;
        if (maintenanceMode) { loading = false; return; }

        var stripeKey = Environment.GetEnvironmentVariable("STRIPE_SECRET_KEY")
            ?? Configuration["Stripe:SecretKey"] ?? "";
        stripeEnabled = !string.IsNullOrEmpty(stripeKey);

        // Check if profile exists
        using (var dbCheck = await DbFactory.CreateDbContextAsync())
        {
            hasProfile = await dbCheck.UserProfiles.AnyAsync(p => p.UserId == userId);
        }

        await LoadData();

        // Always verify pending payments
        await VerifyPendingPayments();

        loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && userId != null && announcements.Any())
        {
            await MarkAnnouncementsAsRead();
            StateHasChanged();
        }
    }

    private async Task MarkAnnouncementsAsRead()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var unreadIds = announcements
                .Where(a => !readAnnouncementIds.Contains(a.Id))
                .Select(a => a.Id)
                .ToList();

            if (!unreadIds.Any()) return;

            // Check which ones already have receipts (in case of race condition)
            var existingIds = await db.AnnouncementReadReceipts
                .Where(r => r.UserId == userId && unreadIds.Contains(r.AnnouncementId))
                .Select(r => r.AnnouncementId)
                .ToListAsync();

            foreach (var annId in unreadIds.Where(id => !existingIds.Contains(id)))
            {
                db.AnnouncementReadReceipts.Add(new AnnouncementReadReceipt
                {
                    AnnouncementId = annId,
                    UserId = userId!,
                    ReadAt = DateTime.UtcNow
                });
            }

            await db.SaveChangesAsync();

            // Update local state
            foreach (var id in unreadIds)
                readAnnouncementIds.Add(id);

            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Non-critical - don't crash if read receipt creation fails
        }
    }

    private async Task VerifyPendingPayments()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var pendingPayments = await db.Payments
            .Where(p => p.PayerUserId == userId && p.Status == PaymentStatus.Pending)
            .ToListAsync();

        if (!pendingPayments.Any()) return;

        var needsSave = false;
        var expireCutoff = DateTime.UtcNow.AddMinutes(-30);

        foreach (var payment in pendingPayments)
        {
            // Try to verify with Stripe if session exists
            if (!string.IsNullOrEmpty(payment.StripeSessionId))
            {
                try
                {
                    var sessionService = new Stripe.Checkout.SessionService();
                    var session = await sessionService.GetAsync(payment.StripeSessionId);
                    if (session.PaymentStatus == "paid")
                    {
                        payment.Status = PaymentStatus.Paid;
                        payment.PaidAt = DateTime.UtcNow;
                        payment.StripePaymentIntentId = session.PaymentIntentId;
                        needsSave = true;
                        continue;
                    }
                }
                catch { }
            }

            // Expire pending payments older than 30 minutes
            if (payment.CreatedAt < expireCutoff)
            {
                payment.Status = PaymentStatus.Failed;
                payment.Description = (payment.Description ?? "") + " (Expired)";
                needsSave = true;
            }
        }

        if (needsSave)
        {
            await db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        if (userId == null) return;
        using var db = await DbFactory.CreateDbContextAsync();

        var parentLinks = await db.ParentLinks.AsNoTracking()
            .Where(pl => pl.ParentUserId == userId && pl.IsClaimed)
            .ToListAsync();
        parentLinkCount = parentLinks.Count;

        var publishedSeasons = await db.Seasons.AsNoTracking()
            .Where(s => s.IsPublished)
            .OrderByDescending(s => s.IsActive)
            .ThenByDescending(s => s.CreatedAt)
            .ToListAsync();

        if (!publishedSeasons.Any() && parentLinks.Any())
        {
            budgetNotReady = true;
            athletes = new();
            return;
        }

        budgetNotReady = false;

        var allTeamLevels = await db.TeamLevels.AsNoTracking().ToListAsync();
        var linkedAthleteIds = parentLinks.Select(l => l.AthleteId).ToList();
        var linkedAthletes = await db.Athletes.AsNoTracking()
            .Where(a => linkedAthleteIds.Contains(a.Id))
            .ToListAsync();
        var gymnastRecords = await db.Gymnasts.AsNoTracking()
            .Where(g => linkedAthleteIds.Contains(g.Id))
            .OrderBy(g => g.Name)
            .ToListAsync();
        var targetSeason = SelectParentSeason(publishedSeasons, allTeamLevels, linkedAthletes, gymnastRecords);
        if (targetSeason == null)
        {
            athletes = new();
            parentGymnasts = new();
            gymnastCount = 0;
            return;
        }

        teamLevels = allTeamLevels.Where(t => t.SeasonId == targetSeason.Id).ToList();
        var seasonAthletes = linkedAthletes
            .Where(a => teamLevels.Any(t => t.Id == a.TeamLevelId))
            .ToList();

        if (!seasonAthletes.Any() && linkedAthletes.Any() && !gymnastRecords.Any())
        {
            budgetNotReady = true;
            athletes = new();
            parentGymnasts = new();
            gymnastCount = 0;
            return;
        }

        var fallbackAthletes = gymnastRecords
            .Select(g => new Athlete
            {
                Id = g.Id,
                Name = g.Name,
                TeamLevelId = teamLevels.FirstOrDefault(t => LevelNamesMatch(t.Name, g.Level))?.Id ?? 0
            })
            .ToList();

        athletes = seasonAthletes
            .Concat(fallbackAthletes.Where(fa => seasonAthletes.All(a => a.Id != fa.Id)))
            .OrderBy(a => a.Name)
            .ToList();
        var athleteIds = athletes.Select(a => a.Id).ToList();
        parentGymnasts = gymnastRecords.Where(g => athleteIds.Contains(g.Id)).ToList();
        gymnastCount = athletes.Count;

        budgetNotReady = false;

        var levelIds = athletes.Select(a => a.TeamLevelId).Where(id => id > 0).Distinct().ToList();

        // Check for unsigned commitment forms
        var activeCommitmentForm = await db.CommitmentForms.AsNoTracking()
            .Where(f => f.SeasonId == targetSeason.Id && f.IsActive)
            .OrderByDescending(f => f.CreatedAt)
            .FirstOrDefaultAsync();

        if (activeCommitmentForm != null)
        {
            var hasSigned = await db.CommitmentSignatures.AsNoTracking()
                .AnyAsync(s => s.CommitmentFormId == activeCommitmentForm.Id && s.ParentUserId == userId);
            needsCommitment = !hasSigned;
        }
        else
        {
            needsCommitment = false;
        }

        // Athletes already loaded from Gymnasts — no need to re-filter by TeamLevel
        payments = await db.Payments.AsNoTracking().Where(p => athleteIds.Contains(p.AthleteId)).ToListAsync();
        parentLinksData = parentLinks.Where(pl => athleteIds.Contains(pl.AthleteId)).ToList();

        // Load data for the selected published season only
        seasons = new List<Season> { targetSeason };
        sharedFees = await db.SharedFees.AsNoTracking()
            .Where(f => f.SeasonId == targetSeason.Id && f.IsIncludedInBudget)
            .ToListAsync();
        var sharedFeeIds = sharedFees.Select(f => f.Id).ToList();
        sharedFeeAssignments = await db.SharedFeeTeamLevelAssignments.AsNoTracking()
            .Where(a => sharedFeeIds.Contains(a.SharedFeeId))
            .ToListAsync();
        allSeasonLevels = teamLevels.ToList();

        // Load meets for upcoming events
        meets = await db.Meets.AsNoTracking().Where(m => m.SeasonId == targetSeason.Id).ToListAsync();
        meetLevelAssignments = await db.MeetTeamLevelAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();

        // Load RSVP data
        var meetIds = meets.Select(m => m.Id).ToList();
        eventRsvps = await db.EventRsvps.AsNoTracking()
            .Where(r => r.ParentUserId == userId && athleteIds.Contains(r.AthleteId))
            .ToListAsync();

        // Load upcoming practices
        upcomingPractices = await db.Practices.AsNoTracking()
            .Where(p => p.SeasonId == targetSeason.Id && p.Date >= DateTime.Today)
            .OrderBy(p => p.Date)
            .ToListAsync();
        var practiceIds = upcomingPractices.Select(p => p.Id).ToList();
        practiceRsvpList = await db.PracticeRsvps.AsNoTracking()
            .Where(r => r.ParentUserId == userId && athleteIds.Contains(r.AthleteId))
            .ToListAsync();

        // Load budget calculator cost per gymnast
        var calcTotal = await db.BudgetCalculatorEntries.AsNoTracking()
            .Where(e => e.SeasonId == targetSeason.Id)
            .SumAsync(e => (decimal?)e.CalculatedTotal) ?? 0;
        var athleteCount = targetSeason.AthleteCount > 0 ? targetSeason.AthleteCount : athletes.Count;
        parentCostPerGymnast = athleteCount > 0 ? Math.Round(calcTotal / athleteCount, 2) : 0;

        // Load apparel items
        parentApparelItems = await db.ApparelItems.AsNoTracking()
            .Where(a => a.SeasonId == targetSeason.Id)
            .OrderBy(a => a.IsRequired ? 0 : 1).ThenBy(a => a.Name)
            .ToListAsync();
        parentApparelColumns = parentApparelItems
            .GroupBy(a => a.Name, StringComparer.OrdinalIgnoreCase)
            .Select(g => new ParentItemCol(g.Key, g.Any(a => a.IsRequired)))
            .ToList();
        parentApparelSelections = await db.GymnastApparelSelections
            .Where(s => athleteIds.Contains(s.GymnastId))
            .ToListAsync();

        // Load competition items
        parentCompetitionItems = await db.CompetitionItems.AsNoTracking()
            .Where(c => c.SeasonId == targetSeason.Id)
            .OrderBy(c => c.IsRequired ? 0 : 1).ThenBy(c => c.Name)
            .ToListAsync();
        parentCompColumns = parentCompetitionItems
            .GroupBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .Select(g => new ParentItemCol(g.Key, g.Any(c => c.IsRequired)))
            .ToList();
        parentCompSelections = await db.GymnastCompetitionSelections
            .Where(s => athleteIds.Contains(s.GymnastId))
            .ToListAsync();

        expandedAthletes = athletes.Select(a => a.Id).ToHashSet();
        foreach (var a in athletes)
            customAmounts.TryAdd(a.Id, 0);

        // Load announcements for published seasons
        announcements = await db.Announcements.AsNoTracking()
            .Where(a => a.SeasonId == targetSeason.Id && a.TeamLevelId == null)
            .OrderByDescending(a => a.IsPinned)
            .ThenByDescending(a => a.CreatedAt)
            .ToListAsync();

        var annIds = announcements.Select(a => a.Id).ToList();
        readAnnouncementIds = (await db.AnnouncementReadReceipts.AsNoTracking()
            .Where(r => r.UserId == userId && annIds.Contains(r.AnnouncementId))
            .Select(r => r.AnnouncementId)
            .ToListAsync())
            .ToHashSet();
    }

    private Season? SelectParentSeason(List<Season> publishedSeasons, List<TeamLevel> allTeamLevels, List<Athlete> linkedAthletes, List<Gymnast> gymnastRecords)
    {
        if (!publishedSeasons.Any())
            return null;

        var linkedSeasonIds = linkedAthletes
            .Select(a => allTeamLevels.FirstOrDefault(t => t.Id == a.TeamLevelId)?.SeasonId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .Distinct()
            .ToHashSet();

        if (linkedSeasonIds.Any())
        {
            return publishedSeasons.FirstOrDefault(s => s.IsActive && linkedSeasonIds.Contains(s.Id))
                ?? publishedSeasons.FirstOrDefault(s => linkedSeasonIds.Contains(s.Id))
                ?? publishedSeasons.FirstOrDefault(s => s.IsActive)
                ?? publishedSeasons.FirstOrDefault();
        }

        var gymnastLevels = gymnastRecords
            .Select(g => g.Level)
            .Where(level => !string.IsNullOrWhiteSpace(level))
            .Select(level => level!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        bool HasMatchingLevel(Season season) =>
            allTeamLevels.Any(t => t.SeasonId == season.Id
                && gymnastLevels.Any(level => LevelNamesMatch(level, t.Name)));

        return publishedSeasons.FirstOrDefault(s => s.IsActive && HasMatchingLevel(s))
            ?? publishedSeasons.FirstOrDefault(HasMatchingLevel)
            ?? publishedSeasons.FirstOrDefault(s => s.IsActive)
            ?? publishedSeasons.FirstOrDefault();
    }

    private static bool LevelNamesMatch(string? left, string? right)
    {
        var normalizedLeft = NormalizeLevelName(left);
        var normalizedRight = NormalizeLevelName(right);
        return !string.IsNullOrEmpty(normalizedLeft)
            && !string.IsNullOrEmpty(normalizedRight)
            && string.Equals(normalizedLeft, normalizedRight, StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeLevelName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        return string.Join(" ", value.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries));
    }

    // Level matching helper
    private bool LevelMatchesKeywords(string level, string appliesTo)
    {
        return appliesTo.Split(',').Select(k => k.Trim()).Where(k => k.Length > 0)
            .Any(k => level.Contains(k, StringComparison.OrdinalIgnoreCase) || k.Contains(level, StringComparison.OrdinalIgnoreCase));
    }

    // Apparel helpers
    private bool DoesApparelApplyToLevel(string itemName, string level)
    {
        if (string.IsNullOrEmpty(level)) return true;
        var items = parentApparelItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return false;
        if (items.Any(a => string.IsNullOrEmpty(a.AppliesTo))) return true;
        return items.Any(a => !string.IsNullOrEmpty(a.AppliesTo) && LevelMatchesKeywords(level, a.AppliesTo));
    }

    private decimal GetApparelPrice(string itemName, string level)
    {
        var items = parentApparelItems.Where(a => a.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!items.Any()) return 0;
        if (!string.IsNullOrEmpty(level))
        {
            // Find the best match — prefer the one with the longest matching keyword
            var matches = items.Where(a => !string.IsNullOrEmpty(a.AppliesTo) && LevelMatchesKeywords(level, a.AppliesTo)).ToList();
            if (matches.Count == 1) return matches[0].Price;
            if (matches.Count > 1)
            {
                // Pick the one with the most specific (longest) matching keyword
                var best = matches.OrderByDescending(a => a.AppliesTo!.Split(',')
                    .Select(k => k.Trim())
                    .Where(k => level.Contains(k, StringComparison.OrdinalIgnoreCase) || k.Contains(level, StringComparison.OrdinalIgnoreCase))
                    .Max(k => k.Length)).First();
                return best.Price;
            }
        }
        return items.FirstOrDefault(a => string.IsNullOrEmpty(a.AppliesTo))?.Price ?? 0;
    }

