    private async Task EnableAutoPay(Athlete athlete, decimal monthlyAmount)
    {
        paymentError = null;

        if (lastPaymentAttempt.TryGetValue(athlete.Id, out var lastAttempt)
            && (DateTime.UtcNow - lastAttempt).TotalSeconds < 30)
        {
            paymentError = "Please wait before trying again.";
            return;
        }

        isProcessing = true;
        lastPaymentAttempt[athlete.Id] = DateTime.UtcNow;

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var link = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == athlete.Id && pl.ParentUserId == userId);
            if (link == null) { isProcessing = false; return; }

            var levelName = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "Program";

            // Create Stripe Customer if not exists
            if (string.IsNullOrEmpty(link.StripeCustomerId))
            {
                var customerService = new Stripe.CustomerService();
                var customer = await customerService.CreateAsync(new Stripe.CustomerCreateOptions
                {
                    Email = userEmail,
                    Name = athlete.Name,
                    Metadata = new Dictionary<string, string> { { "athleteId", athlete.Id.ToString() } }
                });
                link.StripeCustomerId = customer.Id;
                await db.SaveChangesAsync();
            }

            // Create Stripe Checkout in subscription mode
            var options = new Stripe.Checkout.SessionCreateOptions
            {
                Customer = link.StripeCustomerId,
                PaymentMethodTypes = new List<string> { "card" },
                LineItems = new List<Stripe.Checkout.SessionLineItemOptions>
                {
                    new()
                    {
                        PriceData = new Stripe.Checkout.SessionLineItemPriceDataOptions
                        {
                            UnitAmount = (long)(monthlyAmount * 100),
                            Currency = "usd",
                            Recurring = new Stripe.Checkout.SessionLineItemPriceDataRecurringOptions
                            {
                                Interval = "month",
                            },
                            ProductData = new Stripe.Checkout.SessionLineItemPriceDataProductDataOptions
                            {
                                Name = $"{athlete.Name} - {levelName} Monthly Auto-Pay",
                            },
                        },
                        Quantity = 1,
                    },
                },
                Mode = "subscription",
                SuccessUrl = "https://gymbudgetapp-production.up.railway.app/parent?autopay=enabled",
                CancelUrl = "https://gymbudgetapp-production.up.railway.app/parent?autopay=cancelled",
                SubscriptionData = new Stripe.Checkout.SessionSubscriptionDataOptions
                {
                    BillingCycleAnchor = GetNext15th(),
                    Metadata = new Dictionary<string, string>
                    {
                        { "cancel_after_months", GetPlanMonths(athlete.TeamLevelId).ToString() },
                        { "athlete_id", athlete.Id.ToString() }
                    },
                },
            };

            var service = new Stripe.Checkout.SessionService();
            var session = await service.CreateAsync(options);

            link.AutoPayEnabled = true;
            var subscriptionId = session.SubscriptionId ?? session.Id;
            link.StripeSubscriptionId = subscriptionId;
            await db.SaveChangesAsync();

            // Set auto-cancel date on subscription
            if (!string.IsNullOrEmpty(session.SubscriptionId))
            {
                try
                {
                    var subService = new Stripe.SubscriptionService();
                    var planMonths = GetPlanMonths(athlete.TeamLevelId);
                    var cancelAt = GetNext15th().AddMonths(planMonths);
                    await subService.UpdateAsync(session.SubscriptionId, new Stripe.SubscriptionUpdateOptions
                    {
                        CancelAt = cancelAt,
                    });
                }
                catch { /* Non-critical, subscription still works */ }
            }

            _ = NotificationService.NotifyAutoPayEnabled(athlete.Name, userEmail ?? "", monthlyAmount);

            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            paymentError = $"Auto-pay error: {ex.Message}";
            isProcessing = false;
        }
    }

