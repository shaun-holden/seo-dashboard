@page "/parent"
@attribute [Authorize]
@layout GymBudgetApp.Shared.ParentLayout
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject GymBudgetApp.Services.NotificationService NotificationService

<h3>My Athletes</h3>

@if (loading)
{
    <p>Loading...</p>
}
else if (!athletes.Any() && !budgetNotReady)
{
    <div class="text-center py-5">
        <h4 class="text-muted">No athletes linked yet</h4>
        <p>Enter your invite code to get started.</p>
        <a href="/claim" class="btn btn-primary">Link an Athlete</a>
    </div>
}
else if (budgetNotReady)
{
    <div class="text-center py-5">
        <h4 class="text-muted">Your budget is being prepared. Check back soon.</h4>
        <p>Your season information has not been published yet. Please check back later.</p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-muted">@athletes.Count athlete(s)</span>
        <a href="/claim" class="btn btn-sm btn-outline-primary">+ Link Another Athlete</a>
    </div>

    @foreach (var athlete in athletes)
    {
        var levelItems = athleteItems.Where(i => i.TeamLevelId == athlete.TeamLevelId).ToList();
        var requiredItems = levelItems.Where(i => i.IsRequired).ToList();
        var optionalItems = levelItems.Where(i => !i.IsRequired).ToList();
        var athleteSelections = selections.Where(s => s.AthleteId == athlete.Id).Select(s => s.AthleteItemId).ToHashSet();
        var requiredCost = requiredItems.Sum(i => i.Cost);
        var optionalCost = optionalItems.Where(i => athleteSelections.Contains(i.Id)).Sum(i => i.Cost);
        var sharedFeeCost = GetSharedFeeCostPerAthlete(athlete.TeamLevelId);
        var totalCost = requiredCost + optionalCost + sharedFeeCost;
        var athletePayments = payments.Where(p => p.AthleteId == athlete.Id && p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).ToList();
        var athleteCredits = payments.Where(p => p.AthleteId == athlete.Id && p.Type == PaymentType.Credit).ToList();
        var totalPaid = athletePayments.Sum(p => p.Amount);
        var totalCredits = athleteCredits.Sum(p => p.Amount);
        var balance = totalCost - totalPaid - totalCredits;
        var isExpanded = expandedAthletes.Contains(athlete.Id);

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleAthlete(athlete.Id)" style="cursor: pointer;">
                <div>
                    <h5 class="mb-0 d-inline">@athlete.Name</h5>
                    <span class="badge bg-primary ms-2">@(teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "")</span>
                    @if (balance <= 0)
                    {
                        <span class="badge bg-success ms-1">Paid in Full</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark ms-1">$@balance.ToString("N2") due</span>
                    }
                </div>
                <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>

            @if (isExpanded)
            {
            <div class="card-body">
                <!-- Fee Breakdown -->
                <h6>Fee Breakdown</h6>
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr><th>Item</th><th>Type</th><th class="text-end">Cost</th></tr>
                    </thead>
                    <tbody>
                        @if (sharedFeeCost > 0)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input me-2" checked disabled />
                                    Shared Fees
                                </td>
                                <td><span class="badge bg-secondary">Shared Fee</span></td>
                                <td class="text-end">$@sharedFeeCost.ToString("N2")</td>
                            </tr>
                        }
                        @foreach (var item in requiredItems)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input me-2" checked disabled />
                                    @item.Name
                                </td>
                                <td><span class="badge bg-success">Required</span></td>
                                <td class="text-end">$@item.Cost.ToString("N2")</td>
                            </tr>
                        }
                        @foreach (var item in optionalItems)
                        {
                            var itemId = item.Id;
                            var athleteId = athlete.Id;
                            var isSelected = athleteSelections.Contains(itemId);
                            <tr class="@(isSelected ? "" : "table-secondary")">
                                <td>
                                    <input type="checkbox" class="form-check-input me-2" checked="@isSelected"
                                           @onchange="(e) => ToggleSelection(athleteId, itemId, (bool)e.Value!)" />
                                    @item.Name
                                </td>
                                <td><span class="badge bg-info">Optional</span></td>
                                <td class="text-end">@(isSelected ? $"${item.Cost:N2}" : "—")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr class="fw-bold">
                            <td colspan="2">Total Fees</td>
                            <td class="text-end">$@totalCost.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Payment Summary -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Total Fees</small>
                                <h5 class="mb-0">$@totalCost.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Total Paid</small>
                                <h5 class="mb-0 text-success">$@totalPaid.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                    @if (totalCredits > 0)
                    {
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-2">
                                    <small class="text-muted">Credits</small>
                                    <h5 class="mb-0 text-info">-$@totalCredits.ToString("N2")</h5>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-3">
                        <div class="card @(balance <= 0 ? "bg-success text-white" : "bg-warning")">
                            <div class="card-body text-center py-2">
                                <small>Balance Due</small>
                                <h5 class="mb-0">$@balance.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                </div>

                @{
                    var athleteLevel = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId);
                    var planMonths = athleteLevel?.PaymentPlanMonths > 0 ? athleteLevel.PaymentPlanMonths : 8;
                    var monthlyAmount = Math.Round(balance / planMonths, 2);
                    var scheduleStart = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 15);
                    if (DateTime.Today.Day > 15) scheduleStart = scheduleStart.AddMonths(1);
                }

                @if (balance > 0 && stripeEnabled)
                {
                    <!-- Payment Schedule -->
                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <h6 class="card-title">Payment Plan</h6>
                            <p class="text-muted mb-2">@planMonths monthly payments of <strong>$@monthlyAmount.ToString("N2")</strong>, due on the 15th</p>
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr><th>#</th><th>Due Date</th><th class="text-end">Amount</th><th>Status</th></tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < planMonths; i++)
                                        {
                                            var dueDate = scheduleStart.AddMonths(i);
                                            var installmentNum = i + 1;
                                            var cumulativeDue = monthlyAmount * installmentNum;
                                            var isPaid = totalPaid >= cumulativeDue;
                                            var isPartial = !isPaid && totalPaid > monthlyAmount * i;
                                            var isPastDue = dueDate < DateTime.Today && !isPaid;
                                            <tr class="@(isPastDue ? "table-danger" : isPaid ? "table-success" : "")">
                                                <td>@installmentNum</td>
                                                <td>@dueDate.ToString("MMM 15, yyyy")</td>
                                                <td class="text-end">$@monthlyAmount.ToString("N2")</td>
                                                <td>
                                                    @if (isPaid)
                                                    {
                                                        <span class="badge bg-success">Paid</span>
                                                    }
                                                    else if (isPartial)
                                                    {
                                                        <span class="badge bg-info">Partial</span>
                                                    }
                                                    else if (isPastDue)
                                                    {
                                                        <span class="badge bg-danger">Past Due</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Upcoming</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Options -->
                    <div class="row g-2 mb-2">
                        <div class="col-md-4">
                            <button class="btn btn-success w-100" @onclick="() => StartPayment(athlete, monthlyAmount)" disabled="@isProcessing">
                                @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Pay Monthly ($@monthlyAmount.ToString("N2"))
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-primary w-100" @onclick="() => StartPayment(athlete, balance)" disabled="@isProcessing">
                                @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Pay in Full ($@balance.ToString("N2"))
                            </button>
                        </div>
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" placeholder="Amount"
                                       min="1" max="@balance" step="0.01"
                                       @bind="customAmounts[athlete.Id]" />
                                <button class="btn btn-outline-success" disabled="@(isProcessing || !customAmounts.ContainsKey(athlete.Id) || customAmounts[athlete.Id] <= 0)"
                                        @onclick="() => StartPayment(athlete, customAmounts.GetValueOrDefault(athlete.Id, 0))">
                                    Pay
                                </button>
                            </div>
                        </div>
                    </div>
                }
                    <!-- Auto-Pay -->
                    @{
                        var athleteLink = parentLinksData.FirstOrDefault(pl => pl.AthleteId == athlete.Id);
                    }
                    @if (athleteLink != null && balance > 0)
                    {
                        <div class="mt-2">
                            @if (athleteLink.AutoPayEnabled)
                            {
                                <div class="alert alert-success py-2 mb-0 d-flex justify-content-between align-items-center">
                                    <span>Auto-Pay is <strong>enabled</strong> — $@monthlyAmount.ToString("N2") on the 15th monthly</span>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DisableAutoPay(athlete.Id)" disabled="@isProcessing">
                                        Disable Auto-Pay
                                    </button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-primary w-100" @onclick="() => EnableAutoPay(athlete, monthlyAmount)" disabled="@isProcessing">
                                    @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Enable Auto-Pay ($@monthlyAmount.ToString("N2")/month on the 15th)
                                </button>
                            }
                        </div>
                    }
                }
                else if (balance > 0 && !stripeEnabled)
                {
                    <div class="alert alert-info mb-0">
                        Online payments are not yet enabled. Please contact your program administrator.
                    </div>
                }

                @if (paymentError != null)
                {
                    <div class="alert alert-danger mt-2">@paymentError</div>
                }

                <!-- Payment History -->
                @{
                    var athletePending = payments.Where(p => p.AthleteId == athlete.Id && p.Status == PaymentStatus.Pending && p.Type == PaymentType.Payment).ToList();
                    var allAthleteTransactions = athletePayments.Cast<Payment>().Concat(athleteCredits).Concat(athletePending).OrderByDescending(p => p.PaidAt ?? p.CreatedAt).ToList();
                }
                @if (allAthleteTransactions.Any())
                {
                    <h6 class="mt-3">Payment History</h6>
                    <table class="table table-sm">
                        <thead class="table-light"><tr><th>Date</th><th>Description</th><th>Amount</th><th>Type</th></tr></thead>
                        <tbody>
                            @foreach (var p in allAthleteTransactions)
                            {
                                var isCredit = p.Type == PaymentType.Credit;
                                <tr class="@(isCredit ? "table-info" : "")">
                                    <td>@(p.PaidAt?.ToString("MMM dd, yyyy") ?? p.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                    <td>@(p.Description ?? (isCredit ? "Credit" : "Payment"))</td>
                                    <td class="@(isCredit ? "text-info" : "")">@(isCredit ? "-" : "")$@p.Amount.ToString("N2")</td>
                                    <td>
                                        @if (isCredit)
                                        {
                                            <span class="badge bg-info">Credit</span>
                                        }
                                        else if (p.Status == PaymentStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Payment</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <!-- Upcoming Meets -->
                @{
                    var athleteMeetIds = meetLevelAssignments
                        .Where(a => a.TeamLevelId == athlete.TeamLevelId)
                        .Select(a => a.MeetId).ToHashSet();
                    var upcomingMeets = meets
                        .Where(m => athleteMeetIds.Contains(m.Id) && m.Date >= DateTime.Today)
                        .OrderBy(m => m.Date).ToList();
                }
                @if (upcomingMeets.Any())
                {
                    <h6 class="mt-3">Upcoming Events</h6>
                    <div class="list-group">
                        @foreach (var meet in upcomingMeets)
                        {
                            var daysUntil = (meet.Date - DateTime.Today).Days;
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@meet.Name</strong>
                                    <br/><small class="text-muted">@meet.Date.ToString("dddd, MMMM d, yyyy")</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-@(meet.TravelType == TravelType.Fly ? "info" : "secondary")">@meet.TravelType</span>
                                    <br/><small class="text-muted">@daysUntil day(s) away</small>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            }
        </div>
    }
}

@code {
    private bool loading = true;
    private string? userId;
    private List<Athlete> athletes = new();
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<AthleteItemSelection> selections = new();
    private List<Payment> payments = new();
    private List<Meet> meets = new();
    private List<MeetTeamLevelAssignment> meetLevelAssignments = new();
    private List<SharedFee> sharedFees = new();
    private List<SharedFeeTeamLevelAssignment> sharedFeeAssignments = new();
    private List<TeamLevel> allSeasonLevels = new();
    private List<Season> seasons = new();
    private HashSet<int> expandedAthletes = new();
    private bool isProcessing;
    private string? paymentError;
    private bool stripeEnabled;
    private Dictionary<int, decimal> customAmounts = new();
    private List<ParentLink> parentLinksData = new();

    private void ToggleAthlete(int athleteId)
    {
        if (!expandedAthletes.Remove(athleteId))
            expandedAthletes.Add(athleteId);
    }

    private bool budgetNotReady;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;

        var stripeKey = Environment.GetEnvironmentVariable("STRIPE_SECRET_KEY")
            ?? Configuration["Stripe:SecretKey"] ?? "";
        stripeEnabled = !string.IsNullOrEmpty(stripeKey);

        await LoadData();

        // Verify pending payments on return from Stripe
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["payment"] == "success" && stripeEnabled)
        {
            await VerifyPendingPayments();
            await LoadData();
        }

        loading = false;
    }

    private async Task VerifyPendingPayments()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var athleteIds = athletes.Select(a => a.Id).ToList();
        var pendingPayments = await db.Payments
            .Where(p => athleteIds.Contains(p.AthleteId) && p.Status == PaymentStatus.Pending && p.StripeSessionId != null)
            .ToListAsync();

        if (!pendingPayments.Any()) return;

        var sessionService = new Stripe.Checkout.SessionService();
        foreach (var payment in pendingPayments)
        {
            try
            {
                var session = await sessionService.GetAsync(payment.StripeSessionId);
                if (session.PaymentStatus == "paid" && payment.Status != PaymentStatus.Paid)
                {
                    payment.Status = PaymentStatus.Paid;
                    payment.PaidAt = DateTime.UtcNow;
                    payment.StripePaymentIntentId = session.PaymentIntentId;

                    // Notify on payment
                    var athlete = athletes.FirstOrDefault(a => a.Id == payment.AthleteId);
                    if (athlete != null)
                        _ = NotificationService.NotifyPayment(athlete.Name, payment.Amount, 0);
                }
            }
            catch
            {
                // Stripe session retrieval failed; skip
            }
        }
        await db.SaveChangesAsync();
    }

    private async Task LoadData()
    {
        if (userId == null) return;
        using var db = await DbFactory.CreateDbContextAsync();

        var parentLinks = await db.ParentLinks
            .Where(pl => pl.ParentUserId == userId && pl.IsClaimed)
            .ToListAsync();
        var athleteIds = parentLinks.Select(l => l.AthleteId).ToList();

        athletes = await db.Athletes.AsNoTracking()
            .Where(a => athleteIds.Contains(a.Id))
            .OrderBy(a => a.Name)
            .ToListAsync();

        var levelIds = athletes.Select(a => a.TeamLevelId).Distinct().ToList();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => levelIds.Contains(t.Id)).ToListAsync();

        // Filter to only published seasons
        var levelSeasonIds = teamLevels.Select(t => t.SeasonId).Distinct().ToList();
        var publishedSeasonIds = await db.Seasons.AsNoTracking()
            .Where(s => levelSeasonIds.Contains(s.Id) && s.IsPublished)
            .Select(s => s.Id)
            .ToListAsync();
        teamLevels = teamLevels.Where(t => publishedSeasonIds.Contains(t.SeasonId)).ToList();

        if (!teamLevels.Any() && athletes.Any())
        {
            budgetNotReady = true;
            return;
        }
        budgetNotReady = false;

        // Re-filter athletes to only those with published levels
        levelIds = teamLevels.Select(t => t.Id).ToList();
        athletes = athletes.Where(a => levelIds.Contains(a.TeamLevelId)).ToList();
        athleteItems = await db.AthleteItems.AsNoTracking().Where(i => levelIds.Contains(i.TeamLevelId)).ToListAsync();
        selections = await db.AthleteItemSelections.AsNoTracking().Where(s => athleteIds.Contains(s.AthleteId)).ToListAsync();
        payments = await db.Payments.AsNoTracking().Where(p => athleteIds.Contains(p.AthleteId)).ToListAsync();
        parentLinksData = await db.ParentLinks.AsNoTracking().Where(pl => pl.ParentUserId == userId && pl.IsClaimed).ToListAsync();

        // Load seasons and shared fees
        var seasonIds = teamLevels.Select(t => t.SeasonId).Distinct().ToList();
        seasons = await db.Seasons.AsNoTracking().Where(s => seasonIds.Contains(s.Id)).ToListAsync();
        sharedFees = await db.SharedFees.AsNoTracking()
            .Where(f => seasonIds.Contains(f.SeasonId) && f.IsIncludedInBudget)
            .ToListAsync();
        var sharedFeeIds = sharedFees.Select(f => f.Id).ToList();
        sharedFeeAssignments = await db.SharedFeeTeamLevelAssignments.AsNoTracking()
            .Where(a => sharedFeeIds.Contains(a.SharedFeeId))
            .ToListAsync();
        allSeasonLevels = await db.TeamLevels.AsNoTracking()
            .Where(t => seasonIds.Contains(t.SeasonId))
            .ToListAsync();

        // Load meets for upcoming events
        meets = await db.Meets.AsNoTracking().Where(m => seasonIds.Contains(m.SeasonId)).ToListAsync();
        meetLevelAssignments = await db.MeetTeamLevelAssignments.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).ToListAsync();

        expandedAthletes = athletes.Select(a => a.Id).ToHashSet();
        foreach (var a in athletes)
            customAmounts.TryAdd(a.Id, 0);
    }

    private async Task ToggleSelection(int athleteId, int itemId, bool isChecked)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        if (isChecked)
        {
            if (!await db.AthleteItemSelections.AnyAsync(s => s.AthleteId == athleteId && s.AthleteItemId == itemId))
                db.AthleteItemSelections.Add(new AthleteItemSelection { AthleteId = athleteId, AthleteItemId = itemId });
        }
        else
        {
            var existing = await db.AthleteItemSelections.FirstOrDefaultAsync(s => s.AthleteId == athleteId && s.AthleteItemId == itemId);
            if (existing != null) db.AthleteItemSelections.Remove(existing);
        }
        await db.SaveChangesAsync();

        // Send notification email
        var athlete = await db.Athletes.FindAsync(athleteId);
        var item = await db.AthleteItems.FindAsync(itemId);
        if (athlete != null && item != null)
        {
            await LoadData();
            var levelItems = athleteItems.Where(i => i.TeamLevelId == athlete.TeamLevelId).ToList();
            var reqCost = levelItems.Where(i => i.IsRequired).Sum(i => i.Cost);
            var selIds = selections.Where(s => s.AthleteId == athleteId).Select(s => s.AthleteItemId).ToHashSet();
            var optCost = levelItems.Where(i => !i.IsRequired && selIds.Contains(i.Id)).Sum(i => i.Cost);
            var sharedCost = GetSharedFeeCostPerAthlete(athlete.TeamLevelId);
            var totalCost = reqCost + optCost + sharedCost;
            var paid = payments.Where(p => p.AthleteId == athleteId && p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).Sum(p => p.Amount);
            var credits = payments.Where(p => p.AthleteId == athleteId && p.Type == PaymentType.Credit).Sum(p => p.Amount);
            var balance = totalCost - paid - credits;
            _ = NotificationService.NotifyItemChange(athlete.Name, item.Name, item.Cost, isChecked, balance);
            return;
        }
        await LoadData();
    }

    private decimal GetSharedFeeCostPerAthlete(int teamLevelId)
    {
        var level = allSeasonLevels.FirstOrDefault(t => t.Id == teamLevelId);
        if (level == null) return 0;

        // Get season's total athlete count
        var season = seasons.FirstOrDefault(s => s.Id == level.SeasonId);
        var totalAthletes = season?.AthleteCount ?? 0;
        if (totalAthletes == 0) return 0;

        // Sum all shared fees assigned to this level
        decimal total = 0;
        foreach (var fee in sharedFees)
        {
            var assignedLevelIds = sharedFeeAssignments
                .Where(a => a.SharedFeeId == fee.Id)
                .Select(a => a.TeamLevelId).ToList();
            if (assignedLevelIds.Count == 0)
                assignedLevelIds = allSeasonLevels.Where(t => t.SeasonId == fee.SeasonId).Select(t => t.Id).ToList();
            if (!assignedLevelIds.Contains(teamLevelId)) continue;

            total += Math.Round(fee.Amount / totalAthletes, 2);
        }
        return total;
    }

    private async Task EnableAutoPay(Athlete athlete, decimal monthlyAmount)
    {
        paymentError = null;
        isProcessing = true;

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var link = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == athlete.Id && pl.ParentUserId == userId);
            if (link == null) { isProcessing = false; return; }

            var levelName = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "Program";

            // Create Stripe Customer if not exists
            if (string.IsNullOrEmpty(link.StripeCustomerId))
            {
                var customerService = new Stripe.CustomerService();
                var customer = await customerService.CreateAsync(new Stripe.CustomerCreateOptions
                {
                    Email = userEmail,
                    Name = athlete.Name,
                    Metadata = new Dictionary<string, string> { { "athleteId", athlete.Id.ToString() } }
                });
                link.StripeCustomerId = customer.Id;
                await db.SaveChangesAsync();
            }

            // Create Stripe Checkout in subscription mode
            var options = new Stripe.Checkout.SessionCreateOptions
            {
                Customer = link.StripeCustomerId,
                PaymentMethodTypes = new List<string> { "card" },
                LineItems = new List<Stripe.Checkout.SessionLineItemOptions>
                {
                    new()
                    {
                        PriceData = new Stripe.Checkout.SessionLineItemPriceDataOptions
                        {
                            UnitAmount = (long)(monthlyAmount * 100),
                            Currency = "usd",
                            Recurring = new Stripe.Checkout.SessionLineItemPriceDataRecurringOptions
                            {
                                Interval = "month",
                            },
                            ProductData = new Stripe.Checkout.SessionLineItemPriceDataProductDataOptions
                            {
                                Name = $"{athlete.Name} - {levelName} Monthly Auto-Pay",
                            },
                        },
                        Quantity = 1,
                    },
                },
                Mode = "subscription",
                SuccessUrl = Navigation.BaseUri + "parent?autopay=enabled",
                CancelUrl = Navigation.BaseUri + "parent?autopay=cancelled",
                SubscriptionData = new Stripe.Checkout.SessionSubscriptionDataOptions
                {
                    BillingCycleAnchor = GetNext15th(),
                    Metadata = new Dictionary<string, string>
                    {
                        { "cancel_after_months", GetPlanMonths(athlete.TeamLevelId).ToString() },
                        { "athlete_id", athlete.Id.ToString() }
                    },
                },
            };

            var service = new Stripe.Checkout.SessionService();
            var session = await service.CreateAsync(options);

            link.AutoPayEnabled = true;
            var subscriptionId = session.SubscriptionId ?? session.Id;
            link.StripeSubscriptionId = subscriptionId;
            await db.SaveChangesAsync();

            // Set auto-cancel date on subscription
            if (!string.IsNullOrEmpty(session.SubscriptionId))
            {
                try
                {
                    var subService = new Stripe.SubscriptionService();
                    var planMonths = GetPlanMonths(athlete.TeamLevelId);
                    var cancelAt = GetNext15th().AddMonths(planMonths);
                    await subService.UpdateAsync(session.SubscriptionId, new Stripe.SubscriptionUpdateOptions
                    {
                        CancelAt = cancelAt,
                    });
                }
                catch { /* Non-critical, subscription still works */ }
            }

            _ = NotificationService.NotifyAutoPayEnabled(athlete.Name, userEmail ?? "", monthlyAmount);

            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            paymentError = $"Auto-pay error: {ex.Message}";
            isProcessing = false;
        }
    }

    private async Task DisableAutoPay(int athleteId)
    {
        isProcessing = true;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var link = await db.ParentLinks.FirstOrDefaultAsync(pl => pl.AthleteId == athleteId && pl.ParentUserId == userId);
            if (link == null) { isProcessing = false; return; }

            // Cancel Stripe subscription
            if (!string.IsNullOrEmpty(link.StripeSubscriptionId))
            {
                try
                {
                    var subService = new Stripe.SubscriptionService();
                    await subService.CancelAsync(link.StripeSubscriptionId);
                }
                catch { /* Subscription may already be cancelled */ }
            }

            link.AutoPayEnabled = false;
            link.StripeSubscriptionId = null;
            await db.SaveChangesAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            paymentError = $"Error disabling auto-pay: {ex.Message}";
        }
        isProcessing = false;
    }

    private int GetPlanMonths(int teamLevelId)
    {
        var level = teamLevels.FirstOrDefault(t => t.Id == teamLevelId);
        return level?.PaymentPlanMonths > 0 ? level.PaymentPlanMonths : 8;
    }

    private DateTime GetNext15th()
    {
        var now = DateTime.UtcNow;
        var next15 = new DateTime(now.Year, now.Month, 15, 0, 0, 0, DateTimeKind.Utc);
        if (now.Day >= 15) next15 = next15.AddMonths(1);
        return next15;
    }

    private string? userEmail;

    private async Task StartPayment(Athlete athlete, decimal amount)
    {
        paymentError = null;
        isProcessing = true;

        try
        {
            var publishableKey = Environment.GetEnvironmentVariable("STRIPE_PUBLISHABLE_KEY")
                ?? Configuration["Stripe:PublishableKey"] ?? "";
            if (string.IsNullOrEmpty(publishableKey))
            {
                paymentError = "Stripe is not configured. Contact your administrator.";
                isProcessing = false;
                return;
            }

            var levelName = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "Program";

            var options = new Stripe.Checkout.SessionCreateOptions
            {
                PaymentMethodTypes = new List<string> { "card" },
                LineItems = new List<Stripe.Checkout.SessionLineItemOptions>
                {
                    new()
                    {
                        PriceData = new Stripe.Checkout.SessionLineItemPriceDataOptions
                        {
                            UnitAmount = (long)(amount * 100),
                            Currency = "usd",
                            ProductData = new Stripe.Checkout.SessionLineItemPriceDataProductDataOptions
                            {
                                Name = $"{athlete.Name} - {levelName} Fees",
                            },
                        },
                        Quantity = 1,
                    },
                },
                Mode = "payment",
                SuccessUrl = Navigation.BaseUri + "parent?payment=success",
                CancelUrl = Navigation.BaseUri + "parent?payment=cancelled",
            };

            var service = new Stripe.Checkout.SessionService();
            var session = await service.CreateAsync(options);

            // Record pending payment
            using var db = await DbFactory.CreateDbContextAsync();
            db.Payments.Add(new Payment
            {
                AthleteId = athlete.Id,
                PayerUserId = userId!,
                Amount = amount,
                Status = PaymentStatus.Pending,
                StripeSessionId = session.Id,
                Description = $"{athlete.Name} - {levelName} Fees"
            });
            await db.SaveChangesAsync();

            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            paymentError = $"Payment error: {ex.Message}";
            isProcessing = false;
        }
    }
}
