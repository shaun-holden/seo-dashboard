    private async Task SaveParentProfile(int athleteId)
    {
        profileSaveMessages.Remove(athleteId);
        if (!profileEdits.TryGetValue(athleteId, out var edits)) return;

        using var db = await DbFactory.CreateDbContextAsync();

        // Save to Gymnast record (sizes, emails)
        var gymnast = await db.Gymnasts.FindAsync(athleteId);
        if (gymnast != null)
        {
            gymnast.ShirtSize = edits.GetValueOrDefault("shirtSize");
            gymnast.LeotardSize = edits.GetValueOrDefault("leotardSize");
            gymnast.LeggingsSize = edits.GetValueOrDefault("leggingsSize");
            gymnast.PantsSize = edits.GetValueOrDefault("pantsSize");
            gymnast.ModifiedAt = DateTime.UtcNow;
        }

        // Also save to Athlete record if it exists (DOB, emergency info)
        var athlete = await db.Athletes.FindAsync(athleteId);
        if (athlete != null)
        {
            if (edits.TryGetValue("dob", out var dobStr) && DateTime.TryParse(dobStr, out var dob))
                athlete.DateOfBirth = dob;
            else if (string.IsNullOrEmpty(dobStr))
                athlete.DateOfBirth = null;

            athlete.ParentPhone = edits.GetValueOrDefault("parentPhone");
            athlete.Address = edits.GetValueOrDefault("address");
            athlete.EmergencyContactName = edits.GetValueOrDefault("emergencyName");
            athlete.EmergencyContactPhone = edits.GetValueOrDefault("emergencyPhone");
            athlete.EmergencyContactRelationship = edits.GetValueOrDefault("emergencyRelationship");
            athlete.MedicalNotes = edits.GetValueOrDefault("medicalNotes");
            athlete.ModifiedAt = DateTime.UtcNow;
        }

        await db.SaveChangesAsync();
        profileSaveMessages[athleteId] = "Profile saved!";
        await LoadData();
    }

    private decimal GetSharedFeeCostPerAthlete(int teamLevelId)
    {
        var level = allSeasonLevels.FirstOrDefault(t => t.Id == teamLevelId);
        if (level == null) return 0;

        // Get season's total athlete count
        var season = seasons.FirstOrDefault(s => s.Id == level.SeasonId);
        var totalAthletes = season?.AthleteCount ?? 0;
        if (totalAthletes == 0) return 0;

        // Sum all shared fees assigned to this level
        decimal total = 0;
        foreach (var fee in sharedFees)
        {
            var assignedLevelIds = sharedFeeAssignments
                .Where(a => a.SharedFeeId == fee.Id)
                .Select(a => a.TeamLevelId).ToList();
            if (assignedLevelIds.Count == 0)
                assignedLevelIds = allSeasonLevels.Where(t => t.SeasonId == fee.SeasonId).Select(t => t.Id).ToList();
            if (!assignedLevelIds.Contains(teamLevelId)) continue;

            total += Math.Round(fee.Amount / totalAthletes, 2);
        }
        return total;
    }

