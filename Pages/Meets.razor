@page "/meets"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.NotesPanelState NotesPanelState

<h3>@labels.Meets</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id" selected="@(s.Id == selectedSeasonId)">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <button class="btn btn-primary" @onclick="ShowForm">+ Add @labels.Meet</button>
            <select class="form-select" style="max-width: 170px;" value="@filterTravelType"
                    @onchange="OnFilterTravelChanged">
                <option value="all">All Travel</option>
                <option value="Drive">Drive</option>
                <option value="Fly">Fly</option>
            </select>
            @if (seasonGroups.Any())
            {
                <select class="form-select" style="max-width: 170px;" value="@filterGroupId"
                        @onchange="OnFilterGroupChanged">
                    <option value="0">All Groups</option>
                    <option value="-1">Ungrouped</option>
                    @foreach (var g in seasonGroups)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            }
        </div>

        @if (showForm)
        {
            <div class="card mb-4 p-3">
                <h5>@(editingMeet == null ? $"Add {labels.Meet}" : $"Edit {labels.Meet}")</h5>
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <label>@labels.Meet Name</label>
                        <input class="form-control" @bind="formName" placeholder="@($"e.g. {labels.Meet} 1")" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Date</label>
                        <input type="date" class="form-control" @bind="formDate" />
                    </div>
                    <div class="col-md-2 mb-2">
                        <label>Travel Type</label>
                        <select class="form-select" @bind="formTravelType">
                            <option value="Drive">Drive</option>
                            <option value="Fly">Fly</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Budget Amount</label>
                        <input type="number" step="0.01" class="form-control" @bind="formBudgetAmount" placeholder="0.00" />
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-6 mb-2">
                        <label>Venue Address</label>
                        <input class="form-control" @bind="formAddress" placeholder="e.g. 123 Main St, Atlanta, GA 30301" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Entry Cost</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" class="form-control" @bind="formEntryCost" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label>Parking Cost</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" class="form-control" @bind="formParkingCost" placeholder="0.00" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <label>Competition Schedule</label>
                        <textarea class="form-control" rows="3" @bind="formSchedule" placeholder="e.g. Level 3: 9:00 AM, Level 4: 11:00 AM..."></textarea>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label>Hotel Info</label>
                        <input class="form-control" @bind="formHotelInfo" placeholder="e.g. Marriott, 123 Hotel Rd, $129/night" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 mb-2">
                        <label>Notes for Parents</label>
                        <textarea class="form-control" rows="3" @bind="formParentNotes" placeholder="e.g. Arrive 30 min early. Bring water and snacks. Spectator fee is $10."></textarea>
                    </div>
                </div>
                @if (seasonGroups.Any())
                {
                    <div class="mt-2 mb-2 p-2 bg-light rounded">
                        <label class="fw-bold mb-1">Groups (optional)</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var g in seasonGroups)
                            {
                                var gId = g.Id;
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@formGroupIds.Contains(gId)"
                                           @onchange="(e) => ToggleFormGroup(gId, (bool)e.Value!)" />
                                    <label class="form-check-label">@g.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                }
                <button class="btn btn-success me-2" @onclick="SaveMeet">Save</button>
                <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        }

        @if (!filteredMeets.Any() && meets.Any())
        {
            <div class="alert alert-info">No @labels.Meets.ToLower() match your search.</div>
        }
        @foreach (var meet in filteredMeets)
        {
            @RenderMeetCard(meet)
        }
    }
}

@code {
    private List<Season>? seasons;
    private List<Meet> meets = new();
    private List<SeasonGroup> seasonGroups = new();
    private List<MeetGroupAssignment> groupAssignments = new();
    private List<MeetTeamLevelAssignment> teamLevelAssignments = new();
    private List<TeamLevel> teamLevels = new();
    private List<Athlete> allAthletes = new();
    private List<EventRsvp> eventRsvps = new();
    private HashSet<int> expandedMeets = new();
    private HashSet<int> rsvpExpandedMeets = new();
    private int selectedSeasonId;
    private bool showForm;
    private Meet? editingMeet;
    private string formName = "";
    private DateTime formDate = DateTime.Today;
    private TravelType formTravelType = TravelType.Drive;
    private decimal formBudgetAmount = 0;
    private string formAddress = "";
    private decimal formEntryCost = 0;
    private decimal formParkingCost = 0;
    private string formSchedule = "";
    private string formHotelInfo = "";
    private string formParentNotes = "";
    private HashSet<int> formGroupIds = new();
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;
    private string filterTravelType = "all";
    private int filterGroupId = 0;

    private List<Meet> filteredMeets => meets.Where(m =>
    {
        if (filterTravelType == "Drive" && m.TravelType != TravelType.Drive) return false;
        if (filterTravelType == "Fly" && m.TravelType != TravelType.Fly) return false;
        if (filterGroupId == -1)
        {
            if (groupAssignments.Any(a => a.MeetId == m.Id)) return false;
        }
        else if (filterGroupId > 0)
        {
            if (!groupAssignments.Any(a => a.MeetId == m.Id && a.SeasonGroupId == filterGroupId)) return false;
        }
        return true;
    }).ToList();

    // Bulk assign state
    private int? bulkAssignMeetId;
    private HashSet<int> selectedGroupIds = new();

    private RenderFragment RenderMeetCard(Meet meet) => __builder =>
    {
        var meetAssignments = groupAssignments.Where(a => a.MeetId == meet.Id).ToList();
        var assignedGroups = seasonGroups.Where(g => meetAssignments.Any(a => a.SeasonGroupId == g.Id)).ToList();
        var meetLevelIds = teamLevelAssignments.Where(a => a.MeetId == meet.Id).Select(a => a.TeamLevelId).ToHashSet();
        var assignedLevels = teamLevels.Where(t => meetLevelIds.Contains(t.Id)).ToList();
        var isExpanded = expandedMeets.Contains(meet.Id);

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center"
                 @onclick="() => ToggleExpand(meet.Id)" style="cursor: pointer;">
                <div>
                    <strong>@meet.Name</strong>
                    <span class="text-muted ms-2">@meet.Date.ToString("MM/dd/yyyy")</span>
                    <span class="badge bg-@(meet.TravelType == TravelType.Fly ? "info" : "secondary") ms-2">@meet.TravelType</span>
                    @if (meet.BudgetAmount > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">$@meet.BudgetAmount.ToString("N2")</span>
                    }
                    @if (assignedGroups.Any())
                    {
                        <span class="badge bg-success ms-1">@assignedGroups.Count group(s)</span>
                    }
                    @if (assignedLevels.Any())
                    {
                        <span class="badge bg-primary ms-1">@assignedLevels.Count @(labels.TeamLevels)</span>
                    }
                </div>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditMeet(meet)" @onclick:stopPropagation="true">Edit</button>
                    <button class="btn btn-sm btn-outline-danger me-2" @onclick="() => DeleteMeet(meet)" @onclick:stopPropagation="true">Delete</button>
                    <span class="oi @(isExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
                </div>
            </div>

            @if (isExpanded)
            {
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(meet.Address))
                    {
                        <div class="mb-3">
                            <h6>Venue</h6>
                            <p class="mb-1">@meet.Address</p>
                            <a href="https://www.google.com/maps/search/?api=1&query=@(Uri.EscapeDataString(meet.Address))" target="_blank" class="btn btn-sm btn-outline-primary">
                                <span class="oi oi-map-marker me-1"></span> Open in Google Maps
                            </a>
                        </div>
                    }
                    @if (meet.EntryCost.HasValue || meet.ParkingCost.HasValue)
                    {
                        <div class="d-flex gap-3 mb-3">
                            @if (meet.EntryCost.HasValue)
                            {
                                <span class="badge bg-info p-2">Entry: $@meet.EntryCost.Value.ToString("N2")</span>
                            }
                            @if (meet.ParkingCost.HasValue)
                            {
                                <span class="badge bg-secondary p-2">Parking: $@meet.ParkingCost.Value.ToString("N2")</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(meet.CompetitionSchedule))
                    {
                        <div class="mb-3">
                            <h6>Competition Schedule</h6>
                            <pre class="bg-light p-2 rounded" style="white-space: pre-wrap; font-size: 0.9rem;">@meet.CompetitionSchedule</pre>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(meet.HotelInfo))
                    {
                        <div class="mb-3">
                            <h6>Hotel Info</h6>
                            <p class="mb-0">@meet.HotelInfo</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(meet.ParentNotes))
                    {
                        <div class="mb-3">
                            <h6>Notes for Parents</h6>
                            <div class="alert alert-warning mb-0" style="white-space: pre-wrap;">@meet.ParentNotes</div>
                        </div>
                    }
                    <h6>Assigned Groups</h6>
                    @if (assignedGroups.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var group in assignedGroups)
                            {
                                <span class="badge bg-primary d-flex align-items-center gap-1 p-2">
                                    @group.Name
                                    <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;"
                                            @onclick="() => RemoveGroupAssignment(meet.Id, group.Id)"></button>
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No groups assigned yet.</p>
                    }

                    <h6>Assigned @labels.TeamLevels</h6>
                    @if (assignedLevels.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var level in assignedLevels)
                            {
                                <span class="badge bg-primary p-2">@level.Name</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No @labels.TeamLevels assigned yet. Assign from the @labels.TeamLevels page.</p>
                    }

                    @if (seasonGroups.Any())
                    {
                        var unassignedGroups = seasonGroups.Where(g => !meetAssignments.Any(a => a.SeasonGroupId == g.Id)).ToList();
                        @if (unassignedGroups.Any())
                        {
                            <div class="mt-2 p-2 bg-light rounded">
                                <h6>Assign Groups</h6>
                                <div class="d-flex flex-wrap gap-3 mb-2">
                                    @foreach (var group in unassignedGroups)
                                    {
                                        var gId = group.Id;
                                        var isSelected = bulkAssignMeetId == meet.Id && selectedGroupIds.Contains(gId);
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" checked="@isSelected"
                                                   @onchange="(e) => ToggleGroupSelection(meet.Id, gId, (bool)e.Value!)" />
                                            <label class="form-check-label">@group.Name</label>
                                        </div>
                                    }
                                </div>
                                <button class="btn btn-sm btn-success me-1"
                                        disabled="@(bulkAssignMeetId != meet.Id || !selectedGroupIds.Any())"
                                        @onclick="() => BulkAssignGroups(meet.Id)">
                                    Assign Selected (@(bulkAssignMeetId == meet.Id ? selectedGroupIds.Count : 0))
                                </button>
                                <button class="btn btn-sm btn-outline-secondary me-1"
                                        @onclick="() => SelectAllGroups(meet.Id, unassignedGroups)">Select All</button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="DeselectAllGroups">Deselect All</button>
                            </div>
                        }
                    }

                    @{
                        var rsvpLevelIds = meetLevelIds.Any() ? meetLevelIds : teamLevels.Select(t => t.Id).ToHashSet();
                        var meetAthletes = allAthletes.Where(a => rsvpLevelIds.Contains(a.TeamLevelId)).ToList();
                        var meetRsvps = eventRsvps.Where(r => r.MeetId == meet.Id).ToList();
                        var goingCount = meetRsvps.Count(r => r.Status == RsvpStatus.Going);
                        var notGoingCount = meetRsvps.Count(r => r.Status == RsvpStatus.NotGoing);
                        var maybeCount = meetRsvps.Count(r => r.Status == RsvpStatus.Maybe);
                        var noResponseCount = meetAthletes.Count - meetRsvps.Count(r => r.Status != RsvpStatus.NoResponse);
                        var isRsvpExpanded = rsvpExpandedMeets.Contains(meet.Id);
                    }
                    <div class="mt-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <h6 class="mb-0">RSVPs</h6>
                            <span class="badge bg-success">@goingCount Going</span>
                            <span class="badge bg-warning text-dark">@maybeCount Maybe</span>
                            <span class="badge bg-danger">@notGoingCount Not Going</span>
                            <span class="badge bg-secondary">@noResponseCount No Response</span>
                            <span class="text-muted">(@meetAthletes.Count total)</span>
                            <button class="btn btn-sm btn-outline-info ms-2" @onclick="() => ToggleRsvpExpand(meet.Id)" @onclick:stopPropagation="true">
                                @(isRsvpExpanded ? "Hide RSVPs" : "View RSVPs")
                            </button>
                        </div>
                        @if (isRsvpExpanded)
                        {
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Athlete</th>
                                        <th>Level</th>
                                        <th>Status</th>
                                        <th>Note</th>
                                        <th>Updated</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var athlete in meetAthletes.OrderBy(a => a.Name))
                                    {
                                        var rsvp = meetRsvps.FirstOrDefault(r => r.AthleteId == athlete.Id);
                                        var status = rsvp?.Status ?? RsvpStatus.NoResponse;
                                        var badgeClass = status == RsvpStatus.Going ? "bg-success"
                                            : status == RsvpStatus.Maybe ? "bg-warning text-dark"
                                            : status == RsvpStatus.NotGoing ? "bg-danger"
                                            : "bg-secondary";
                                        <tr>
                                            <td>@athlete.Name</td>
                                            <td>@(teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "—")</td>
                                            <td><span class="badge @badgeClass">@status</span></td>
                                            <td>@(rsvp?.Note ?? "—")</td>
                                            <td>@(rsvp != null ? rsvp.UpdatedAt.ToLocalTime().ToString("MM/dd hh:mm tt") : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
        </div>
    };

    private void OnFilterTravelChanged(ChangeEventArgs e) { filterTravelType = e.Value?.ToString() ?? "all"; }
    private void OnFilterGroupChanged(ChangeEventArgs e) { filterGroupId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; }

    private void ToggleExpand(int meetId)
    {
        if (!expandedMeets.Remove(meetId))
            expandedMeets.Add(meetId);
    }

    private void ToggleRsvpExpand(int meetId)
    {
        if (!rsvpExpandedMeets.Remove(meetId))
            rsvpExpandedMeets.Add(meetId);
    }

    private void ToggleGroupSelection(int meetId, int groupId, bool isChecked)
    {
        if (bulkAssignMeetId != meetId)
        {
            bulkAssignMeetId = meetId;
            selectedGroupIds.Clear();
        }
        if (isChecked) selectedGroupIds.Add(groupId);
        else selectedGroupIds.Remove(groupId);
    }

    private void SelectAllGroups(int meetId, List<SeasonGroup> unassigned)
    {
        bulkAssignMeetId = meetId;
        selectedGroupIds = unassigned.Select(g => g.Id).ToHashSet();
    }

    private void DeselectAllGroups()
    {
        selectedGroupIds.Clear();
        bulkAssignMeetId = null;
    }

    private async Task BulkAssignGroups(int meetId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        foreach (var groupId in selectedGroupIds)
        {
            db.MeetGroupAssignments.Add(new MeetGroupAssignment { MeetId = meetId, SeasonGroupId = groupId });
        }
        await db.SaveChangesAsync();
        selectedGroupIds.Clear();
        bulkAssignMeetId = null;
        await LoadMeets();
    }

    private async Task RemoveGroupAssignment(int meetId, int groupId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var assignment = await db.MeetGroupAssignments.FirstOrDefaultAsync(a => a.MeetId == meetId && a.SeasonGroupId == groupId);
        if (assignment != null)
        {
            db.MeetGroupAssignments.Remove(assignment);
            await db.SaveChangesAsync();
            await LoadMeets();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        seasons = await Db.Seasons.Where(s => s.IsActive).OrderByDescending(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        NotesPanelState.SeasonId = selectedSeasonId;
        await LoadMeets();
    }

    private async Task LoadMeets()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        meets = await db.Meets.AsNoTracking().Where(m => m.SeasonId == selectedSeasonId).OrderBy(m => m.Date).ToListAsync();
        seasonGroups = await db.SeasonGroups.AsNoTracking().Where(g => g.SeasonId == selectedSeasonId).OrderBy(g => g.SortOrder).ToListAsync();
        var meetIds = meets.Select(m => m.Id).ToList();
        groupAssignments = await db.MeetGroupAssignments.AsNoTracking().Where(a => meetIds.Contains(a.MeetId)).ToListAsync();
        teamLevelAssignments = await db.MeetTeamLevelAssignments.AsNoTracking().Where(a => meetIds.Contains(a.MeetId)).ToListAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var tlIds = teamLevels.Select(t => t.Id).ToList();
        allAthletes = await db.Athletes.AsNoTracking().Where(a => tlIds.Contains(a.TeamLevelId)).ToListAsync();
        eventRsvps = await db.EventRsvps.AsNoTracking().Where(r => meetIds.Contains(r.MeetId)).ToListAsync();
    }

    private void ToggleFormGroup(int groupId, bool isChecked)
    {
        if (isChecked) formGroupIds.Add(groupId);
        else formGroupIds.Remove(groupId);
    }

    private void ShowForm() { editingMeet = null; formName = ""; formDate = DateTime.Today; formTravelType = TravelType.Drive; formBudgetAmount = 0; formAddress = ""; formEntryCost = 0; formParkingCost = 0; formSchedule = ""; formHotelInfo = ""; formParentNotes = ""; formGroupIds.Clear(); showForm = true; }
    private void CancelForm() { showForm = false; }

    private void EditMeet(Meet meet)
    {
        editingMeet = meet; formName = meet.Name; formDate = meet.Date; formTravelType = meet.TravelType; formBudgetAmount = meet.BudgetAmount;
        formAddress = meet.Address ?? ""; formEntryCost = meet.EntryCost ?? 0; formParkingCost = meet.ParkingCost ?? 0; formSchedule = meet.CompetitionSchedule ?? ""; formHotelInfo = meet.HotelInfo ?? ""; formParentNotes = meet.ParentNotes ?? "";
        formGroupIds = groupAssignments.Where(a => a.MeetId == meet.Id).Select(a => a.SeasonGroupId).ToHashSet();
        showForm = true;
    }

    private async Task SaveMeet()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        Meet meet;
        if (editingMeet == null)
        {
            meet = new Meet { Name = formName, Date = formDate, TravelType = formTravelType, BudgetAmount = formBudgetAmount, SeasonId = selectedSeasonId, SeasonGroupId = formGroupIds.Any() ? formGroupIds.First() : null, Address = string.IsNullOrWhiteSpace(formAddress) ? null : formAddress.Trim(), EntryCost = formEntryCost > 0 ? formEntryCost : null, ParkingCost = formParkingCost > 0 ? formParkingCost : null, CompetitionSchedule = string.IsNullOrWhiteSpace(formSchedule) ? null : formSchedule.Trim(), HotelInfo = string.IsNullOrWhiteSpace(formHotelInfo) ? null : formHotelInfo.Trim(), ParentNotes = string.IsNullOrWhiteSpace(formParentNotes) ? null : formParentNotes.Trim() };
            db.Meets.Add(meet);
            await db.SaveChangesAsync();
        }
        else
        {
            meet = await db.Meets.FindAsync(editingMeet.Id) ?? editingMeet;
            meet.Name = formName; meet.Date = formDate; meet.TravelType = formTravelType; meet.BudgetAmount = formBudgetAmount; meet.SeasonGroupId = formGroupIds.Any() ? formGroupIds.First() : null;
            meet.Address = string.IsNullOrWhiteSpace(formAddress) ? null : formAddress.Trim(); meet.EntryCost = formEntryCost > 0 ? formEntryCost : null; meet.ParkingCost = formParkingCost > 0 ? formParkingCost : null; meet.CompetitionSchedule = string.IsNullOrWhiteSpace(formSchedule) ? null : formSchedule.Trim(); meet.HotelInfo = string.IsNullOrWhiteSpace(formHotelInfo) ? null : formHotelInfo.Trim(); meet.ParentNotes = string.IsNullOrWhiteSpace(formParentNotes) ? null : formParentNotes.Trim();
            var existing = db.MeetGroupAssignments.Where(a => a.MeetId == meet.Id).ToList();
            db.MeetGroupAssignments.RemoveRange(existing);
            await db.SaveChangesAsync();
        }
        foreach (var gId in formGroupIds)
        {
            if (!db.MeetGroupAssignments.Any(a => a.MeetId == meet.Id && a.SeasonGroupId == gId))
                db.MeetGroupAssignments.Add(new MeetGroupAssignment { MeetId = meet.Id, SeasonGroupId = gId });
        }
        await db.SaveChangesAsync();
        await LoadMeets();
        showForm = false;
    }

    private async Task DeleteMeet(Meet meet)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Meets.FindAsync(meet.Id);
        if (entity != null) { db.Meets.Remove(entity); await db.SaveChangesAsync(); }
        await LoadMeets();
    }
}
