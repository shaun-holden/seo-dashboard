@page "/"
@attribute [Authorize]
@using System.Security.Claims
@using GymBudgetApp
@using GymBudgetApp.Models
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AppDbContext Db
@inject IConfiguration Configuration
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

<h3>Dashboard</h3>

<AuthorizeView>
    <Authorized>
        <p>Welcome, <strong>@context.User.Identity?.Name</strong>!</p>
    </Authorized>
</AuthorizeView>

@if (activeSeason != null)
{
    <div class="alert alert-info mb-3">
        <strong>Active Season:</strong> @activeSeason.Name
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary h-100">
                <div class="card-body">
                    <h6 class="card-title">@labels.Meets</h6>
                    <h3>@meetCount</h3>
                    @if (nextMeet != null)
                    {
                        <small>Next: @nextMeet.Name (@nextMeet.Date.ToString("MM/dd"))</small>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info h-100">
                <div class="card-body">
                    <h6 class="card-title">Total Budget</h6>
                    <h3>$@totalBudget.ToString("N2")</h3>
                    <small>@budgetItemCount line items</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning h-100">
                <div class="card-body">
                    <h6 class="card-title">Cost Per Gymnast</h6>
                    @if (totalAthletes > 0 && totalBudget > 0)
                    {
                        <h3>$@((totalBudget / totalAthletes).ToString("N2"))</h3>
                        <small>@totalAthletes gymnasts</small>
                    }
                    else
                    {
                        <h3>--</h3>
                        <small>Set athlete count in Seasons</small>
                    }
                </div>
            </div>
        </div>
    </div>
}

<div class="row mt-3">
    <div class="col-md-4 mb-3">
        <a href="/seasons" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><span class="oi oi-calendar me-2"></span>Seasons</h5>
                    <p class="card-text text-muted">Create and manage your budget seasons.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/meets" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><span class="oi oi-map-marker me-2"></span>@labels.Meets</h5>
                    <p class="card-text text-muted">Add and track @labels.Meets.ToLower().</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/coaches" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><span class="oi oi-people me-2"></span>@labels.Coaches</h5>
                    <p class="card-text text-muted">Manage your @labels.Coaches.ToLower().</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/budget" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><span class="oi oi-dollar me-2"></span>Budget</h5>
                    <p class="card-text text-muted">Enter budgeted and actual expenses.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/reports" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><span class="oi oi-document me-2"></span>Reports</h5>
                    <p class="card-text text-muted">View budget vs. actual reports.</p>
                </div>
            </div>
        </a>
    </div>
    @if (labels.EnableTeamLevels)
    {
        <div class="col-md-4 mb-3">
            <a href="/teamlevels" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><span class="oi oi-star me-2"></span>@labels.TeamLevels</h5>
                        <p class="card-text text-muted">Set up @labels.TeamLevels.ToLower() and payment plans.</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@code {
    private ProjectLabels labels = ProjectLabels.Default;
    private Season? activeSeason;
    private int meetCount;
    private int coachCount;
    private int activeCoachCount;
    private decimal totalBudget;
    private int budgetItemCount;
    private int totalAthletes;
    private int teamLevelCount;
    private Meet? nextMeet;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;
        var adminEmails = Configuration.GetSection("AdminEmails").Get<List<string>>() ?? new() { Configuration["AdminEmail"] ?? "deshaun@tntgym.org" };
        var isAdmin = adminEmails.Any(ae => string.Equals(email, ae, StringComparison.OrdinalIgnoreCase))
                      || authState.User.IsInRole("Employee");
        var isParent = authState.User.IsInRole("Parent");

        if (isParent && !isAdmin)
        {
            Navigation.NavigateTo("/parent", replace: true);
            return;
        }

        if (userId != null)
        {
            activeSeason = await Db.Seasons.Where(s => s.IsActive).FirstOrDefaultAsync();
            labels = new ProjectLabels(activeSeason);

            if (activeSeason != null)
            {
                var seasonId = activeSeason.Id;
                meetCount = await Db.Meets.CountAsync(m => m.SeasonId == seasonId);
                coachCount = await Db.Coaches.CountAsync(c => c.SeasonId == seasonId);
                activeCoachCount = await Db.Coaches.CountAsync(c => c.SeasonId == seasonId && c.IsActive);
                budgetItemCount = await Db.BudgetLineItems.CountAsync(b => b.SeasonId == seasonId);

                // Use calculator total if available, fall back to shared fees + athlete items
                var calcTotal = await Db.BudgetCalculatorEntries
                    .Where(e => e.SeasonId == seasonId)
                    .SumAsync(e => (decimal?)e.CalculatedTotal) ?? 0;

                if (calcTotal > 0)
                {
                    totalBudget = calcTotal;
                }
                else
                {
                    var sharedFeesTotal = await Db.SharedFees
                        .Where(f => f.SeasonId == seasonId && f.IsIncludedInBudget)
                        .SumAsync(f => (decimal?)f.Amount) ?? 0;
                    var levelIds2 = await Db.TeamLevels.Where(t => t.SeasonId == seasonId).Select(t => t.Id).ToListAsync();
                    var athleteItemsTotal = await Db.AthleteItems
                        .Where(a => levelIds2.Contains(a.TeamLevelId))
                        .SumAsync(a => (decimal?)a.Cost) ?? 0;
                    totalBudget = sharedFeesTotal + athleteItemsTotal;
                }

                totalAthletes = activeSeason.AthleteCount;

                nextMeet = await Db.Meets
                    .Where(m => m.SeasonId == seasonId && m.Date >= DateTime.Today)
                    .OrderBy(m => m.Date)
                    .FirstOrDefaultAsync();
            }
        }
    }
}
