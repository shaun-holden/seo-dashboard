@page "/payments"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Payment Tracking</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6>Total Owed</h6>
                        <h4>$@totalOwed.ToString("N2")</h4>
                        <small>@athletes.Count athlete(s)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6>Total Collected</h6>
                        <h4>$@totalPaid.ToString("N2")</h4>
                        <small>@paidPayments.Count payment(s)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6>Outstanding</h6>
                        <h4>$@((totalOwed - totalPaid).ToString("N2"))</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6>Collection Rate</h6>
                        <h4>@(totalOwed > 0 ? (totalPaid / totalOwed * 100).ToString("N0") : "0")%</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- Apply Credit -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Apply Credit</h5>
                <button class="btn btn-sm @(showCreditForm ? "btn-outline-secondary" : "btn-success")" @onclick="() => showCreditForm = !showCreditForm">
                    @(showCreditForm ? "Cancel" : "+ Apply Credit")
                </button>
            </div>
            @if (showCreditForm)
            {
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Athlete</label>
                            <select class="form-select" @bind="creditAthleteId">
                                <option value="0">-- Select Athlete --</option>
                                @foreach (var a in athletes)
                                {
                                    var lvl = teamLevels.FirstOrDefault(t => t.Id == a.TeamLevelId)?.Name ?? "";
                                    <option value="@a.Id">@a.Name (@lvl)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" min="0.01" step="0.01" @bind="creditAmount" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Reason</label>
                            <input type="text" class="form-control" placeholder="e.g. Overpayment, sibling discount" @bind="creditDescription" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-success w-100" @onclick="ApplyCredit"
                                    disabled="@(creditAthleteId == 0 || creditAmount <= 0)">
                                Apply Credit
                            </button>
                        </div>
                    </div>
                    @if (creditMessage != null)
                    {
                        <div class="alert alert-success mt-3 mb-0">@creditMessage</div>
                    }
                </div>
            }
        </div>

        <!-- Recent Credits -->
        @if (payments.Any(p => p.Type == PaymentType.Credit))
        {
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0">Recent Credits</h5></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Athlete</th><th>Amount</th><th>Reason</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in payments.Where(p => p.Type == PaymentType.Credit).OrderByDescending(p => p.PaidAt).Take(5))
                            {
                                var aName = athletes.FirstOrDefault(a => a.Id == c.AthleteId)?.Name ?? "Unknown";
                                <tr>
                                    <td>@aName</td>
                                    <td class="text-success">-$@c.Amount.ToString("N2")</td>
                                    <td>@c.Description</td>
                                    <td>@(c.PaidAt?.ToString("MMM dd, yyyy") ?? c.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header"><h5 class="mb-0">Athlete Payment Status</h5></div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Athlete</th>
                            <th>@labels.TeamLevel</th>
                            <th class="text-end">Total Fees</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Balance</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Parent Linked</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var athlete in athletes)
                        {
                            var levelItems = athleteItems.Where(i => i.TeamLevelId == athlete.TeamLevelId).ToList();
                            var requiredCost = levelItems.Where(i => i.IsRequired).Sum(i => i.Cost);
                            var athleteSel = selections.Where(s => s.AthleteId == athlete.Id).Select(s => s.AthleteItemId).ToHashSet();
                            var optionalCost = levelItems.Where(i => !i.IsRequired && athleteSel.Contains(i.Id)).Sum(i => i.Cost);
                            var fees = requiredCost + optionalCost;
                            var paid = payments.Where(p => p.AthleteId == athlete.Id && p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).Sum(p => p.Amount);
                            var credits = payments.Where(p => p.AthleteId == athlete.Id && p.Type == PaymentType.Credit).Sum(p => p.Amount);
                            var balance = fees - paid - credits;
                            var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == athlete.Id);
                            var levelName = teamLevels.FirstOrDefault(t => t.Id == athlete.TeamLevelId)?.Name ?? "";

                            <tr>
                                <td><strong>@athlete.Name</strong></td>
                                <td>@levelName</td>
                                <td class="text-end">$@fees.ToString("N2")</td>
                                <td class="text-end text-success">$@paid.ToString("N2")</td>
                                <td class="text-end @(balance <= 0 ? "text-success" : "text-danger") fw-bold">$@balance.ToString("N2")</td>
                                <td class="text-center">
                                    @if (balance <= 0)
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else if (paid > 0)
                                    {
                                        <span class="badge bg-warning text-dark">Partial</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Unpaid</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (link?.IsClaimed == true)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else if (link != null)
                                    {
                                        <span class="badge bg-secondary font-monospace">@link.InviteCode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="2">Totals</td>
                            <td class="text-end">$@totalOwed.ToString("N2")</td>
                            <td class="text-end text-success">$@totalPaid.ToString("N2")</td>
                            <td class="text-end">$@(totalOwed - totalPaid).ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private List<TeamLevel> teamLevels = new();
    private List<AthleteItem> athleteItems = new();
    private List<Athlete> athletes = new();
    private List<AthleteItemSelection> selections = new();
    private List<Payment> payments = new();
    private List<ParentLink> parentLinks = new();
    private int selectedSeasonId;
    private string? userId;
    private ProjectLabels labels = ProjectLabels.Default;
    private bool showCreditForm;
    private int creditAthleteId;
    private decimal creditAmount;
    private string creditDescription = "";
    private string? creditMessage;

    private List<Payment> paidPayments => payments.Where(p => p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).ToList();
    private decimal totalCredits => payments.Where(p => p.Type == PaymentType.Credit).Sum(p => p.Amount);
    private decimal totalPaid => paidPayments.Sum(p => p.Amount) + totalCredits;
    private decimal totalOwed => athletes.Sum(a =>
    {
        var items = athleteItems.Where(i => i.TeamLevelId == a.TeamLevelId).ToList();
        var req = items.Where(i => i.IsRequired).Sum(i => i.Cost);
        var sel = selections.Where(s => s.AthleteId == a.Id).Select(s => s.AthleteItemId).ToHashSet();
        var opt = items.Where(i => !i.IsRequired && sel.Contains(i.Id)).Sum(i => i.Cost);
        return req + opt;
    });

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        using var db = await DbFactory.CreateDbContextAsync();
        seasons = await db.Seasons.Where(s => s.IsActive).OrderByDescending(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        await LoadData();
    }

    private async Task ApplyCredit()
    {
        if (creditAthleteId == 0 || creditAmount <= 0) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var athlete = await db.Athletes.FindAsync(creditAthleteId);
        db.Payments.Add(new Payment
        {
            AthleteId = creditAthleteId,
            PayerUserId = userId!,
            Amount = creditAmount,
            Status = PaymentStatus.Paid,
            Type = PaymentType.Credit,
            Description = string.IsNullOrWhiteSpace(creditDescription) ? "Admin credit" : creditDescription,
            PaidAt = DateTime.UtcNow
        });
        await db.SaveChangesAsync();
        creditMessage = $"Credit of ${creditAmount:N2} applied to {athlete?.Name ?? "athlete"}.";
        creditAthleteId = 0;
        creditAmount = 0;
        creditDescription = "";
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        teamLevels = await db.TeamLevels.AsNoTracking().Where(t => t.SeasonId == selectedSeasonId).ToListAsync();
        var levelIds = teamLevels.Select(t => t.Id).ToList();
        athleteItems = await db.AthleteItems.AsNoTracking().Where(i => levelIds.Contains(i.TeamLevelId)).ToListAsync();
        athletes = await db.Athletes.AsNoTracking().Where(a => levelIds.Contains(a.TeamLevelId)).OrderBy(a => a.Name).ToListAsync();
        var athleteIds = athletes.Select(a => a.Id).ToList();
        selections = await db.AthleteItemSelections.AsNoTracking().Where(s => athleteIds.Contains(s.AthleteId)).ToListAsync();
        payments = await db.Payments.AsNoTracking().Where(p => athleteIds.Contains(p.AthleteId)).ToListAsync();
        parentLinks = await db.ParentLinks.AsNoTracking().Where(pl => athleteIds.Contains(pl.AthleteId)).ToListAsync();
    }
}
