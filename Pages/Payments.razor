@page "/payments"
@attribute [Authorize(Roles = "Employee")]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using System.Text
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GymBudgetApp.Services.AuditService AuditService
@inject GymBudgetApp.Services.PermissionService PermissionService
@inject IConfiguration Configuration
@inject IJSRuntime JS

<h3>Payment Tracking</h3>

@if (!canViewPayments)
{
    <div class="alert alert-danger">
        You do not have permission to view payments.
    </div>
}
else if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" @onchange="OnSeasonChanged">
            <option value="">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6>Total Owed</h6>
                        <h4>$@totalOwed.ToString("N2")</h4>
                        <small>@gymnasts.Count gymnast(s)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6>Total Collected</h6>
                        <h4>$@totalPaid.ToString("N2")</h4>
                        <small>@paidPayments.Count payment(s)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6>Outstanding</h6>
                        <h4>$@((totalOwed - totalPaid).ToString("N2"))</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6>Collection Rate</h6>
                        <h4>@(totalOwed > 0 ? (totalPaid / totalOwed * 100).ToString("N0") : "0")%</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <div class="card text-white bg-danger">
                    <div class="card-body">
                        <h6>Needs Follow-Up</h6>
                        <h4>@outstandingRows.Count</h4>
                        <small>@linkedOutstandingRows.Count linked parent(s)</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Apply Credit -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Apply Credit</h5>
                <button class="btn btn-sm @(showCreditForm ? "btn-outline-secondary" : "btn-success")" @onclick="() => showCreditForm = !showCreditForm">
                    @(showCreditForm ? "Cancel" : "+ Apply Credit")
                </button>
            </div>
            @if (showCreditForm)
            {
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Athlete</label>
                            <select class="form-select" @bind="creditAthleteId">
                                <option value="0">-- Select Athlete --</option>
                                @foreach (var a in gymnasts)
                                {
                                    var lvl = a.Level ?? "";
                                    <option value="@a.Id">@a.Name (@lvl)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" min="0.01" step="0.01" @bind="creditAmount" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Reason</label>
                            <input type="text" class="form-control" placeholder="e.g. Overpayment, sibling discount" @bind="creditDescription" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-success w-100" @onclick="ApplyCredit"
                                    disabled="@(creditAthleteId == 0 || creditAmount <= 0)">
                                Apply Credit
                            </button>
                        </div>
                    </div>
                    @if (creditMessage != null)
                    {
                        <div class="alert alert-success mt-3 mb-0">@creditMessage</div>
                    }
                </div>
            }
        </div>

        <!-- Credits -->
        @if (payments.Any(p => p.Type == PaymentType.Credit))
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Credits Applied</h5>
                    @{ var allCredits = payments.Where(p => p.Type == PaymentType.Credit).OrderByDescending(p => p.PaidAt ?? p.CreatedAt).ToList(); }
                    <span class="badge bg-info">@allCredits.Count credit(s) — $@allCredits.Sum(c => c.Amount).ToString("N2") total</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Athlete</th><th>Amount</th><th>Reason</th><th>Date</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in allCredits)
                            {
                                var aName = gymnasts.FirstOrDefault(a => a.Id == c.AthleteId)?.Name ?? "Unknown";
                                var creditId = c.Id;
                                <tr>
                                    <td>@aName</td>
                                    <td class="text-success">-$@c.Amount.ToString("N2")</td>
                                    <td>@(c.Description ?? "Credit")</td>
                                    <td>@(c.PaidAt?.ToString("MMM dd, yyyy") ?? c.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                    <td>
                                        @if (editingPaymentId == creditId)
                                        {
                                            <div class="d-flex gap-1 align-items-center">
                                                <select class="form-select form-select-sm" style="max-width:180px;" @bind="editSeasonId">
                                                    @foreach (var s in seasons!)
                                                    {
                                                        <option value="@s.Id">@s.Name</option>
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-success" @onclick="() => SavePaymentSeason(creditId)">Save</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingPaymentId = 0">X</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditPayment(creditId)">Move</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="d-flex gap-3 mb-3 flex-wrap align-items-end">
            <input type="text" class="form-control" style="max-width: 200px;" placeholder="Search name..." @bind="paymentSearchText" @bind:event="oninput" />
            <select class="form-select" style="max-width: 200px;" @bind="paymentFilterLevel">
                <option value="">All Levels</option>
                @foreach (var lvl in gymnasts.Where(g => !string.IsNullOrEmpty(g.Level)).Select(g => g.Level!).Distinct().OrderBy(l => l))
                {
                    <option value="@lvl">@lvl</option>
                }
            </select>
            <select class="form-select" style="max-width: 200px;" @bind="paymentStatusFilter">
                <option value="All">All Statuses</option>
                <option value="Unpaid">Unpaid</option>
                <option value="Partial">Partial</option>
                <option value="Paid">Paid</option>
                <option value="Outstanding">Outstanding Only</option>
            </select>
            <select class="form-select" style="max-width: 220px;" @bind="paymentParentLinkFilter">
                <option value="All">All Parent Links</option>
                <option value="Claimed">Claimed Parents</option>
                <option value="InvitePending">Invite Pending</option>
                <option value="Missing">No Parent Link</option>
            </select>
            <button class="btn btn-outline-success" @onclick="ExportVisibleRows" disabled="@(!paymentRows.Any())">
                <span class="oi oi-data-transfer-download me-1"></span>Export Visible CSV
            </button>
            <button class="btn btn-outline-primary" @onclick="CopyOutstandingEmails" disabled="@(!outstandingContactEmails.Any())">
                <span class="oi oi-envelope-closed me-1"></span>Copy Outstanding Emails
            </button>
        </div>

        @if (actionMessage != null)
        {
            <div class="alert alert-info py-2">@actionMessage</div>
        }

        @if (outstandingRows.Any())
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Follow-Up Queue</h5>
                    <span class="text-muted small">@outstandingRows.Count athlete(s) with balances</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Athlete</th>
                                <th>Level</th>
                                <th>Balance</th>
                                <th>Parent Contact</th>
                                <th>Link Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in outstandingRows.Take(8))
                            {
                                <tr>
                                    <td>@row.Name</td>
                                    <td>@row.Level</td>
                                    <td class="fw-bold text-danger">$@row.Balance.ToString("N2")</td>
                                    <td>@(string.IsNullOrWhiteSpace(row.ParentContactEmail) ? "—" : row.ParentContactEmail)</td>
                                    <td>
                                        @if (row.ParentLinked)
                                        {
                                            <span class="badge bg-success">Claimed</span>
                                        }
                                        else if (row.HasInviteCode)
                                        {
                                            <span class="badge bg-secondary">Invite Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">Missing Link</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header"><h5 class="mb-0">Athlete Payment Status</h5></div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Athlete</th>
                            <th>@labels.TeamLevel</th>
                            <th class="text-end">Total Fees</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Credits</th>
                            <th class="text-end">Balance</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Parent Link</th>
                            <th>Parent Contact</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in filteredRows)
                        {
                            <tr>
                                <td><strong>@row.Name</strong></td>
                                <td>@row.Level</td>
                                <td class="text-end">$@row.TotalFees.ToString("N2")</td>
                                <td class="text-end text-success">$@row.Paid.ToString("N2")</td>
                                <td class="text-end text-info">$@row.Credits.ToString("N2")</td>
                                <td class="text-end @(row.Balance <= 0 ? "text-success" : "text-danger") fw-bold">$@row.Balance.ToString("N2")</td>
                                <td class="text-center">
                                    @if (row.Balance <= 0)
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else if (row.Paid > 0)
                                    {
                                        <span class="badge bg-warning text-dark">Partial</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Unpaid</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (row.ParentLinked)
                                    {
                                        <span class="badge bg-success">Claimed</span>
                                    }
                                    else if (row.HasInviteCode)
                                    {
                                        <span class="badge bg-secondary font-monospace">@row.InviteCode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(row.ParentContactEmail) ? "—" : row.ParentContactEmail)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="2">Totals</td>
                            <td class="text-end">$@filteredRows.Sum(r => r.TotalFees).ToString("N2")</td>
                            <td class="text-end text-success">$@filteredRows.Sum(r => r.Paid).ToString("N2")</td>
                            <td class="text-end text-info">$@filteredRows.Sum(r => r.Credits).ToString("N2")</td>
                            <td class="text-end">$@filteredRows.Sum(r => r.Balance).ToString("N2")</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private List<Gymnast> gymnasts = new();
    private List<Payment> payments = new();
    private List<ParentLink> parentLinks = new();
    private List<PaymentRow> paymentRows = new();
    private decimal costPerGymnast;
    private string paymentSearchText = "";
    private string paymentFilterLevel = "";
    private string paymentStatusFilter = "All";
    private string paymentParentLinkFilter = "All";
    private string? actionMessage;
    private int selectedSeasonId;
    private string? userId;
    private string? userEmail;
    private ProjectLabels labels = ProjectLabels.Default;
    private bool showCreditForm;
    private int creditAthleteId;
    private decimal creditAmount;
    private string creditDescription = "";
    private string? creditMessage;
    private bool canViewPayments;
    private int editingPaymentId;
    private int editSeasonId;

    private class PaymentRow
    {
        public int AthleteId { get; set; }
        public string Name { get; set; } = "";
        public string Level { get; set; } = "";
        public decimal TotalFees { get; set; }
        public decimal Paid { get; set; }
        public decimal Credits { get; set; }
        public decimal Balance { get; set; }
        public bool ParentLinked { get; set; }
        public bool HasInviteCode { get; set; }
        public string InviteCode { get; set; } = "";
        public string ParentContactEmail { get; set; } = "";
    }

    private List<PaymentRow> filteredRows =>
        paymentRows
            .Where(r => string.IsNullOrWhiteSpace(paymentSearchText)
                || r.Name.Contains(paymentSearchText, StringComparison.OrdinalIgnoreCase))
            .Where(r => string.IsNullOrEmpty(paymentFilterLevel) || r.Level == paymentFilterLevel)
            .Where(MatchesStatusFilter)
            .Where(MatchesParentLinkFilter)
            .OrderByDescending(r => r.Balance)
            .ThenBy(r => r.Name)
            .ToList();

    private List<PaymentRow> outstandingRows =>
        paymentRows
            .Where(r => r.Balance > 0)
            .OrderByDescending(r => r.Balance)
            .ThenBy(r => r.Name)
            .ToList();

    private List<PaymentRow> linkedOutstandingRows =>
        outstandingRows.Where(r => r.ParentLinked).ToList();

    private List<string> outstandingContactEmails =>
        outstandingRows
            .SelectMany(r => r.ParentContactEmail
                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(e => e)
            .ToList();

    private List<Payment> paidPayments => payments.Where(p => p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment).ToList();
    private decimal totalCredits => payments.Where(p => p.Type == PaymentType.Credit).Sum(p => p.Amount);
    private decimal totalPaid => paidPayments.Sum(p => p.Amount) + totalCredits;
    private decimal totalOwed => costPerGymnast * gymnasts.Count;

    private bool MatchesStatusFilter(PaymentRow row) => paymentStatusFilter switch
    {
        "Paid" => row.Balance <= 0,
        "Partial" => row.Balance > 0 && row.Paid > 0,
        "Unpaid" => row.Balance > 0 && row.Paid <= 0,
        "Outstanding" => row.Balance > 0,
        _ => true
    };

    private bool MatchesParentLinkFilter(PaymentRow row) => paymentParentLinkFilter switch
    {
        "Claimed" => row.ParentLinked,
        "InvitePending" => !row.ParentLinked && row.HasInviteCode,
        "Missing" => !row.ParentLinked && !row.HasInviteCode,
        _ => true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value;

        var adminEmails = Configuration.GetSection("AdminEmails").Get<List<string>>()
            ?? new() { Configuration["AdminEmail"] ?? "deshaun@tntgym.org" };
        var isAdmin = adminEmails.Any(ae => string.Equals(userEmail, ae, StringComparison.OrdinalIgnoreCase));
        await PermissionService.LoadAsync(userId, userEmail, isAdmin);
        canViewPayments = isAdmin || PermissionService.CanViewPayments;

        if (!canViewPayments)
            return;

        using var db = await DbFactory.CreateDbContextAsync();
        seasons = await db.Seasons
            .OrderByDescending(s => s.IsActive)
            .ThenByDescending(s => s.Name)
            .ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        selectedSeasonId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        labels = new ProjectLabels(seasons?.FirstOrDefault(s => s.Id == selectedSeasonId));
        actionMessage = null;
        await LoadData();
    }

    private async Task ApplyCredit()
    {
        if (creditAthleteId == 0 || creditAmount <= 0) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var athlete = await db.Gymnasts.FindAsync(creditAthleteId);
        db.Payments.Add(new Payment
        {
            SeasonId = selectedSeasonId,
            AthleteId = creditAthleteId,
            PayerUserId = userId!,
            Amount = creditAmount,
            Status = PaymentStatus.Paid,
            Type = PaymentType.Credit,
            Description = string.IsNullOrWhiteSpace(creditDescription) ? "Admin credit" : creditDescription,
            PaidAt = DateTime.UtcNow
        });
        await db.SaveChangesAsync();
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "CreditApplied", $"Applied ${creditAmount:N2} credit to {athlete?.Name ?? "athlete"}");
        creditMessage = $"Credit of ${creditAmount:N2} applied to {athlete?.Name ?? "athlete"}.";
        creditAthleteId = 0;
        creditAmount = 0;
        creditDescription = "";
        await LoadData();
    }

    private async Task ExportVisibleRows()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Athlete,Level,Total Fees,Paid,Credits,Balance,Status,Parent Link,Parent Contact");
        foreach (var row in filteredRows)
        {
            var status = row.Balance <= 0 ? "Paid" : row.Paid > 0 ? "Partial" : "Unpaid";
            var linkStatus = row.ParentLinked ? "Claimed" : row.HasInviteCode ? "Invite Pending" : "Missing";
            sb.AppendLine($"{EscapeCsv(row.Name)},{EscapeCsv(row.Level)},{row.TotalFees:F2},{row.Paid:F2},{row.Credits:F2},{row.Balance:F2},{status},{EscapeCsv(linkStatus)},{EscapeCsv(row.ParentContactEmail)}");
        }
        await JS.InvokeVoidAsync("downloadFile", $"payments-{selectedSeasonId}-filtered.csv", sb.ToString());
        actionMessage = $"Exported {filteredRows.Count} visible payment row(s).";
    }

    private async Task CopyOutstandingEmails()
    {
        var content = string.Join("; ", outstandingContactEmails);
        await JS.InvokeVoidAsync("copyToClipboard", content);
        actionMessage = outstandingContactEmails.Any()
            ? $"Copied {outstandingContactEmails.Count} outstanding parent email(s)."
            : "No outstanding parent emails were available to copy.";
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var seasonLevelNames = await db.TeamLevels.AsNoTracking()
            .Where(t => t.SeasonId == selectedSeasonId)
            .Select(t => t.Name)
            .ToListAsync();

        var allGymnasts = await db.Gymnasts.AsNoTracking()
            .OrderBy(g => g.Name)
            .ToListAsync();

        gymnasts = allGymnasts
            .Where(g => !string.IsNullOrWhiteSpace(g.Level)
                && seasonLevelNames.Any(levelName => string.Equals(levelName, g.Level, StringComparison.OrdinalIgnoreCase)))
            .ToList();

        var gymnastIds = gymnasts.Select(g => g.Id).ToList();
        // Load all payments for this season (including athletes no longer in the season)
        payments = await db.Payments.AsNoTracking()
            .Where(p => p.SeasonId == selectedSeasonId)
            .ToListAsync();
        // Include orphaned athletes (have payments but no longer match season levels)
        var orphanedAthleteIds = payments.Select(p => p.AthleteId).Distinct()
            .Where(id => !gymnastIds.Contains(id)).ToList();
        if (orphanedAthleteIds.Any())
        {
            var orphanedGymnasts = allGymnasts.Where(g => orphanedAthleteIds.Contains(g.Id)).ToList();
            gymnasts = gymnasts.Concat(orphanedGymnasts).OrderBy(g => g.Name).ToList();
            gymnastIds = gymnasts.Select(g => g.Id).ToList();
        }
        parentLinks = await db.ParentLinks.AsNoTracking().Where(pl => gymnastIds.Contains(pl.AthleteId)).ToListAsync();

        // Calculate cost per gymnast from calculator
        var calcTotal = await db.BudgetCalculatorEntries.AsNoTracking()
            .Where(e => e.SeasonId == selectedSeasonId)
            .SumAsync(e => (decimal?)e.CalculatedTotal) ?? 0;
        var season = await db.Seasons.FindAsync(selectedSeasonId);
        var athleteCount = season?.AthleteCount > 0 ? season.AthleteCount : gymnasts.Count;
        costPerGymnast = athleteCount > 0 ? Math.Round(calcTotal / athleteCount, 2) : 0;

        // Only include athletes who have payments (Stripe or manual) or credits in the system
        var athleteIdsWithPayments = payments
            .Select(p => p.AthleteId)
            .Distinct()
            .ToHashSet();

        paymentRows = gymnasts
            .Where(g => athleteIdsWithPayments.Contains(g.Id))
            .Select(g =>
        {
            var paid = payments
                .Where(p => p.AthleteId == g.Id && p.Status == PaymentStatus.Paid && p.Type == PaymentType.Payment)
                .Sum(p => p.Amount);
            var credits = payments
                .Where(p => p.AthleteId == g.Id && p.Type == PaymentType.Credit)
                .Sum(p => p.Amount);
            var link = parentLinks.FirstOrDefault(pl => pl.AthleteId == g.Id);
            var contactEmails = new[] { g.ParentEmail, g.ParentEmail2 }
                .Where(email => !string.IsNullOrWhiteSpace(email))
                .Select(email => email!.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase);

            return new PaymentRow
            {
                AthleteId = g.Id,
                Name = g.Name,
                Level = g.Level ?? "",
                TotalFees = costPerGymnast,
                Paid = paid,
                Credits = credits,
                Balance = costPerGymnast - paid - credits,
                ParentLinked = link?.IsClaimed == true,
                HasInviteCode = link != null,
                InviteCode = link?.InviteCode ?? "",
                ParentContactEmail = string.Join("; ", contactEmails)
            };
        }).ToList();
    }

    private void StartEditPayment(int paymentId)
    {
        editingPaymentId = paymentId;
        editSeasonId = selectedSeasonId;
    }

    private async Task SavePaymentSeason(int paymentId)
    {
        if (editSeasonId <= 0) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var payment = await db.Payments.FindAsync(paymentId);
        if (payment == null) return;

        var oldSeasonName = (await db.Seasons.FindAsync(payment.SeasonId))?.Name ?? "Unknown";
        var newSeasonName = (await db.Seasons.FindAsync(editSeasonId))?.Name ?? "Unknown";

        payment.SeasonId = editSeasonId;
        await db.SaveChangesAsync();

        var athleteName = (await db.Gymnasts.FindAsync(payment.AthleteId))?.Name ?? "Unknown";
        await AuditService.LogAsync(userId ?? "", userEmail ?? "", "PaymentSeasonChanged",
            $"Moved {payment.Type} ${payment.Amount:N2} for {athleteName} from '{oldSeasonName}' to '{newSeasonName}'");

        editingPaymentId = 0;
        actionMessage = $"Moved {payment.Type.ToString().ToLower()} for {athleteName} to {newSeasonName}.";
        await LoadData();
    }

    private static string EscapeCsv(string? value)
    {
        value ??= "";
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }
}
