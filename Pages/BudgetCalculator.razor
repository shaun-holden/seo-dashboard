@page "/budget-calculator"
@attribute [Authorize]
@using GymBudgetApp.Models
@using GymBudgetApp
@using GymBudgetApp.Services
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<h3>Budget Calculator</h3>

@if (seasons == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label>Select Season</label>
        <select class="form-select w-auto d-inline-block ms-2" value="@selectedSeasonId" @onchange="OnSeasonChanged">
            <option value="0">-- Select Season --</option>
            @foreach (var s in seasons)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    @if (selectedSeasonId > 0)
    {
        <div class="budget-tabs">
            @foreach (var tab in allTabs)
            {
                <button class="budget-tab @(activeTab == tab ? "active" : "")" @onclick="() => SetTab(tab)">@GetTabLabel(tab)</button>
            }
            <button class="budget-tab @(activeTab == addCategoryTab ? "active" : "")" @onclick="() => SetTab(addCategoryTab)">+ Add Category</button>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                @if (activeTab == "TeamEntry")
                {
                    <h5>Team Entry Fees</h5>
                    @if (rosterLevels.Any())
                    {
                        @foreach (var levelName in rosterLevels)
                        {
                            var entry = GetOrCreateEntryByName("TeamEntry", levelName);
                            var lvlName = levelName;
                            <div class="row mb-2 align-items-center">
                                <div class="col-md-3"><label class="form-label mb-0">@levelName</label></div>
                                <div class="col-md-3">
                                    <label class="form-label mb-0 small">Fee/Meet</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                               @onchange="@(e => UpdateTeamEntry(entry, e, "amount"))" />
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label mb-0 small">Meets</label>
                                    <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                           @onchange="@(e => UpdateTeamEntry(entry, e, "q1"))" />
                                </div>
                                <div class="col-md-2 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                                <div class="col-md-2">
                                    <label class="form-label mb-0 small">Actual</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                               @onchange="@(e => UpdateActual(entry, e))" />
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No gymnasts in roster yet. Add gymnasts on the Roster page.</p>
                    }
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("TeamEntry").ToString("N2") | Actual: $@GetCategoryActual("TeamEntry").ToString("N2")</div>
                }
                else if (activeTab == "SessionCost")
                {
                    <h5>Session Costs</h5>
                    @foreach (var entry in GetEntriesForCategory("SessionCost"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Rate/Session</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateSessionCost(entry, e, "amount"))" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Sessions</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                       @onchange="@(e => UpdateSessionCost(entry, e, "q1"))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Coaches</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity2"
                                       @onchange="@(e => UpdateSessionCost(entry, e, "q2"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("SessionCost"))">
                        <span class="oi oi-plus me-1"></span>Add Session Type
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("SessionCost").ToString("N2") | Actual: $@GetCategoryActual("SessionCost").ToString("N2")</div>
                }
                else if (activeTab == "Mileage")
                {
                    <h5>Mileage</h5>
                    @foreach (var entry in GetEntriesForCategory("Mileage"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Miles</label>
                                <input type="number" class="form-control form-control-sm" step="0.01" value="@entry.Amount"
                                       @onchange="@(e => UpdateMileage(entry, e, "amount"))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Rate/Mile</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Quantity1"
                                           @onchange="@(e => UpdateMileage(entry, e, "q1"))" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Trips</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity2"
                                       @onchange="@(e => UpdateMileage(entry, e, "q2"))" />
                            </div>
                            <div class="col-md-1">
                                <label class="form-label mb-0 small">Coaches</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity3"
                                       @onchange="@(e => UpdateMileage(entry, e, "q3"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="() => AddMileageItem()">
                        <span class="oi oi-plus me-1"></span>Add Mileage Entry
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("Mileage").ToString("N2") | Actual: $@GetCategoryActual("Mileage").ToString("N2")</div>
                }
                else if (activeTab == "Flights")
                {
                    <h5>Flights</h5>
                    @foreach (var entry in GetEntriesForCategory("Flights"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Price/Ticket</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateTwoField(entry, e, "amount"))" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Coaches</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                       @onchange="@(e => UpdateTwoField(entry, e, "q1"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("Flights"))">
                        <span class="oi oi-plus me-1"></span>Add Flight
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("Flights").ToString("N2") | Actual: $@GetCategoryActual("Flights").ToString("N2")</div>
                }
                else if (activeTab == "Hotel")
                {
                    <h5>Hotel</h5>
                    @foreach (var entry in GetEntriesForCategory("Hotel"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Price/Night</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateThreeField(entry, e, "amount"))" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Nights</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                       @onchange="@(e => UpdateThreeField(entry, e, "q1"))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Rooms</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity2"
                                       @onchange="@(e => UpdateThreeField(entry, e, "q2"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("Hotel"))">
                        <span class="oi oi-plus me-1"></span>Add Hotel
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("Hotel").ToString("N2") | Actual: $@GetCategoryActual("Hotel").ToString("N2")</div>
                }
                else if (activeTab == "CarRental")
                {
                    <h5>Car Rental</h5>
                    @foreach (var entry in GetEntriesForCategory("CarRental"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Daily Rate</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateThreeField(entry, e, "amount"))" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Days</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                       @onchange="@(e => UpdateThreeField(entry, e, "q1"))" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Vehicles</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity2"
                                       @onchange="@(e => UpdateThreeField(entry, e, "q2"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("CarRental"))">
                        <span class="oi oi-plus me-1"></span>Add Vehicle
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("CarRental").ToString("N2") | Actual: $@GetCategoryActual("CarRental").ToString("N2")</div>
                }
                else if (activeTab == "Coaches")
                {
                    <h5>Coaches</h5>
                    @foreach (var entry in GetEntriesForCategory("Coaches"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Amount/Coach</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateTwoField(entry, e, "amount"))" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Coaches</label>
                                <input type="number" class="form-control form-control-sm" value="@entry.Quantity1"
                                       @onchange="@(e => UpdateTwoField(entry, e, "q1"))" />
                            </div>
                            <div class="col-md-1 text-muted">= $@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <label class="form-label mb-0 small">Actual</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("Coaches"))">
                        <span class="oi oi-plus me-1"></span>Add Coach Entry
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("Coaches").ToString("N2") | Actual: $@GetCategoryActual("Coaches").ToString("N2")</div>
                }
                else if (activeTab == "Miscellaneous")
                {
                    <h5>Miscellaneous</h5>
                    @foreach (var entry in GetEntriesForCategory("Miscellaneous"))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-5">
                                <input type="text" class="form-control form-control-sm" placeholder="Description" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateMiscItem(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1 text-muted">$@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" placeholder="Actual" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="@(() => AddLineItem("Miscellaneous"))">
                        <span class="oi oi-plus me-1"></span>Add Item
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("Miscellaneous").ToString("N2") | Actual: $@GetCategoryActual("Miscellaneous").ToString("N2")</div>
                }
                else if (activeTab == "BankFees")
                {
                    <h5>Bank / Processing Fees</h5>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="bankFeeToggle" checked="@BankFeesEntry.IsPercentage"
                                   @onchange="@(e => ToggleBankFeeMode(BankFeesEntry, e))" />
                            <label class="form-check-label" for="bankFeeToggle">
                                @(BankFeesEntry.IsPercentage ? "Percentage of Subtotal" : "Fixed Amount")
                            </label>
                        </div>
                    </div>
                    @if (BankFeesEntry.IsPercentage)
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Percentage</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" class="form-control" step="0.01" value="@BankFeesEntry.Amount"
                                           @onchange="@(e => UpdateBankFee(BankFeesEntry, e))" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-muted">
                                Subtotal: $@BankFeesSubtotal.ToString("N2") | Fee: $@BankFeesEntry.CalculatedTotal.ToString("N2")
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-3">
                                <label class="form-label mb-0 small">Fixed Amount</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@BankFeesEntry.Amount"
                                           @onchange="@(e => UpdateBankFee(BankFeesEntry, e))" />
                                </div>
                            </div>
                            <div class="col-md-4 text-muted">Fee: $@BankFeesEntry.CalculatedTotal.ToString("N2")</div>
                        </div>
                    }
                    <div class="row mb-2 align-items-center">
                        <div class="col-md-3">
                            <label class="form-label mb-0 small">Actual</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" step="0.01" value="@BankFeesEntry.ActualAmount"
                                       @onchange="@(e => UpdateActual(BankFeesEntry, e))" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal("BankFees").ToString("N2") | Actual: $@GetCategoryActual("BankFees").ToString("N2")</div>
                }
                else if (activeTab == addCategoryTab)
                {
                    <h5>Add Custom Category</h5>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <input type="text" class="form-control" placeholder="Category Name" @bind="newCustomCategoryName" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary" @onclick="AddCustomCategory" disabled="@string.IsNullOrWhiteSpace(newCustomCategoryName)">
                                Create Category
                            </button>
                        </div>
                    </div>
                    @if (customCategories.Any())
                    {
                        <p class="text-muted">Custom categories: @string.Join(", ", customCategories)</p>
                    }
                }
                else if (customCategories.Contains(activeTab))
                {
                    <h5>@activeTab</h5>
                    @foreach (var entry in GetEntriesForCategory(activeTab))
                    {
                        <div class="row mb-2 align-items-center">
                            <div class="col-md-5">
                                <input type="text" class="form-control form-control-sm" placeholder="Description" value="@entry.Name"
                                       @onchange="@(e => UpdateEntryName(entry, e))" />
                            </div>
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" value="@entry.Amount"
                                           @onchange="@(e => UpdateMiscItem(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1 text-muted">$@entry.CalculatedTotal.ToString("N2")</div>
                            <div class="col-md-2">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" step="0.01" placeholder="Actual" value="@entry.ActualAmount"
                                           @onchange="@(e => UpdateActual(entry, e))" />
                                </div>
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => DuplicateEntry(entry)" title="Copy">
                                    <span class="oi oi-clipboard"></span>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEntry(entry)">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="() => AddLineItem(activeTab)">
                        <span class="oi oi-plus me-1"></span>Add Item
                    </button>
                    <div class="mt-3 fw-bold">Category Total: $@GetCategoryTotal(activeTab).ToString("N2") | Actual: $@GetCategoryActual(activeTab).ToString("N2")</div>
                }
            </div>
        </div>

        <!-- Grand Total Bar -->
        <div class="budget-grand-total">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var tab in allTabs)
                        {
                            var catTotal = GetCategoryTotal(tab);
                            @if (catTotal != 0)
                            {
                                <span><small class="text-white-50">@GetTabLabel(tab):</small> $@catTotal.ToString("N2")</span>
                            }
                        }
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <div style="font-size: 1.25rem; font-weight: bold;">Total Budget: $@grandTotal.ToString("N2") | Actual: $@grandActual.ToString("N2")</div>
                    <div class="@(grandTotal - grandActual >= 0 ? "text-white-50" : "text-warning")">Variance: $@((grandTotal - grandActual).ToString("N2"))</div>
                    @if (seasonAthleteCount > 0)
                    {
                        <div class="text-white-50">Cost Per Gymnast: $@((grandTotal / seasonAthleteCount).ToString("N2")) (@seasonAthleteCount gymnasts)</div>
                    }
                </div>
            </div>
        </div>
    }
}

@code {
    private List<Season>? seasons;
    private int selectedSeasonId;
    private string activeTab = "TeamEntry";
    private List<string> rosterLevels = new();
    private List<BudgetCalculatorEntry> entries = new();
    private int seasonAthleteCount;
    private decimal grandTotal;
    private decimal grandActual;
    private string newCustomCategoryName = string.Empty;
    private List<string> customCategories = new();
    private const string addCategoryTab = "AddCategory";

    private BudgetCalculatorEntry BankFeesEntry => GetOrCreateBankFeesEntry();
    private decimal BankFeesSubtotal => GetSubtotalExcluding("BankFees");

    private readonly List<string> defaultTabs = new()
    {
        "TeamEntry", "SessionCost", "Mileage", "Flights", "Hotel",
        "CarRental", "Coaches", "Miscellaneous", "BankFees"
    };

    private List<string> allTabs => defaultTabs.Concat(customCategories).ToList();

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        seasons = await db.Seasons.Where(s => s.IsActive).OrderBy(s => s.Name).ToListAsync();
    }

    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id) && id > 0)
        {
            selectedSeasonId = id;
            await LoadSeasonData();
        }
        else
        {
            selectedSeasonId = 0;
            entries.Clear();
            rosterLevels.Clear();
        }
    }

    private async Task LoadSeasonData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        rosterLevels = await db.Gymnasts
            .Where(g => !string.IsNullOrEmpty(g.Level))
            .Select(g => g.Level!)
            .Distinct()
            .OrderBy(l => l)
            .ToListAsync();

        var season = await db.Seasons.FindAsync(selectedSeasonId);
        seasonAthleteCount = season?.AthleteCount ?? 0;
        if (seasonAthleteCount == 0)
        {
            seasonAthleteCount = await db.Gymnasts.CountAsync();
        }

        entries = await db.BudgetCalculatorEntries
            .Where(e => e.SeasonId == selectedSeasonId)
            .ToListAsync();

        // Discover custom categories
        customCategories = entries
            .Where(e => !defaultTabs.Contains(e.Category))
            .Select(e => e.Category)
            .Distinct()
            .ToList();

        RecalcGrandTotal();
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private string GetTabLabel(string tab)
    {
        return tab switch
        {
            "TeamEntry" => "Team Entry",
            "SessionCost" => "Session Cost",
            "CarRental" => "Car Rental",
            "BankFees" => "Bank Fees",
            _ => tab
        };
    }

    // ---- Team Entry ----
    private BudgetCalculatorEntry GetOrCreateEntry(string category, int? teamLevelId = null)
    {
        var entry = entries.FirstOrDefault(e => e.Category == category && e.TeamLevelId == teamLevelId);
        if (entry == null)
        {
            entry = new BudgetCalculatorEntry
            {
                SeasonId = selectedSeasonId,
                Category = category,
                TeamLevelId = teamLevelId
            };
            entries.Add(entry);
        }
        return entry;
    }

    private BudgetCalculatorEntry GetOrCreateEntryByName(string category, string name)
    {
        var entry = entries.FirstOrDefault(e => e.Category == category && e.Name == name);
        if (entry == null)
        {
            entry = new BudgetCalculatorEntry
            {
                SeasonId = selectedSeasonId,
                Category = category,
                Name = name
            };
            entries.Add(entry);
        }
        return entry;
    }

    private async Task UpdateTeamEntry(BudgetCalculatorEntry entry, ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            switch (field)
            {
                case "amount": entry.Amount = val; break;
                case "q1": entry.Quantity1 = val; break;
            }
            entry.CalculatedTotal = entry.Amount * entry.Quantity1;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Session Cost: Rate x Sessions x Coaches ----
    private async Task UpdateSessionCost(BudgetCalculatorEntry entry, ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            switch (field)
            {
                case "amount": entry.Amount = val; break;
                case "q1": entry.Quantity1 = val; break;
                case "q2": entry.Quantity2 = val; break;
            }
            entry.CalculatedTotal = entry.Amount * entry.Quantity1 * entry.Quantity2;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Mileage: Miles x Rate x Trips x Coaches ----
    private async Task UpdateMileage(BudgetCalculatorEntry entry, ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            switch (field)
            {
                case "amount": entry.Amount = val; break;
                case "q1": entry.Quantity1 = val; break;
                case "q2": entry.Quantity2 = val; break;
                case "q3": entry.Quantity3 = val; break;
            }
            entry.CalculatedTotal = entry.Amount * entry.Quantity1 * entry.Quantity2 * entry.Quantity3;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Two-field: Amount x Quantity1 (Flights, Coaches) ----
    private async Task UpdateTwoField(BudgetCalculatorEntry entry, ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            switch (field)
            {
                case "amount": entry.Amount = val; break;
                case "q1": entry.Quantity1 = val; break;
            }
            entry.CalculatedTotal = entry.Amount * entry.Quantity1;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Three-field: Amount x Q1 x Q2 (Hotel, CarRental) ----
    private async Task UpdateThreeField(BudgetCalculatorEntry entry, ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            switch (field)
            {
                case "amount": entry.Amount = val; break;
                case "q1": entry.Quantity1 = val; break;
                case "q2": entry.Quantity2 = val; break;
            }
            entry.CalculatedTotal = entry.Amount * entry.Quantity1 * entry.Quantity2;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Misc / Custom: just Amount ----
    private async Task UpdateMiscItem(BudgetCalculatorEntry entry, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            entry.Amount = val;
            entry.CalculatedTotal = val;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    // ---- Bank Fees ----
    private BudgetCalculatorEntry GetOrCreateBankFeesEntry()
    {
        var entry = entries.FirstOrDefault(e => e.Category == "BankFees");
        if (entry == null)
        {
            entry = new BudgetCalculatorEntry
            {
                SeasonId = selectedSeasonId,
                Category = "BankFees"
            };
            entries.Add(entry);
        }
        return entry;
    }

    private async Task ToggleBankFeeMode(BudgetCalculatorEntry entry, ChangeEventArgs e)
    {
        entry.IsPercentage = bool.TryParse(e.Value?.ToString(), out var v) && v;
        RecalcBankFee(entry);
        await SaveEntry(entry);
        RecalcGrandTotal();
    }

    private async Task UpdateBankFee(BudgetCalculatorEntry entry, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            entry.Amount = val;
            RecalcBankFee(entry);
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    private void RecalcBankFee(BudgetCalculatorEntry entry)
    {
        if (entry.IsPercentage)
        {
            var subtotal = GetSubtotalExcluding("BankFees");
            entry.CalculatedTotal = Math.Round(subtotal * entry.Amount / 100m, 2);
        }
        else
        {
            entry.CalculatedTotal = entry.Amount;
        }
    }

    private decimal GetSubtotalExcluding(string excludeCategory)
    {
        return entries.Where(e => e.Category != excludeCategory).Sum(e => e.CalculatedTotal);
    }

    // ---- Entry Name ----
    private async Task UpdateEntryName(BudgetCalculatorEntry entry, ChangeEventArgs e)
    {
        entry.Name = e.Value?.ToString();
        await SaveEntry(entry);
    }

    // ---- Add / Delete ----
    private async Task AddLineItem(string category)
    {
        var entry = new BudgetCalculatorEntry
        {
            SeasonId = selectedSeasonId,
            Category = category
        };
        entries.Add(entry);
        await SaveEntry(entry);
    }

    private async Task AddMileageItem()
    {
        var entry = new BudgetCalculatorEntry
        {
            SeasonId = selectedSeasonId,
            Category = "Mileage",
            Quantity1 = 0.67m // default rate per mile
        };
        entries.Add(entry);
        await SaveEntry(entry);
    }

    private async Task DeleteEntry(BudgetCalculatorEntry entry)
    {
        entries.Remove(entry);
        if (entry.Id > 0)
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var dbEntry = await db.BudgetCalculatorEntries.FindAsync(entry.Id);
            if (dbEntry != null)
            {
                db.BudgetCalculatorEntries.Remove(dbEntry);
                await db.SaveChangesAsync();
            }
        }
        RecalcGrandTotal();
    }

    private async Task DuplicateEntry(BudgetCalculatorEntry source)
    {
        var copy = new BudgetCalculatorEntry
        {
            SeasonId = selectedSeasonId,
            Category = source.Category,
            Name = source.Name + " (copy)",
            Amount = source.Amount,
            Quantity1 = source.Quantity1,
            Quantity2 = source.Quantity2,
            Quantity3 = source.Quantity3,
            CalculatedTotal = source.CalculatedTotal,
            IsPercentage = source.IsPercentage
        };
        entries.Add(copy);
        await SaveEntry(copy);
        RecalcGrandTotal();
    }

    private async Task AddCustomCategory()
    {
        if (string.IsNullOrWhiteSpace(newCustomCategoryName)) return;
        var name = newCustomCategoryName.Trim();
        if (!customCategories.Contains(name) && !defaultTabs.Contains(name))
        {
            customCategories.Add(name);
        }
        newCustomCategoryName = string.Empty;
        activeTab = name;
    }

    // ---- Helpers ----
    private List<BudgetCalculatorEntry> GetEntriesForCategory(string category)
    {
        return entries.Where(e => e.Category == category).ToList();
    }

    private decimal GetCategoryTotal(string category)
    {
        return entries.Where(e => e.Category == category).Sum(e => e.CalculatedTotal);
    }

    private decimal GetCategoryActual(string category)
    {
        return entries.Where(e => e.Category == category).Sum(e => e.ActualAmount);
    }

    private void RecalcGrandTotal()
    {
        // Recalc bank fees based on current subtotal
        var bankEntry = entries.FirstOrDefault(e => e.Category == "BankFees");
        if (bankEntry != null && bankEntry.IsPercentage)
        {
            RecalcBankFee(bankEntry);
        }
        grandTotal = entries.Sum(e => e.CalculatedTotal);
        grandActual = entries.Sum(e => e.ActualAmount);
    }

    private async Task UpdateActual(BudgetCalculatorEntry entry, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            entry.ActualAmount = val;
            await SaveEntry(entry);
            RecalcGrandTotal();
        }
    }

    private async Task SaveEntry(BudgetCalculatorEntry entry)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        if (entry.Id == 0)
        {
            db.BudgetCalculatorEntries.Add(entry);
            await db.SaveChangesAsync();
        }
        else
        {
            db.BudgetCalculatorEntries.Update(entry);
            await db.SaveChangesAsync();
        }
    }
}
